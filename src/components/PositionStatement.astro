---
/* Home position statement — the brand's opening line on the page.
   ------------------------------------------------------------------
   REBUILD (2026-05-23). The first cut centred the line vertically in a
   tall section and unveiled it with a single masked rise. This version
   anchors the line at the top of the section — the gap from the
   nav-bar's bottom edge to the top of the headline equals one
   nav-height of breathing room (84px desktop, 66px mobile, matching
   Header.astro). The line is split into two halves that slide in from
   opposite sides ("Volcanic Soul." from the left, "24-Carat Gold."
   from the right) and settle into one composed sentence.

   Treatment per the conventions overlay: "Volcanic Soul." pink, the rest
   ink, both halves display italic, wrapping naturally — not locked to
   one line. The sub-line follows, quieter. */

import dividerGoldLeaf from '../assets/divider-gold-leaf.svg?raw';

interface Props {
  /** Brand position copy split into the pink half and the ink half. */
  positionPink: string;
  positionInk: string;
  subline: string;
}
const { positionPink, positionInk, subline } = Astro.props;
---

{/* Half-level colour split (Stephane 2026-05-23, second iteration).
    Left half: "Volcanic Soul." pink. Right half: "24-Carat Gold."
    gold-deep. Ink is dropped from the headline entirely; each half is
    now uniform colour. The per-word span structure is kept (slide
    motion is unaffected) so future word-level tweaks remain cheap.
    positionPink / positionInk props are passed through unused so
    home.json stays valid; the spans are hard-coded because a single
    brand line doesn't earn the structured-data overhead. */}
<section class="position" aria-label="Mariposa" data-position>
  <div class="position__inner container">
    {/* The position sentence. Each half lives inside a horizontal
        clipping mask; the inner line slides in from its side on entry
        and settles into the centred composition. */}
    <h2 class="position__line">
      <span class="position__half position__half--first">
        <span class="slide-mask">
          <span class="slide-inner" data-direction="left">
            <span class="position__em">Volcanic</span>{' '}<span class="position__em">Soul.</span>
          </span>
        </span>
      </span>
      <span class="position__half position__half--second">
        <span class="slide-mask">
          <span class="slide-inner" data-direction="right">
            <span class="position__gold">24-Carat</span>{' '}<span class="position__gold">Gold.</span>
          </span>
        </span>
      </span>
    </h2>

    {/* Deterministic two-line sub-line. Both halves are wrapped in
        block-display, nowrap spans so the break sits exactly after
        "occasions," at every viewport. Same pattern as the footer
        brand-line lead/tail. The whole .position__subline still drives
        the fade-in as one element; both lines reveal together. */}
    <p class="position__subline" data-position-subline>
      <span class="position__subline-lead">For those who don't wait for special occasions,</span><span class="position__subline-tail">but create them.</span>
    </p>

    {/* Gold-leaf divider. Reintroduced 2026-05-23 below the sub-line as
        a quiet close to the section, separating the position statement
        from the product section that follows. Inlined via `?raw` so the
        stroke inherits currentColor and the file ships as part of the
        component bundle. Static — no draw-in. */}
    <div class="position__divider" aria-hidden="true" set:html={dividerGoldLeaf} />
  </div>
</section>

<style>
  .position {
    /* Plain opaque white through the section (Stephane 2026-05-23,
       revert). An earlier iteration faded white→transparent over the
       final 180px so the body texture could bleed in; with the body
       texture gone and the cream wedge restored on the product
       section below, the fade has no destination — the .range__bleed
       handles the white→cream seam now. Reverted to flat white.
       Top padding equals one nav-height (84px desktop / 66px mobile),
       matching the gap from the nav-bar's bottom edge to the headline.
       Bottom padding is intentionally tighter (~2/3 of top) per
       Stephane's 2026-05-23 iteration: closes the gap between the
       sub-line and the top of the Volage frame in the product section.
       Asymmetry is deliberate; do not re-symmetrise. */
    background: var(--white);
    padding-top: 84px;
    padding-bottom: 21px;
  }
  @media (max-width: 720px) {
    .position {
      padding-top: 66px;
      padding-bottom: 17px;
    }
  }

  .position__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  /* Position sentence — display italic, staircase cascade.
     ----------------------------------------------------------------
     Stagger (Stephane 2026-05-23, revised): the two halves stack on
     separate lines across the full container width. Each half is
     `white-space: nowrap` so neither can wrap internally regardless
     of column width — the max-width cap is gone, the staircase does
     all the line-breaking. First half hugs the left third, second
     half hugs the right third, on a wide stage. Per-half slide-in
     motion is unaffected (the masks sit inside the offset halves). */
  .position__line {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 1.08;
    letter-spacing: var(--ls-display);
    margin: 0;
    /* No max-width cap: white-space: nowrap on each half does the
       line-breaking job. Full container width is the cascade stage. */
    text-align: left;
    width: 100%;
  }
  .position__half {
    display: block;
    /* Force each half on one line regardless of cascade offsets or
       container width. Stops "24-Carat Gold." from breaking onto two
       lines at the display italic size. */
    white-space: nowrap;
  }
  /* First half anchored hard left of the cascade stage. */
  .position__half--first {
    margin-left: 0;
  }
  /* Second half pushed right to read as a clearly diagonal staircase.
     Was 14% — now 30% desktop. */
  .position__half--second {
    margin-left: 30%;
  }
  @media (max-width: 480px) {
    /* Narrower viewport, tighter (but still bigger than the old 10%)
       stagger so the staircase still reads without the second half
       running off the right edge. */
    .position__half--second {
      margin-left: 18%;
    }
  }
  /* Half-level colour spans. `--em` = pink (left half: "Volcanic
     Soul."), `--gold` = gold-deep (right half: "24-Carat Gold.").
     Gold-deep is chosen over gold-leaf so the words hold their weight
     against the white background and partner the pink at display size
     without washing out. */
  .position__em { color: var(--pink); }
  .position__gold { color: var(--gold-deep); }

  /* Horizontal slide-in mask. Each half is wrapped in a clipping box
     wide enough to absorb the off-stage transform; the inner element
     translates in from its side. Padding/negative margin pairs leave
     room for the italic's ascenders/descenders without clipping. */
  .slide-mask {
    display: inline-block;
    overflow: hidden;
    padding: 0.16em 0.06em;
    margin: -0.16em -0.06em;
    vertical-align: bottom;
  }
  .slide-inner {
    display: inline-block;
    /* JS sets the entry transform. Without JS the line is simply in
       place — no flash of off-stage content. */
  }

  .position__subline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    /* Fluid: 14px at ~320px viewport, scales to 28px desktop ceiling.
       Floor chosen so the lead clause (46ch) fits in the 272px content
       width at narrowest target without wrapping. Same pattern as the
       footer brand-line: keep the desktop ceiling, drop the floor. */
    font-size: clamp(14px, 4.4vw, 1.75rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    /* Headline-to-subline gap. Approximates the prior rhythm when a
       gold-leaf divider sat between them (top + bottom margins of the
       divider summed to roughly this value). Removed divider 2026-05-23. */
    margin-top: clamp(var(--space-4), 4vw, var(--space-6));
    margin-left: auto;
    margin-right: auto;
    max-width: 46ch;
  }
  /* Forces the break immediately after "occasions,". Both halves are
     block-display, nowrap, so the line split is deterministic at every
     viewport and the lead never wraps internally. */
  .position__subline-lead,
  .position__subline-tail {
    display: block;
    white-space: nowrap;
  }

  /* Gold-leaf divider under the sub-line. Width clamped per the
     conventions overlay; vertical margins give air above (separating
     from the sub-line) and a smaller breath below before the section
     ends. The asset's gradient handles the fade — no extra colour
     here. Static, per Stephane 2026-05-23. */
  .position__divider {
    width: clamp(64px, 8vw, 96px);
    margin-top: clamp(var(--space-5), 3.5vw, var(--space-6));
    margin-bottom: var(--space-3);
    margin-left: auto;
    margin-right: auto;
    line-height: 0;
  }
  .position__divider :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .position { min-height: 0; }
  }
</style>

<script>
  import { gsap, slideIn, REDUCED } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-position]');
  if (section) {
    const halves = section.querySelectorAll<HTMLElement>('.slide-inner');
    const subline = section.querySelector<HTMLElement>('[data-position-subline]');
    const rightHalf = section.querySelector<HTMLElement>('.slide-inner[data-direction="right"]');

    // Two halves slide in from opposite sides and settle.
    slideIn(halves, { start: 'top 78%' });

    // Sub-line: pure fade-in, no Y translation. Anchored to the same
    // trigger as the right-side headline half so the two reveals start
    // together and resolve together — the sub-line appears with
    // "24-Carat Gold." landing in place.
    if (subline) {
      if (REDUCED) {
        gsap.set(subline, { opacity: 1 });
      } else {
        gsap.set(subline, { opacity: 0 });
        gsap.to(subline, {
          opacity: 1,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: rightHalf ?? subline,
            start: 'top 78%',
            toggleActions: 'play none none none',
          },
        });
      }
    }
  }
</script>
