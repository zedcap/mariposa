---
/* Home hero — contained image slider.
   ------------------------------------------------------------------
   HEIGHT (2026-05-22). The hero is a CONTAINED band, not full-viewport.
   The site runs the marigold.global nav pattern: the menu sits below
   the hero and sticks to the top on scroll. That placement only reads
   if the menu is actually visible below the hero on load. A 100svh hero
   pushes the menu under the fold, so the "menu below hero" pattern is
   invisible until the user scrolls — which defeats it. Containing the
   hero so the nav bar shows underneath on first paint is the pattern
   working as designed. Stephane's call; not a regression to a header
   strip — the band stays rich (six frames, Ken Burns, slider motion),
   only the height is capped.

   The section carries its own choreography: a slow scale on the active
   frame and a plain cross-fade between slides.

   Hero imagery renders in ORIGINAL COLOUR — a deliberate override of
   the design system's "full-bleed photography = B&W / duotone" rule.
   Stephane's call (2026-05-22); recorded in mariposa-design-conventions.md.

   6 frames, slow auto-advance (7s) → 42s loop. No manual nav, no dots:
   the slider is a passive, auto-only band (Stephane's call, 2026-05-23).
   Pause on hover preserved. prefers-reduced-motion: no Ken Burns,
   instant cross-fade.

   ART DIRECTION (2026-05-24). The phone breakpoint now serves a
   purpose-cropped portrait source (3:4, 1472×1963) rather than
   re-cropping the landscape original in CSS. Astro's <Image> has no
   built-in art direction, so each frame ships a <picture> with a
   <source media="(max-width: 720px)" srcset=...> generated via
   getImage(), and a desktop <img> fallback. */
import { getImage } from 'astro:assets';

/* Mariposa hero frames — the collage device: the same faceless woman
   with a cigar across six scene-and-ground variants, in colour.
   Numeric order 1 → 6 as delivered. Landscape source, 3200×1800 (16:9).
   Mobile source is a pre-cropped 3:4 portrait, 1472×1963. */
import heroImage1 from '../assets/hero-mp-1.jpg';
import heroImage2 from '../assets/hero-mp-2.jpg';
import heroImage3 from '../assets/hero-mp-3.jpg';
import heroImage4 from '../assets/hero-mp-4.jpg';
import heroImage5 from '../assets/hero-mp-5.jpg';
import heroImage6 from '../assets/hero-mp-6.jpg';

/* Desktop-only static hero (2026-05-26). Desktop renders frame 1 as a
   single static image using the `_1d` source; mobile carousel is
   unchanged. Frames 2-6 are hidden on desktop via CSS and auto-advance
   is gated to mobile breakpoint only. Revert by pointing frame 1's
   desktop source back at `heroImage1` and removing the gating. */
import heroImage1Desktop from '../assets/hero-mp-1d.jpg';

import heroImage1Mobile from '../assets/hero-mp-1-mobile.jpg';
import heroImage2Mobile from '../assets/hero-mp-2-mobile.jpg';
import heroImage3Mobile from '../assets/hero-mp-3-mobile.jpg';
import heroImage4Mobile from '../assets/hero-mp-4-mobile.jpg';
import heroImage5Mobile from '../assets/hero-mp-5-mobile.jpg';
import heroImage6Mobile from '../assets/hero-mp-6-mobile.jpg';

const heroImages = [
  heroImage1,
  heroImage2,
  heroImage3,
  heroImage4,
  heroImage5,
  heroImage6,
];

const heroImagesMobile = [
  heroImage1Mobile,
  heroImage2Mobile,
  heroImage3Mobile,
  heroImage4Mobile,
  heroImage5Mobile,
  heroImage6Mobile,
];

interface Slide {
  key: string;
  caption: string;
}
interface Props {
  slides: Slide[];
}
const { slides } = Astro.props;

/* Pre-resolve responsive sources at build time. getImage() returns a
   `srcSet` we can hand to <source>/<img>; widths chosen per breakpoint
   (mobile band tops out around a phone width, desktop band goes wide). */
const desktopSources = await Promise.all(
  heroImages.map((src, i) =>
    getImage({
      /* Frame 1's desktop source is the static `_1d` image; frames 2-6
         keep the `_c` series (still bundled, but hidden on desktop). */
      src: i === 0 ? heroImage1Desktop : src,
      widths: [720, 1280, 1920, 2560],
      sizes: '100vw',
      format: 'webp',
    }),
  ),
);
const mobileSources = await Promise.all(
  heroImagesMobile.map((src) =>
    getImage({
      src,
      widths: [480, 720, 1080, 1472],
      sizes: '100vw',
      format: 'webp',
    }),
  ),
);
---

<section class="hero" aria-label="Mariposa" data-hero>
  <div class="hero__track">
    {
      slides.map((slide, i) => {
        const desktop = desktopSources[i] ?? desktopSources[0];
        const mobile = mobileSources[i] ?? mobileSources[0];
        const isFirst = i === 0;
        return (
          <div
            class:list={['hero__slide', { 'is-active': isFirst }]}
            data-slide
            aria-hidden={isFirst ? 'false' : 'true'}
          >
            <div class="hero__frame" data-hero-frame>
              <picture>
                <source
                  media="(max-width: 720px)"
                  srcset={mobile.srcSet.attribute}
                  sizes="100vw"
                  type="image/webp"
                />
                <img
                  class="hero__img"
                  src={desktop.src}
                  srcset={desktop.srcSet.attribute}
                  sizes="100vw"
                  alt={slide.caption}
                  width={desktop.attributes.width}
                  height={desktop.attributes.height}
                  loading={isFirst ? 'eager' : 'lazy'}
                  fetchpriority={isFirst ? 'high' : 'auto'}
                  decoding="async"
                />
              </picture>
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .hero {
    /* Contained band — sized so the nav menu below the hero is visible
       on first paint without scrolling (the marigold.global pattern).
       64svh on a standard desktop viewport leaves the full 84px nav bar
       clearly in view; the min/max keep that true across screen sizes.
       Rich imagery and motion live inside this height, not beyond it. */
    position: relative;
    height: 64svh;
    min-height: 440px;
    max-height: 720px;
    overflow: hidden;
    background: var(--ink);
  }

  .hero__track {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* Plain cross-fade between slides — no gold wash. */
    transition: opacity var(--dur-slow) var(--ease-paper);
  }
  .hero__slide.is-active {
    opacity: 1;
  }

  /* The frame is the element the Ken Burns scale acts on, kept separate
     from the fading slide so the two transforms never fight. */
  .hero__frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__frame picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Original colour — hero is a deliberate override of the design
       system's full-bleed duotone rule. No filter. */
    will-change: transform;
  }

  @media (max-width: 720px) {
    .hero {
      /* On a phone the band is a 3:4 portrait — purpose-cropped sources
         land at 1472×1963 (essentially 3:4). The mobile <source> in the
         <picture> serves those directly, so no CSS object-position
         per-frame trickery is needed any more (removed 2026-05-24). */
      height: auto;
      min-height: 0;
      max-height: none;
      aspect-ratio: 3 / 4;
    }
  }

  /* Desktop static hero (2026-05-26). Frame 1 stays visible (always
     `.is-active` because JS auto-advance is gated to mobile); frames
     2-6 are hidden so only the single `_1d` image renders. Mobile
     carousel keeps cycling — overrides scoped to min-width: 721px. */
  @media (min-width: 721px) {
    .hero__slide:not(:first-of-type) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide { transition: opacity 0.01ms; }
  }
</style>

<script>
  import { gsap, REDUCED } from '../lib/motion';

  const hero = document.querySelector<HTMLElement>('[data-hero]');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-slide]'));
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-frame]'));
  const ADVANCE_MS = 7000;

  /* Desktop static hero (2026-05-26). Auto-advance and Ken Burns only
     run at the mobile breakpoint; on desktop frame 1 stays as a single
     static image (frames 2-6 are hidden via CSS). */
  const IS_MOBILE = window.matchMedia('(max-width: 720px)').matches;

  if (hero && slides.length > 1 && IS_MOBILE) {
    let current = 0;
    let timer: number | undefined;
    let kenBurns: gsap.core.Tween | undefined;

    /* Ken Burns — the active frame eases from slightly enlarged toward
       true size over the full dwell. Slow, analogue: the eye should
       never catch it as a discrete move, only feel the frame breathe.
       The marigold hero gives its imagery the same quiet life. */
    const animateFrame = (idx: number) => {
      if (REDUCED) return;
      kenBurns?.kill();
      const frame = frames[idx];
      if (!frame) return;
      gsap.set(frame, { scale: 1.0, xPercent: 0 });
      kenBurns = gsap.fromTo(
        frame,
        { scale: 1.0, xPercent: 0 },
        {
          scale: 1.08,
          xPercent: idx % 2 === 0 ? 1.2 : -1.2,
          duration: (ADVANCE_MS + 1400) / 1000,
          ease: 'none',
        },
      );
    };

    const show = (next: number) => {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');

      current = (next + slides.length) % slides.length;

      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      animateFrame(current);
    };

    const start = () => {
      if (REDUCED) return;
      stop();
      timer = window.setInterval(() => show(current + 1), ADVANCE_MS);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      kenBurns?.pause();
    };
    const resume = () => {
      kenBurns?.resume();
      start();
    };

    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', resume);

    animateFrame(0);
    start();
  }
</script>
