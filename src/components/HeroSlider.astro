---
/* Home hero — full-bleed image slider.
   ------------------------------------------------------------------
   REBUILD (2026-05-21). The first cut sat the hero in a 64svh contained
   band; it read as a header strip, not a hero. This rebuild restores
   full-viewport scale (the Marigold hero is full-bleed) and gives each
   slide a slow Ken Burns scale so the imagery is alive rather than
   static. No text overlay on the imagery — resolved — but the section
   carries its own choreography: a slow scale on the active frame, a
   cross-fade through a sliver of gold, a thin gold progress line that
   fills over the dwell time, and a quiet drifting scroll cue.

   4 frames, slow auto-advance (7s), pause on hover, manual ticks.
   prefers-reduced-motion: no Ken Burns, no progress fill, instant
   cross-fade, scroll cue static.

   ============================ PLACEHOLDER IMAGERY ============================
   The four hero frames below are PLACEHOLDERS, not final art.
   - hero-image0 / hero-image1 / hero-image2 are MARIGOLD's own hero
     photographs, pulled from the Marigold Shopify theme. They belong to
     another brand and MUST NOT ship on the live Mariposa site.
   - hero-image3 is a separately supplied stand-in.
   All four are temporary holds until Mariposa's commissioned photography
   lands (shot list in website-scope.md §7). SWAP ALL FOUR before launch.
   ============================================================================ */
import { Image } from 'astro:assets';

/* PLACEHOLDER hero frames — see banner above. Order is fixed:
   image0 → image1 → image2 → image3, matching the four caption slides. */
import heroImage0 from '../assets/hero-image0.jpg';
import heroImage1 from '../assets/hero-image1.jpg';
import heroImage2 from '../assets/hero-image2.jpg';
import heroImage3 from '../assets/hero-image3.jpg';

const heroImages = [heroImage0, heroImage1, heroImage2, heroImage3];

interface Slide {
  key: string;
  caption: string;
}
interface Props {
  slides: Slide[];
}
const { slides } = Astro.props;
---

<section class="hero" aria-label="Mariposa" data-hero>
  <div class="hero__track">
    {
      slides.map((slide, i) => (
        <div
          class:list={['hero__slide', { 'is-active': i === 0 }]}
          data-slide
          aria-hidden={i === 0 ? 'false' : 'true'}
        >
          <div class="hero__frame" data-hero-frame>
            {/* PLACEHOLDER image — frames 0-2 are Marigold's photos. */}
            <Image
              class="hero__img"
              src={heroImages[i] ?? heroImages[0]}
              alt={slide.caption}
              widths={[720, 1280, 1920, 2400]}
              sizes="100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
            />
          </div>
        </div>
      ))
    }
  </div>

  {/* Slow vignette — anchors the imagery to the white page below. */}
  <div class="hero__veil" aria-hidden="true"></div>

  {/* Indicators — thin gold ticks; the active tick carries a fill bar
      that runs over the dwell time, so the slider's pace is legible. */}
  <div class="hero__indicators" role="tablist" aria-label="Hero slides">
    {
      slides.map((slide, i) => (
        <button
          class:list={['hero__tick', { 'is-active': i === 0 }]}
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Show slide ${i + 1}`}
          data-tick={i}
        >
          <span class="hero__tick-fill" data-tick-fill></span>
        </button>
      ))
    }
  </div>

  {/* Scroll cue — a quiet "keep going" mark; it drifts on a loop. */}
  <div class="hero__cue" data-hero-cue aria-hidden="true">
    <span class="hero__cue-line"></span>
  </div>
</section>

<style>
  .hero {
    /* Full-bleed — the rebuild restores real hero scale. The brand
       impression has to land within the first viewport. */
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background: var(--ink);
  }

  .hero__track {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* Cross-fade through a sliver of gold: the outgoing slide fades to
       a faint gold wash before the incoming one resolves. The wash is
       the gold sliver from the design system's page-transition spec. */
    transition: opacity var(--dur-slow) var(--ease-paper);
  }
  .hero__slide.is-active {
    opacity: 1;
  }

  /* The frame is the element the Ken Burns scale acts on, kept separate
     from the fading slide so the two transforms never fight. */
  .hero__frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Duotone — full-bleed photography reads B&W / warm sepia. */
    filter: grayscale(1) sepia(0.26) contrast(1.05) brightness(0.8);
    will-change: transform;
  }

  /* Vignette — a soft darkening at the foot so the white page below
     enters cleanly, and a faint top wash so the resting nav reads. */
  .hero__veil {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(to bottom, rgba(28, 25, 21, 0.32) 0%, transparent 22%),
      linear-gradient(to top, rgba(28, 25, 21, 0.5) 0%, transparent 30%);
  }

  /* Indicators — thin gold ticks, bottom-left, generous from the edge. */
  .hero__indicators {
    position: absolute;
    left: var(--page-pad-d);
    bottom: var(--space-8);
    display: flex;
    gap: var(--space-3);
    z-index: 4;
  }

  .hero__tick {
    position: relative;
    width: 52px;
    height: 2px;
    padding: 0;
    border: 0;
    background: rgba(255, 255, 255, 0.26);
    cursor: pointer;
    overflow: hidden;
    transition: background-color var(--dur-default) var(--ease-paper);
  }
  .hero__tick:hover {
    background: rgba(255, 255, 255, 0.5);
  }
  .hero__tick-fill {
    position: absolute;
    inset: 0;
    transform-origin: left center;
    transform: scaleX(0);
    background: var(--gold-leaf);
  }
  /* The active tick's fill is animated by JS (a GSAP tween over the
     dwell). The static rule keeps the active tick lit when JS is off. */
  .hero__tick.is-active {
    background: rgba(255, 255, 255, 0.26);
  }
  .hero__tick.is-active .hero__tick-fill {
    transform: scaleX(1);
  }

  /* Scroll cue — a thin vertical gold line, bottom-centre. The line
     itself runs a slow downward drift on a loop (CSS keyframe; GSAP is
     not needed for a pure loop). */
  .hero__cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-7);
    transform: translateX(-50%);
    width: 1px;
    height: 56px;
    z-index: 4;
    overflow: hidden;
  }
  .hero__cue-line {
    display: block;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--gold-leaf) 45%,
      var(--gold-leaf) 55%,
      transparent 100%
    );
    animation: hero-cue-drift 2600ms var(--ease-drift) infinite;
  }
  @keyframes hero-cue-drift {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  @media (max-width: 720px) {
    .hero__indicators {
      left: var(--page-pad-m);
      bottom: var(--space-7);
    }
    .hero__tick { width: 40px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cue-line { animation: none; }
    .hero__slide { transition: opacity 0.01ms; }
  }
</style>

<script>
  import { gsap, REDUCED } from '../lib/motion';

  const hero = document.querySelector<HTMLElement>('[data-hero]');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-slide]'));
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-frame]'));
  const ticks = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tick]'));
  const fills = Array.from(document.querySelectorAll<HTMLElement>('[data-tick-fill]'));
  const ADVANCE_MS = 7000;

  if (hero && slides.length > 1) {
    let current = 0;
    let timer: number | undefined;
    let kenBurns: gsap.core.Tween | undefined;
    let fillTween: gsap.core.Tween | undefined;

    /* Ken Burns — the active frame eases from slightly enlarged toward
       true size over the full dwell. Slow, analogue: the eye should
       never catch it as a discrete move, only feel the frame breathe.
       The marigold hero gives its imagery the same quiet life. */
    const animateFrame = (idx: number) => {
      if (REDUCED) return;
      kenBurns?.kill();
      const frame = frames[idx];
      if (!frame) return;
      gsap.set(frame, { scale: 1.0, xPercent: 0 });
      kenBurns = gsap.fromTo(
        frame,
        { scale: 1.0, xPercent: 0 },
        {
          scale: 1.08,
          xPercent: idx % 2 === 0 ? 1.2 : -1.2,
          duration: (ADVANCE_MS + 1400) / 1000,
          ease: 'none',
        },
      );
    };

    /* The active tick's fill bar runs left-to-right over the dwell, so
       the slider's pace is visible without a heavy progress UI. */
    const runFill = (idx: number) => {
      if (REDUCED) return;
      fillTween?.kill();
      fills.forEach((f, i) => gsap.set(f, { scaleX: i === idx ? 0 : 0 }));
      const fill = fills[idx];
      if (!fill) return;
      fillTween = gsap.fromTo(
        fill,
        { scaleX: 0 },
        { scaleX: 1, duration: ADVANCE_MS / 1000, ease: 'none' },
      );
    };

    const show = (next: number) => {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      ticks[current]?.classList.remove('is-active');
      ticks[current]?.setAttribute('aria-selected', 'false');
      if (!REDUCED) gsap.set(fills[current], { scaleX: 0 });

      current = (next + slides.length) % slides.length;

      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      ticks[current]?.classList.add('is-active');
      ticks[current]?.setAttribute('aria-selected', 'true');
      animateFrame(current);
      runFill(current);
    };

    const start = () => {
      if (REDUCED) return;
      stop();
      timer = window.setInterval(() => show(current + 1), ADVANCE_MS);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      fillTween?.pause();
      kenBurns?.pause();
    };
    const resume = () => {
      fillTween?.resume();
      kenBurns?.resume();
      start();
    };

    ticks.forEach((tick, i) => {
      tick.addEventListener('click', () => {
        show(i);
        start();
      });
    });

    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', resume);

    animateFrame(0);
    runFill(0);
    start();
  }
</script>
