---
/* Age gate — revised design mock.
   ------------------------------------------------------------------
   2026-05-25. Single revised design replacing the prior four-option
   comparison page. Stephane has picked the direction: a centred
   white card on a 50% white overlay, with the home page visible
   behind. Card includes wordmark, italic Spectral question, two
   side-by-side buttons (ink-filled Yes / outlined No), a checked-
   by-default "Remember me on this device" tickbox, and a small
   disclaimer with an inline Terms & Conditions link that fires the
   existing `mariposa:open-terms` event.

   Direct-URL only. NOT linked from the nav. The live AgeGate.astro
   component is UNTOUCHED — this is a visual mock only. None of the
   localStorage / sessionStorage logic is wired here; the overlay is
   simply rendered visible so Stephane can see the design.

   The backdrop is mocked inline (hero image + a position-statement
   excerpt) rather than rendering the real home page, to avoid this
   mock page double-mounting components and to keep the layered
   effect legible regardless of the live gate's visibility state. */

import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroBg from '../assets/hero-mp-1.jpg';

const home = (await getEntry('site', 'home'))!.data as {
  position: { positionPink: string; positionInk: string; subline: string };
};
const { position } = home;
---

<BaseLayout title="Mariposa • Age gate — revised design mock">

  {/* Ribbon banner — internal label, sits above everything. */}
  <div class="ribbon">
    <div class="container">
      <span class="ribbon__text">
        Age Gate Mock &mdash; Revised Design. Live age gate unchanged.
      </span>
    </div>
  </div>

  {/* ═══════════════════════════════════════════════════════════════
      Stage — a contained viewport-scale surface that holds the
      mocked backdrop, the 50% white overlay, and the centred card.
      Aspect-ratio locked so the layered effect reads consistently
      regardless of screen size.
      ═══════════════════════════════════════════════════════════════ */}

  <div class="stage-wrap">
    <div class="stage" aria-label="Revised age gate preview">

      {/* Backdrop — representative of the home page underneath. */}
      <Image
        src={heroBg}
        alt="Mariposa home page hero, shown as the backdrop the age gate sits over."
        class="stage__bg"
        widths={[800, 1200, 1800]}
        sizes="1200px"
      />
      <div class="stage__backdrop-content" aria-hidden="true">
        <div class="stage__position">
          <span class="stage__position-pink">{position.positionPink}</span>{' '}
          <span class="stage__position-ink">{position.positionInk}</span>
        </div>
      </div>

      {/* Overlay — full-stage, 50% white, blocks the page beneath. */}
      <div class="stage__overlay" aria-hidden="true"></div>

      {/* Card — centred, opaque white, pink hairline, editorial frame. */}
      <div class="gate-card" role="dialog" aria-modal="true" aria-labelledby="mock-age-q">
        <span class="wordmark gate-card__mark">mariposa</span>

        <h2 class="gate-card__question" id="mock-age-q">Are you 21 or older?</h2>

        <div class="gate-card__choices">
          <button class="gate-btn gate-btn--solid" type="button">Yes, I am</button>
          <button class="gate-btn gate-btn--outline" type="button">No</button>
        </div>

        <label class="gate-card__remember">
          <input type="checkbox" class="gate-check" checked />
          <span class="gate-card__remember-text">Remember me on this device</span>
        </label>

        <p class="gate-card__disclaimer">
          By continuing, you confirm that you are of legal smoking age
          and agree to our{' '}
          <button type="button" class="gate-card__terms" data-open-terms>
            Terms &amp; Conditions
          </button>.
        </p>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  /* ─── Ribbon banner ──────────────────────────────────────── */
  .ribbon {
    background: var(--ink);
    color: var(--white);
    padding-block: var(--space-3);
  }
  .ribbon__text {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    letter-spacing: var(--ls-small);
    color: var(--pearl);
  }

  /* ─── Stage wrap ─────────────────────────────────────────── */
  .stage-wrap {
    background: var(--pearl);
    padding-block: clamp(var(--space-7), 6vw, var(--space-9));
    padding-inline: var(--page-pad-m);
    display: flex;
    justify-content: center;
  }
  .stage {
    position: relative;
    width: 100%;
    max-width: 1200px;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    box-shadow: var(--shadow-lift);
    background: var(--ink);
  }

  /* ─── Backdrop ───────────────────────────────────────────── */
  .stage__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .stage__backdrop-content {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: clamp(var(--space-7), 6vw, var(--space-9));
    z-index: 1;
  }
  .stage__position {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.6rem, 3.4vw, 2.6rem);
    line-height: var(--lh-snug);
    color: var(--white);
    text-align: center;
    max-width: 28ch;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }
  .stage__position-pink { color: var(--pink); font-style: italic; }
  .stage__position-ink  { color: var(--white); }

  /* ─── Overlay — 50% white ────────────────────────────────── */
  .stage__overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--white) 50%, transparent);
    z-index: 2;
  }

  /* ═══════════════════════════════════════════════════════════
     Gate card — centred, opaque, pink hairline.
     ═══════════════════════════════════════════════════════════ */
  .gate-card {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;

    width: min(440px, 90vw);
    background: var(--white);
    border: 1px solid var(--pink);

    padding-block: var(--space-7);
    padding-inline: var(--space-8);

    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .gate-card__mark {
    font-size: var(--fs-h5);
    color: var(--ink);
    line-height: 1;
  }

  .gate-card__question {
    margin: var(--space-6) 0 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: var(--lh-snug);
    color: var(--ink);
  }

  .gate-card__choices {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
    width: 100%;
    justify-content: center;
  }

  /* Buttons — square corners (--radius-xs) for the editorial register,
     matching the brand's quieter button language used on cards and
     inputs rather than the loud pill used in the live gate. */
  .gate-btn {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: var(--ls-small);
    border-radius: var(--radius-xs);
    padding: 12px 24px;
    cursor: pointer;
    flex: 1 1 auto;
    min-width: 120px;
    transition:
      background-color var(--dur-default) var(--ease-paper),
      color var(--dur-default) var(--ease-paper);
  }
  .gate-btn--solid {
    color: var(--white);
    background: var(--ink);
    border: 1px solid var(--ink);
  }
  .gate-btn--solid:hover {
    background: color-mix(in srgb, var(--ink) 85%, var(--white));
  }
  .gate-btn--outline {
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--ink);
  }
  .gate-btn--outline:hover {
    background: var(--pearl);
  }

  /* Remember-me — checkbox + label on one row. */
  .gate-card__remember {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--ink-soft);
  }
  .gate-check {
    appearance: none;
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border: 1px solid var(--ink);
    background: var(--white);
    border-radius: 2px;
    display: inline-grid;
    place-content: center;
    cursor: pointer;
    margin: 0;
  }
  .gate-check::before {
    content: '';
    width: 8px;
    height: 8px;
    transform: scale(0);
    transition: transform var(--dur-quick) var(--ease-paper);
    background: var(--ink);
    border-radius: 1px;
  }
  .gate-check:checked::before {
    transform: scale(1);
  }
  .gate-check:focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 2px;
  }

  .gate-card__disclaimer {
    margin: var(--space-4) 0 0 0;
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    line-height: var(--lh-body);
    color: var(--ash);
    max-width: 36ch;
  }
  .gate-card__terms {
    font: inherit;
    color: var(--ink);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .gate-card__terms:hover { color: var(--pink-deep); }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .stage { aspect-ratio: 3 / 4; }
    .gate-card {
      padding-block: var(--space-6);
      padding-inline: var(--space-6);
    }
    .gate-card__choices { flex-wrap: wrap; }
  }
</style>

<script>
  /* Mock-only: wire the Terms & Conditions link to the existing
     TermsModal event. Yes / No / checkbox are intentionally inert —
     James will spec the live behaviour separately. */
  const termsBtn = document.querySelector<HTMLButtonElement>('[data-open-terms]');
  termsBtn?.addEventListener('click', () => {
    window.dispatchEvent(
      new CustomEvent('mariposa:open-terms', { detail: { opener: termsBtn } })
    );
  });
</script>
</content>
</invoke>