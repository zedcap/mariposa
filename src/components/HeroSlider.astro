---
/* Home hero — contained image slider.
   ------------------------------------------------------------------
   HEIGHT (2026-05-22). The hero is a CONTAINED band, not full-viewport.
   The site runs the marigold.global nav pattern: the menu sits below
   the hero and sticks to the top on scroll. That placement only reads
   if the menu is actually visible below the hero on load. A 100svh hero
   pushes the menu under the fold, so the "menu below hero" pattern is
   invisible until the user scrolls — which defeats it. Containing the
   hero so the nav bar shows underneath on first paint is the pattern
   working as designed. Stephane's call; not a regression to a header
   strip — the band stays rich (frames, Ken Burns, slider motion),
   only the height is capped.

   Hero imagery renders in ORIGINAL COLOUR — a deliberate override of
   the design system's "full-bleed photography = B&W / duotone" rule.
   Stephane's call (2026-05-22); recorded in mariposa-design-conventions.md.

   SPLIT MARKUP (2026-05-26). Desktop and mobile run independent
   carousels. Two separate `<div data-hero>` blocks; CSS hides one per
   viewport; each has its own JS loop. Cleanest separation because the
   two cycles differ in both source set and frame sequence.

   DESKTOP. 4-frame custom sequence using the d-series 1200×630 sources:
   d1 → d3 → d2 → d3 (loop). d3 appears twice (positions 2 and 4).
   7-second dwell, cross-fade. Single static `_1d` previously; now
   restored as a 4-step cycle (Stephane's call, 2026-05-26).

   MOBILE. 4-frame custom sequence mirroring desktop, using the d-series
   mobile portrait sources: m1d → m3d → m2d → m3d (loop). m3d appears
   twice (positions 2 and 4). 7-second dwell, Ken Burns on the active
   frame. Replaces the previous 6-frame `_c` series cycle (2026-05-26).

   prefers-reduced-motion: no Ken Burns, instant cross-fade, no
   auto-advance (handled in JS via REDUCED flag). */
import { getImage } from 'astro:assets';

/* Mariposa hero frames — the collage device: the same faceless woman
   with a cigar across variants, in colour. */

/* Desktop d-series (1200×630). Three distinct frames; the sequence
   visits d3 twice per loop. */
import heroImage1Desktop from '../assets/hero-mp-1d.jpg';
import heroImage2Desktop from '../assets/hero-mp-2d.jpg';
import heroImage3Desktop from '../assets/hero-mp-3d.jpg';

/* Mobile d-series (purpose-cropped 3:4 portrait). Three distinct frames;
   the sequence visits m3d twice per loop, mirroring desktop. */
import heroImage1Mobile from '../assets/hero-mp-1d-mobile.jpg';
import heroImage2Mobile from '../assets/hero-mp-2d-mobile.jpg';
import heroImage3Mobile from '../assets/hero-mp-3d-mobile.jpg';

/* Desktop carousel sequence — d1, d3, d2, d3. Order matters; d3 must
   appear at positions 2 and 4 of the four-step loop. */
const desktopSequence = [
  heroImage1Desktop,
  heroImage3Desktop,
  heroImage2Desktop,
  heroImage3Desktop,
];

/* Mobile carousel sequence — m1d, m3d, m2d, m3d. Mirrors desktop. */
const mobileSequence = [
  heroImage1Mobile,
  heroImage3Mobile,
  heroImage2Mobile,
  heroImage3Mobile,
];

interface Slide {
  key: string;
  caption: string;
}
interface Props {
  slides: Slide[];
}
const { slides } = Astro.props;

/* Pre-resolve responsive sources at build time. Desktop widths sized
   for the 1200px cap; mobile widths for the phone band. */
const desktopSources = await Promise.all(
  desktopSequence.map((src) =>
    getImage({
      src,
      widths: [720, 1200, 1600, 2400],
      sizes: '(min-width: 721px) min(100vw, 1200px), 100vw',
      format: 'webp',
    }),
  ),
);
const mobileSources = await Promise.all(
  mobileSequence.map((src) =>
    getImage({
      src,
      widths: [480, 720, 1080, 1472],
      sizes: '100vw',
      format: 'webp',
    }),
  ),
);

/* Captions for each 4-step sequence reuse the closest matching `slides`
   entries by index where available; fall back to the first. Desktop and
   mobile share the same d1/d3/d2/d3 mapping. */
const desktopCaptions = [
  slides[0]?.caption ?? '',
  slides[2]?.caption ?? slides[0]?.caption ?? '',
  slides[1]?.caption ?? slides[0]?.caption ?? '',
  slides[2]?.caption ?? slides[0]?.caption ?? '',
];
const mobileCaptions = desktopCaptions;
---

{/* Desktop carousel — 4-frame d-series sequence (d1, d3, d2, d3). */}
<section class="hero hero--desktop" aria-label="Mariposa" data-hero-desktop>
  <div class="hero__track">
    {
      desktopSources.map((img, i) => {
        const isFirst = i === 0;
        return (
          <div
            class:list={['hero__slide', { 'is-active': isFirst }]}
            data-slide-desktop
            aria-hidden={isFirst ? 'false' : 'true'}
          >
            <div class="hero__frame">
              <img
                class="hero__img"
                src={img.src}
                srcset={img.srcSet.attribute}
                sizes="(min-width: 721px) min(100vw, 1200px), 100vw"
                alt={desktopCaptions[i]}
                width={img.attributes.width}
                height={img.attributes.height}
                loading={isFirst ? 'eager' : 'lazy'}
                fetchpriority={isFirst ? 'high' : 'auto'}
                decoding="async"
              />
            </div>
          </div>
        );
      })
    }
  </div>
</section>

{/* Mobile carousel — 4-frame d-series sequence (m1d, m3d, m2d, m3d). */}
<section class="hero hero--mobile" aria-label="Mariposa" data-hero-mobile>
  <div class="hero__track">
    {
      mobileSources.map((img, i) => {
        const isFirst = i === 0;
        return (
          <div
            class:list={['hero__slide', { 'is-active': isFirst }]}
            data-slide-mobile
            aria-hidden={isFirst ? 'false' : 'true'}
          >
            <div class="hero__frame" data-hero-frame-mobile>
              <img
                class="hero__img"
                src={img.src}
                srcset={img.srcSet.attribute}
                sizes="100vw"
                alt={mobileCaptions[i]}
                width={img.attributes.width}
                height={img.attributes.height}
                loading={isFirst ? 'eager' : 'lazy'}
                fetchpriority={isFirst ? 'high' : 'auto'}
                decoding="async"
              />
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--ink);
  }

  /* Desktop band — locked to native 1200×630 proportions of the d-series
     sources and capped at 1200px wide so the image NEVER scales (no crop,
     no upscale blur). Centred horizontally; body white fills the margins
     on wider monitors. Sits under the previous 720px max-height, so the
     nav below the hero remains visible on first paint. */
  .hero--desktop {
    max-width: 1200px;
    aspect-ratio: 1200 / 630;
    margin: 0 auto;
  }

  /* Mobile band — 3:4 portrait, full-bleed. */
  .hero--mobile {
    aspect-ratio: 3 / 4;
  }

  /* Viewport gating — only the matching block renders per breakpoint.
     Avoids running two JS loops or paying for two image sets at runtime. */
  @media (min-width: 721px) {
    .hero--mobile { display: none; }
  }
  @media (max-width: 720px) {
    .hero--desktop { display: none; }
  }

  .hero__track {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* Plain cross-fade between slides — no gold wash. */
    transition: opacity var(--dur-slow) var(--ease-paper);
  }
  .hero__slide.is-active {
    opacity: 1;
  }

  /* The frame is the element the Ken Burns scale acts on, kept separate
     from the fading slide so the two transforms never fight. */
  .hero__frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Original colour — hero is a deliberate override of the design
       system's full-bleed duotone rule. No filter. */
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide { transition: opacity 0.01ms; }
  }
</style>

<script>
  import { gsap, REDUCED } from '../lib/motion';

  const ADVANCE_MS = 7000;

  /* Desktop carousel — 4-frame d-series cycle, plain cross-fade only
     (no Ken Burns on the d-series; the d frames are tightly composed
     and the scale was a `_c`-series touch). */
  const desktopHero = document.querySelector<HTMLElement>('[data-hero-desktop]');
  const desktopSlides = Array.from(
    document.querySelectorAll<HTMLElement>('[data-slide-desktop]'),
  );

  if (desktopHero && desktopSlides.length > 1) {
    let current = 0;
    let timer: number | undefined;

    const show = (next: number) => {
      desktopSlides[current].classList.remove('is-active');
      desktopSlides[current].setAttribute('aria-hidden', 'true');
      current = (next + desktopSlides.length) % desktopSlides.length;
      desktopSlides[current].classList.add('is-active');
      desktopSlides[current].setAttribute('aria-hidden', 'false');
    };

    const start = () => {
      if (REDUCED) return;
      stop();
      timer = window.setInterval(() => show(current + 1), ADVANCE_MS);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
    };

    desktopHero.addEventListener('mouseenter', stop);
    desktopHero.addEventListener('mouseleave', start);

    start();
  }

  /* Mobile carousel — 4-frame d-series cycle (m1d, m3d, m2d, m3d) with
     Ken Burns on the active frame. Mirrors desktop sequence. */
  const mobileHero = document.querySelector<HTMLElement>('[data-hero-mobile]');
  const mobileSlides = Array.from(
    document.querySelectorAll<HTMLElement>('[data-slide-mobile]'),
  );
  const mobileFrames = Array.from(
    document.querySelectorAll<HTMLElement>('[data-hero-frame-mobile]'),
  );

  if (mobileHero && mobileSlides.length > 1) {
    let current = 0;
    let timer: number | undefined;
    let kenBurns: gsap.core.Tween | undefined;

    const animateFrame = (idx: number) => {
      if (REDUCED) return;
      kenBurns?.kill();
      const frame = mobileFrames[idx];
      if (!frame) return;
      gsap.set(frame, { scale: 1.0, xPercent: 0 });
      kenBurns = gsap.fromTo(
        frame,
        { scale: 1.0, xPercent: 0 },
        {
          scale: 1.08,
          xPercent: idx % 2 === 0 ? 1.2 : -1.2,
          duration: (ADVANCE_MS + 1400) / 1000,
          ease: 'none',
        },
      );
    };

    const show = (next: number) => {
      mobileSlides[current].classList.remove('is-active');
      mobileSlides[current].setAttribute('aria-hidden', 'true');
      current = (next + mobileSlides.length) % mobileSlides.length;
      mobileSlides[current].classList.add('is-active');
      mobileSlides[current].setAttribute('aria-hidden', 'false');
      animateFrame(current);
    };

    const start = () => {
      if (REDUCED) return;
      stop();
      timer = window.setInterval(() => show(current + 1), ADVANCE_MS);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      kenBurns?.pause();
    };
    const resume = () => {
      kenBurns?.resume();
      start();
    };

    mobileHero.addEventListener('mouseenter', stop);
    mobileHero.addEventListener('mouseleave', resume);

    animateFrame(0);
    start();
  }
</script>
