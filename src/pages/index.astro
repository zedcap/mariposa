---
/* Home — one-page vertical scroll.
   Hero slider (no text), brand position statement, product section
   (Option B), lifestyle section. The hero goes into BaseLayout's named
   `hero` slot, so the nav rests directly below it on load and sticks to
   the top on scroll (marigold.global pattern). Copy comes from content
   collections. */
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import PositionStatement from '../components/PositionStatement.astro';
import ProductSlider from '../components/ProductSlider.astro';
import LifestyleSection from '../components/LifestyleSection.astro';

const home = (await getEntry('site', 'home'))!.data as {
  hero: {
    slides: { key: string; caption: string }[];
  };
  position: { positionPink: string; positionInk: string; subline: string };
  lifestyle: {
    eyebrow: string;
    paragraphs: string[];
    closingLine: string;
    aboutLinkLabel: string;
  };
};

const products = (await getCollection('products'))
  .map((entry) => entry.data)
  .sort((a, b) => a.order - b.order);
---

<BaseLayout title="Mariposa — Cuban Soul. 24 Carat Swiss Gold.">
  <HeroSlider slot="hero" slides={home.hero.slides} />

  <PositionStatement
    positionPink={home.position.positionPink}
    positionInk={home.position.positionInk}
    subline={home.position.subline}
  />

  <ProductSlider products={products} />

  <LifestyleSection
    eyebrow={home.lifestyle.eyebrow}
    paragraphs={home.lifestyle.paragraphs}
    closingLine={home.lifestyle.closingLine}
    aboutLinkLabel={home.lifestyle.aboutLinkLabel}
  />
</BaseLayout>
