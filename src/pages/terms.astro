---
/* ════════════════════════════════════════════════════════════════
   /terms — Terms & Conditions

   PLACEHOLDER content — Stephane to supply final terms via legal
   review. The structure here (eight standard sections) is a wireframe
   so the route, footer link, and page register can be agreed before
   real copy lands. Replace each section body when counsel returns
   approved language; the page chrome and styles should not need to
   change.

   Header + Footer are injected by BaseLayout; do not import them
   here. Sticky contact is also injected globally.
   ════════════════════════════════════════════════════════════════ */
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Use of Site',
    body: [
      'Access to and use of the Mariposa website is offered to you conditional on your acceptance of the terms set out on this page. By browsing, requesting information, or otherwise interacting with the site, you agree to be bound by these terms in full.',
      'You may not use the site for any purpose that is unlawful, that infringes the rights of others, or that interferes with the operation of the site or its underlying infrastructure. Mariposa reserves the right to restrict or withdraw access at any time without notice.',
    ],
  },
  {
    title: 'Intellectual Property',
    body: [
      'All content on this site, including text, photography, illustrations, marks, and layout, is the property of Mariposa or its licensors and is protected by applicable intellectual-property laws. No content may be reproduced, distributed, or used to create derivative works without prior written permission.',
      'The Mariposa name, wordmark, and visual identity are reserved. Use of the brand for commentary, journalism, or fair-use purposes is permitted in line with standard practice.',
    ],
  },
  {
    title: 'Disclaimer of Warranties',
    body: [
      'The site and its content are provided on an "as is" and "as available" basis. Mariposa makes no representations or warranties of any kind, express or implied, as to the accuracy, completeness, or suitability of any information provided.',
      'Mariposa does not warrant that the site will be uninterrupted, error-free, secure, or free from harmful components. Use of the site is at your own risk.',
    ],
  },
  {
    title: 'Limitation of Liability',
    body: [
      'To the maximum extent permitted by law, Mariposa, its principals, employees, and partners shall not be liable for any indirect, incidental, consequential, special, or punitive damages arising out of or in connection with your use of the site, even if Mariposa has been advised of the possibility of such damages.',
      'Where liability cannot be excluded, it is limited to the minimum permitted under applicable law.',
    ],
  },
  {
    title: 'Privacy',
    body: [
      'Mariposa respects your privacy. Any personal information collected through this site — for example, the email address you provide when contacting us — is handled in line with applicable data-protection law and used only for the purpose for which you supplied it.',
      'We do not sell personal information to third parties. A full privacy notice will be published alongside these terms in due course.',
    ],
  },
  {
    title: 'Governing Law',
    body: [
      'These terms are governed by and construed in accordance with the laws of the jurisdiction in which Mariposa is established, without regard to its conflict-of-law principles. Any dispute arising under or in connection with these terms shall be subject to the exclusive jurisdiction of the competent courts in that jurisdiction.',
    ],
  },
  {
    title: 'Changes to Terms',
    body: [
      'Mariposa may revise these terms from time to time. The current version is always the one published on this page, with the date below taken as the date of last update. Continued use of the site after a revision constitutes acceptance of the revised terms.',
    ],
  },
  {
    title: 'Contact',
    body: [
      'Questions about these terms should be directed to the email address listed on the sticky contact element in the lower-right corner of every page.',
    ],
  },
];

const lastUpdated = '24 May 2026';
---

<BaseLayout
  title="Mariposa • Terms"
  description="Terms and conditions for the Mariposa website."
>
  <article class="terms">
    <div class="terms__inner">
      <header class="terms__header">
        <p class="terms__eyebrow">Legal</p>
        <h1 class="terms__title">Terms &amp; Conditions</h1>
        <hr class="rule-gold terms__rule" />
        <p class="terms__updated">Last updated · {lastUpdated}</p>
      </header>

      {sections.map((s) => (
        <section class="terms__section">
          <h2 class="terms__h2">{s.title}</h2>
          {s.body.map((p) => <p class="terms__p">{p}</p>)}
        </section>
      ))}
    </div>
  </article>
</BaseLayout>

<style>
  /* ─── Page chrome ─────────────────────────────────────────── */
  .terms {
    padding-block: clamp(var(--space-8), 10vw, var(--space-10));
    background: var(--white);
  }
  .terms__inner {
    max-width: 740px;            /* constrained measure, brief: ~700-800px */
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 32px);
  }

  /* ─── Header ──────────────────────────────────────────────── */
  .terms__header {
    margin-bottom: var(--space-9);
  }
  .terms__eyebrow {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 var(--space-4);
  }
  .terms__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(var(--fs-h3), 5.5vw, var(--fs-h2));
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    color: var(--ink);
    margin: 0 0 var(--space-5);
  }
  .terms__rule {
    margin: 0 0 var(--space-4);
  }
  .terms__updated {
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--ash);
    margin: 0;
  }

  /* ─── Sections ────────────────────────────────────────────── */
  .terms__section {
    margin-top: var(--space-8);
  }
  .terms__section:first-of-type {
    margin-top: 0;
  }
  .terms__h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--fs-h4);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-display);
    color: var(--ink);
    margin: 0 0 var(--space-4);
  }
  .terms__p {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-soft);
    margin: 0 0 var(--space-4);
  }
  .terms__p:last-child {
    margin-bottom: 0;
  }
</style>
