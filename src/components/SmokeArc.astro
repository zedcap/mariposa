---
/* SmokeArc — tasting notes as a vertical sequence.
   ------------------------------------------------------------------
   Section 5 of a SKU page. The brief's Option B (preferred over a
   horizontal scroll): a sticky gold timeline on the left margin
   tracks the three thirds as the reader scrolls through them.

   Implementation: CSS `position: sticky` for the timeline column,
   no JS dependency for the pin. Active-tick highlighting uses an
   IntersectionObserver that watches each third and toggles a class
   on the corresponding marker. Reduced-motion: no animation; the
   sticky behaviour still works (it's layout, not motion), but if
   it ever feels intrusive at that setting the sticky can be
   neutralised under the media query.

   Mobile: timeline collapses inline above each third — the brief's
   stated mobile fallback.

   Marks (2026-05-24, Stephane): one ordinal label per third (1st /
   2nd / 3rd) instead of minute timecodes. Three marks for three
   thirds, 1:1 with the IntersectionObserver active-third logic. No
   closing tick — the line ends at the third mark.

   Pairings: NOT implemented this build. The brief flags them as a
   future addition pending Axel-drafted copy. */

interface Stage {
  stage: string;        // e.g. "First third"
  note: string;
}

interface Props {
  tasting: Stage[];     // expected length 3, but the component is
                        // agnostic; whatever it gets, it lays out.
  /* Labels paired one-to-one with `tasting`. Strings so the
     component doesn't have to know about formatting. */
  marks?: string[];
}

const {
  tasting,
  marks = ["1st", "2nd", "3rd"],
} = Astro.props;

/* One mark per third (length = tasting.length). Trim or pad to
   match so the caller can't accidentally desynchronise the rail
   from the thirds. */
const fullMarks = marks.length >= tasting.length
  ? marks.slice(0, tasting.length)
  : [...marks, ...Array(tasting.length - marks.length).fill('')];
---

<section class="smoke" aria-labelledby="smoke-heading" data-reveal-section>
  <div class="smoke__inner container">
    <p class="eyebrow smoke__eyebrow" id="smoke-heading">Tasting Notes</p>

    <div class="smoke__layout">
      {/* Sticky timeline — gold rule with marker ticks. aria-label so
          screen readers announce the structural role. */}
      <nav class="smoke__timeline" aria-label="Smoke arc timeline">
        <div class="smoke__rail" aria-hidden="true">
          <span class="smoke__line"></span>
          {fullMarks.map((m, i) => (
            <span
              class="smoke__tick"
              data-tick-index={i}
              style={`top: ${((i + 0.5) / fullMarks.length) * 100}%`}
            >
              <span class="smoke__dot"></span>
              <span class="smoke__time">{m}</span>
            </span>
          ))}
        </div>
      </nav>

      {/* The three thirds — stacked vertically. Each one a generous
          70vh-ish block so the sticky timeline has room to track. */}
      <ol class="smoke__thirds">
        {tasting.map((stage, i) => (
          <li class="smoke__third" data-third-index={i} data-reveal-third>
            {/* Mobile-only inline marker — the timeline collapses to
                a stack on small viewports, per the brief's mobile note. */}
            <p class="smoke__inline-mark" aria-hidden="true">
              <span class="smoke__inline-dot"></span>
              <span class="smoke__inline-time">{fullMarks[i]}</span>
            </p>
            <p class="smoke__stage">{stage.stage}</p>
            <p class="smoke__note">{stage.note}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .smoke {
    /* Padding split (2026-05-24): top halved so Tasting Notes sits
       closer to the foot of the dark-brown bleed band above; bottom
       preserved at the original clamp value. */
    padding-top: clamp(calc(var(--space-8) / 2), 4.5vw, calc(var(--space-10) / 2));
    padding-bottom: clamp(var(--space-8), 9vw, var(--space-10));
  }

  /* Inner column locked to the same measure as the cigar section's
     .cigar__inner (880px centred) so the eyebrow, notes column and
     timeline-bound layout sit on the same horizontal placement as
     the narrative and the spec strips above. (Stephane 2026-05-24:
     "the tasting notes should align — same left and right margins —
     with the cigar narrative paragraph and the specifications".) */
  .smoke__inner {
    max-width: 880px;
    margin-inline: auto;
  }
  /* Section-level eyebrow override (Stephane 2026-05-24): Tasting
     Notes is a section title, so it steps up from --fs-eyebrow (12px)
     to a clamp that reads meaningfully larger — same scale as the
     volage page's THE CIGAR eyebrow. Same Hanken-uppercase-tracked
     grammar as .eyebrow; only the font-size changes. The per-third
     STAGE labels (.smoke__stage) keep the default eyebrow size —
     they're sub-headings within this section. */
  .smoke__eyebrow {
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    margin-bottom: var(--space-7);
  }

  /* Notes occupy the full 880px measure; the timeline rail floats
     outside that measure into the page gutter, so the notes line up
     flush-left with the spec strips above and the eyebrow line. The
     thirds column itself keeps its own 56ch reading measure below.
     Previously: 2-col grid (120-160px rail + 1fr notes) which inset
     the notes ~140-180px from the container edge — visibly out of
     alignment with the narrative and specs above. */
  .smoke__layout {
    position: relative;
  }

  /* ── Timeline ────────────────────────────────────────────── */
  /* Rail sits inside .smoke__inner, anchored to its right edge
     (2026-05-24, revised same day). Earlier in the day the rail was
     pushed into the right gutter via `left: 100%; margin-left`; that
     placed its right edge ~24px past the spec table's right edge on
     the page above, breaking the alignment line. The thirds prose is
     capped at 56ch (~560-600px) inside the 880px column, leaving
     ~280px of dead space on the right of the layout that the rail
     occupies without crowding the notes. The rail line and tick dots
     remain anchored to the rail's right edge, so they now sit flush
     with the spec table's right margin; minute labels still read
     leftward toward the prose.
     Previously: left: 100% + margin-left placed the rail past the
     880px column edge into the page gutter. */
  .smoke__timeline {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: clamp(80px, 10vw, 120px);
    pointer-events: none;
  }
  /* Below ~1080px the viewport no longer has comfortable gutter room
     for the rail to sit fully outside the notes column. Hide the
     desktop rail in that range and let the inline minute-mark
     (previously mobile-only, see media query below) carry the
     timeline indicator above each third. Alignment with the
     narrative and specs is the priority; the per-third reveal
     behaviour is unchanged. */
  @media (max-width: 1080px) {
    .smoke__timeline {
      display: none;
    }
    .smoke__inline-mark {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-family: var(--font-body);
      font-size: var(--fs-eyebrow);
      font-weight: 500;
      letter-spacing: var(--ls-section);
      text-transform: uppercase;
      color: var(--gold-deep);
      margin: 0 0 var(--space-4) 0;
    }
    .smoke__inline-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--gold);
      border: 1px solid var(--gold-deep);
    }
  }
  .smoke__rail {
    position: relative;
    height: 100%;
    min-height: 100%;
  }
  .smoke__line {
    position: absolute;
    /* Line anchored to the rail's right edge (2026-05-24) so the rail
       sits as far from the notes column as possible within the right
       gutter, and minute labels extend leftward toward the notes. */
    right: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--gold-deep);
    opacity: 0.5;
  }
  .smoke__tick {
    position: absolute;
    /* Anchored to the rail's right edge to sit on the line (2026-05-24).
       Source order is dot → label; row-reverse flips them visually so
       the label reads to the left of the dot, toward the notes column. */
    right: -6px;
    transform: translateY(-50%);
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: var(--space-4);
    transition: opacity var(--dur-default) var(--ease-paper);
    opacity: 0.5;
  }
  .smoke__tick.is-active {
    opacity: 1;
  }
  .smoke__dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--white);
    border: 1px solid var(--gold-deep);
    transition: background var(--dur-default) var(--ease-paper),
                transform var(--dur-default) var(--ease-paper);
  }
  .smoke__tick.is-active .smoke__dot {
    background: var(--gold);
    transform: scale(1.15);
  }
  .smoke__time {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    white-space: nowrap;
  }

  /* ── Thirds ──────────────────────────────────────────────── */
  /* Spacing tightened 2026-05-23: the thirds previously read as
     three separated landscapes (50vh-min each, large between-gap)
     which Stephane called out as "way too much space" between the
     three notes. Cut the min-height and roughly quartered the gap
     so they now read as a tight vertical succession; the sticky
     timeline still tracks the three beats, the active-tick logic
     is unchanged. */
  .smoke__thirds {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-5), 3vw, var(--space-6));
  }
  .smoke__third {
    max-width: 56ch;
    /* No artificial min-height: each third is as tall as its own
       copy. The timeline still has room to track (the rail height
       is set on the timeline column itself). */
    display: flex;
    flex-direction: column;
    /* Progressive reveal (2026-05-23): each third starts hidden
       and fades in when its corresponding tick activates. The
       `.is-revealed` class is set once by the IntersectionObserver
       in the script below and never removed. */
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 420ms var(--ease-paper),
                transform 420ms var(--ease-paper);
  }
  .smoke__third.is-revealed {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .smoke__third {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  .smoke__stage {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 var(--space-4) 0;
  }
  /* Tasting-note size matched to the Presentation section's intro
     line (.packaging__lede in volage.astro) so the two read at the
     same register. Was clamp(1.25rem, 2.4vw, 1.65rem). */
  .smoke__note {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0;
  }
  /* Desktop-only step-down (Stephane 2026-05-24): one size smaller on
     desktop, mobile inherits the base above. clamp middle and ceiling
     drop one step (1.8vw → 1.5vw, 1.25rem → 1.1rem); floor unchanged
     at 1.05rem because the desktop range never binds to the floor (the
     721px breakpoint times 1.5vw = ~10.8rem-equivalent; well above
     1.05rem). Override wrapping is cleaner than restoring on mobile —
     base survives unchanged and only desktop carries the override. */
  @media (min-width: 721px) {
    .smoke__note {
      font-size: clamp(1.05rem, 1.5vw, 1.1rem);
    }
  }

  /* Inline mobile marker — hidden on desktop. */
  .smoke__inline-mark {
    display: none;
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  /* The rail-hide + inline-mark show now happens at <=1080px (see
     above) so the mobile block here only handles thirds spacing
     and the very-narrow minute-label hide. */
  @media (max-width: 720px) {
    .smoke__thirds {
      gap: var(--space-6);
    }
    /* Hide the minute label on mobile (2026-05-24) — the dot alone
       carries the timeline indicator above each third; the minute
       text wasn't earning its space on a narrow viewport. */
    .smoke__inline-time {
      display: none;
    }
  }
</style>

<script>
  /* The timeline ticks an active class so the dot lights up as you
     read each third. The same trigger also flips `.is-revealed` on
     the third itself (CSS handles the fade). One watcher does both
     jobs. Per-third GSAP reveal was removed 2026-05-23 — the CSS
     fade tied to tick activation replaces it. */

  const thirds = document.querySelectorAll<HTMLElement>('.smoke [data-third-index]');
  const ticks  = document.querySelectorAll<HTMLElement>('.smoke [data-tick-index]');

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // If reduced motion, snap all thirds visible immediately so the
  // observer-driven fade never holds them back.
  if (prefersReduced) {
    thirds.forEach((t) => t.classList.add('is-revealed'));
  }

  // Tick activation — the tick at index N lights when third N is
  // the most-centred third in the viewport. The same enter also
  // reveals third N (and is sticky thereafter). Marks are 1:1 with
  // thirds (2026-05-24), so there is no closing tick to handle.
  if (thirds.length && ticks.length) {
    const setActive = (i: number) => {
      ticks.forEach((t) => t.classList.remove('is-active'));
      const tick = ticks[i];
      if (tick) tick.classList.add('is-active');
    };

    const revealThird = (i: number) => {
      const third = thirds[i];
      if (third) third.classList.add('is-revealed');
    };

    const io = new IntersectionObserver(
      (entries) => {
        // Reveal any entering third immediately (one-shot, additive).
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const idx = Number((entry.target as HTMLElement).dataset.thirdIndex);
            revealThird(idx);
          }
        }
        // Pick the entry that's most visible right now for tick activation.
        let bestEntry: IntersectionObserverEntry | null = null;
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          if (!bestEntry || entry.intersectionRatio > bestEntry.intersectionRatio) {
            bestEntry = entry;
          }
        }
        if (bestEntry) {
          const idx = Number((bestEntry.target as HTMLElement).dataset.thirdIndex);
          setActive(idx);
        }
      },
      {
        /* A band centred on the viewport — the third the reader is
           reading is the one lighting up. */
        rootMargin: '-35% 0px -35% 0px',
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );
    thirds.forEach((t) => io.observe(t));

    // Light the first tick on load so the rail isn't blank before
    // the first third is centred. The first third itself stays
    // hidden until it enters the centre band (per the brief: notes
    // appear one by one as you scroll).
    setActive(0);

  }
</script>
