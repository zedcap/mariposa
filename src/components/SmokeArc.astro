---
/* SmokeArc — tasting notes as a vertical sequence.
   ------------------------------------------------------------------
   Section 5 of a SKU page. The brief's Option B (preferred over a
   horizontal scroll): a sticky gold timeline on the left margin
   tracks the three thirds as the reader scrolls through them.

   Implementation: CSS `position: sticky` for the timeline column,
   no JS dependency for the pin. Active-tick highlighting uses an
   IntersectionObserver that watches each third and toggles a class
   on the corresponding marker. Reduced-motion: no animation; the
   sticky behaviour still works (it's layout, not motion), but if
   it ever feels intrusive at that setting the sticky can be
   neutralised under the media query.

   Mobile: timeline collapses inline above each third — the brief's
   stated mobile fallback.

   Each tasting third carries its own time marker (0', 15', 30',
   45'). The smoke time is the Volage spec; Caprice will pass its
   own time array.

   Pairings: NOT implemented this build. The brief flags them as a
   future addition pending Axel-drafted copy. */

interface Stage {
  stage: string;        // e.g. "First third"
  note: string;
}

interface Props {
  tasting: Stage[];     // expected length 3, but the component is
                        // agnostic; whatever it gets, it lays out.
  /* Time markers paired one-to-one with `tasting`. Strings so the
     component doesn't have to know about formatting. */
  marks?: string[];
}

const {
  tasting,
  marks = ["0'", "15'", "30'", "45'"],
} = Astro.props;

/* The marker count is tasting.length + 1 (a final tick that closes
   the line). Pad the marks array if the caller supplied fewer. */
const fullMarks = marks.length >= tasting.length + 1
  ? marks.slice(0, tasting.length + 1)
  : [...marks, ...Array(tasting.length + 1 - marks.length).fill('')];
---

<section class="smoke" aria-labelledby="smoke-heading" data-reveal-section>
  <div class="smoke__inner container">
    <p class="eyebrow smoke__eyebrow" id="smoke-heading">The smoke arc</p>

    <div class="smoke__layout">
      {/* Sticky timeline — gold rule with marker ticks. aria-label so
          screen readers announce the structural role. */}
      <nav class="smoke__timeline" aria-label="Smoke arc timeline">
        <div class="smoke__rail" aria-hidden="true">
          <span class="smoke__line"></span>
          {fullMarks.map((m, i) => (
            <span
              class="smoke__tick"
              data-tick-index={i}
              style={`top: ${(i / (fullMarks.length - 1)) * 100}%`}
            >
              <span class="smoke__dot"></span>
              <span class="smoke__time">{m}</span>
            </span>
          ))}
        </div>
      </nav>

      {/* The three thirds — stacked vertically. Each one a generous
          70vh-ish block so the sticky timeline has room to track. */}
      <ol class="smoke__thirds">
        {tasting.map((stage, i) => (
          <li class="smoke__third" data-third-index={i} data-reveal-third>
            {/* Mobile-only inline marker — the timeline collapses to
                a stack on small viewports, per the brief's mobile note. */}
            <p class="smoke__inline-mark" aria-hidden="true">
              <span class="smoke__inline-dot"></span>
              <span class="smoke__inline-time">{fullMarks[i]}</span>
            </p>
            <p class="smoke__stage">{stage.stage}</p>
            <p class="smoke__note">{stage.note}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .smoke {
    padding-block: clamp(var(--space-8), 9vw, var(--space-10));
  }
  .smoke__eyebrow {
    margin-bottom: var(--space-7);
  }

  /* Two columns at desktop: sticky timeline left, thirds stack right. */
  .smoke__layout {
    display: grid;
    grid-template-columns: minmax(120px, 160px) 1fr;
    gap: clamp(var(--space-7), 6vw, var(--space-9));
  }

  /* ── Timeline ────────────────────────────────────────────── */
  /* Rail spans the full height of the thirds column (2026-05-23):
     the grid row auto-sizes to the taller child (the thirds stack),
     and `align-self: stretch` (default) lets this column match.
     The rail's first and last ticks then sit exactly at the top of
     the first third and the bottom of the final third, with the
     intermediate ticks landing on the thirds' transitions.
     Previously: `height: 60vh; min-height: 360px` with `position:
     sticky` — gave a fixed-height rail decoupled from the notes. */
  .smoke__timeline {
    /* no fixed height — fills the grid row */
  }
  .smoke__rail {
    position: relative;
    height: 100%;
    min-height: 100%;
    margin-left: var(--space-3);
  }
  .smoke__line {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--gold-deep);
    opacity: 0.5;
  }
  .smoke__tick {
    position: absolute;
    left: -6px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    transition: opacity var(--dur-default) var(--ease-paper);
    opacity: 0.5;
  }
  .smoke__tick.is-active {
    opacity: 1;
  }
  .smoke__dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--white);
    border: 1px solid var(--gold-deep);
    transition: background var(--dur-default) var(--ease-paper),
                transform var(--dur-default) var(--ease-paper);
  }
  .smoke__tick.is-active .smoke__dot {
    background: var(--gold);
    transform: scale(1.15);
  }
  .smoke__time {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    white-space: nowrap;
  }

  /* ── Thirds ──────────────────────────────────────────────── */
  /* Spacing tightened 2026-05-23: the thirds previously read as
     three separated landscapes (50vh-min each, large between-gap)
     which Stephane called out as "way too much space" between the
     three notes. Cut the min-height and roughly quartered the gap
     so they now read as a tight vertical succession; the sticky
     timeline still tracks the three beats, the active-tick logic
     is unchanged. */
  .smoke__thirds {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-5), 3vw, var(--space-6));
  }
  .smoke__third {
    max-width: 56ch;
    /* No artificial min-height: each third is as tall as its own
       copy. The timeline still has room to track (the rail height
       is set on the timeline column itself). */
    display: flex;
    flex-direction: column;
    /* Progressive reveal (2026-05-23): each third starts hidden
       and fades in when its corresponding tick activates. The
       `.is-revealed` class is set once by the IntersectionObserver
       in the script below and never removed. */
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 420ms var(--ease-paper),
                transform 420ms var(--ease-paper);
  }
  .smoke__third.is-revealed {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .smoke__third {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  .smoke__stage {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 var(--space-4) 0;
  }
  /* Tasting-note size matched to the Presentation section's intro
     line (.packaging__lede in volage.astro) so the two read at the
     same register. Was clamp(1.25rem, 2.4vw, 1.65rem). */
  .smoke__note {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0;
  }

  /* Inline mobile marker — hidden on desktop. */
  .smoke__inline-mark {
    display: none;
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .smoke__layout {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .smoke__timeline {
      display: none;
    }
    .smoke__thirds {
      gap: var(--space-6);
    }
    .smoke__inline-mark {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-family: var(--font-body);
      font-size: var(--fs-eyebrow);
      font-weight: 500;
      letter-spacing: var(--ls-section);
      text-transform: uppercase;
      color: var(--gold-deep);
      margin: 0 0 var(--space-4) 0;
    }
    .smoke__inline-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--gold);
      border: 1px solid var(--gold-deep);
    }
    /* Hide the minute label on mobile (2026-05-24) — the dot alone
       carries the timeline indicator above each third; the minute
       text wasn't earning its space on a narrow viewport. */
    .smoke__inline-time {
      display: none;
    }
  }
</style>

<script>
  /* The timeline ticks an active class so the dot lights up as you
     read each third. The same trigger also flips `.is-revealed` on
     the third itself (CSS handles the fade). One watcher does both
     jobs. Per-third GSAP reveal was removed 2026-05-23 — the CSS
     fade tied to tick activation replaces it. */

  const thirds = document.querySelectorAll<HTMLElement>('.smoke [data-third-index]');
  const ticks  = document.querySelectorAll<HTMLElement>('.smoke [data-tick-index]');

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // If reduced motion, snap all thirds visible immediately so the
  // observer-driven fade never holds them back.
  if (prefersReduced) {
    thirds.forEach((t) => t.classList.add('is-revealed'));
  }

  // Tick activation — the tick at index N lights when third N is the
  // most-centred third in the viewport. The same enter also reveals
  // third N (and is sticky thereafter). The final tick (index N+1)
  // lights when the user has scrolled past the last third.
  if (thirds.length && ticks.length) {
    const setActive = (i: number) => {
      ticks.forEach((t) => t.classList.remove('is-active'));
      const tick = ticks[i];
      if (tick) tick.classList.add('is-active');
    };

    const revealThird = (i: number) => {
      const third = thirds[i];
      if (third) third.classList.add('is-revealed');
    };

    const io = new IntersectionObserver(
      (entries) => {
        // Reveal any entering third immediately (one-shot, additive).
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const idx = Number((entry.target as HTMLElement).dataset.thirdIndex);
            revealThird(idx);
          }
        }
        // Pick the entry that's most visible right now for tick activation.
        let bestEntry: IntersectionObserverEntry | null = null;
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          if (!bestEntry || entry.intersectionRatio > bestEntry.intersectionRatio) {
            bestEntry = entry;
          }
        }
        if (bestEntry) {
          const idx = Number((bestEntry.target as HTMLElement).dataset.thirdIndex);
          setActive(idx);
        }
      },
      {
        /* A band centred on the viewport — the third the reader is
           reading is the one lighting up. */
        rootMargin: '-35% 0px -35% 0px',
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );
    thirds.forEach((t) => io.observe(t));

    // Light the first tick on load so the rail isn't blank before
    // the first third is centred. The first third itself stays
    // hidden until it enters the centre band (per the brief: notes
    // appear one by one as you scroll).
    setActive(0);

    // After the last third has scrolled past, light the closing tick.
    const lastThird = thirds[thirds.length - 1];
    const tailIo = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const past = entry.boundingClientRect.bottom < 0;
          if (past) setActive(ticks.length - 1);
        }
      },
      { threshold: 0 },
    );
    tailIo.observe(lastThird);
  }
</script>
