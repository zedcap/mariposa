---
/* Home hero — contained image slider.
   ------------------------------------------------------------------
   HEIGHT (2026-05-22). The hero is a CONTAINED band, not full-viewport.
   The site runs the marigold.global nav pattern: the menu sits below
   the hero and sticks to the top on scroll. That placement only reads
   if the menu is actually visible below the hero on load. A 100svh hero
   pushes the menu under the fold, so the "menu below hero" pattern is
   invisible until the user scrolls — which defeats it. Containing the
   hero so the nav bar shows underneath on first paint is the pattern
   working as designed. Stephane's call; not a regression to a header
   strip — the band stays rich (four frames, Ken Burns, slider motion),
   only the height is capped.

   The section carries its own choreography: a slow scale on the active
   frame and a plain cross-fade between slides.

   Hero imagery renders in ORIGINAL COLOUR — a deliberate override of
   the design system's "full-bleed photography = B&W / duotone" rule.
   Stephane's call (2026-05-22); recorded in mariposa-design-conventions.md.

   3 frames, slow auto-advance (7s), pause on hover, manual dots.
   prefers-reduced-motion: no Ken Burns, instant cross-fade. */
import { Image } from 'astro:assets';

/* Mariposa hero frames — the collage device: the same faceless woman
   with a cigar on three worlds, in colour. Order is deliberate and
   fixed: scenes 1, 3, 2. Landscape source, 3200×1800 (16:9). */
import heroImage1Color from '../assets/hero-mariposa-1-color.jpg';
import heroImage3Color from '../assets/hero-mariposa-3-color.jpg';
import heroImage2Color from '../assets/hero-mariposa-2-color.jpg';

const heroImages = [
  heroImage1Color,
  heroImage3Color,
  heroImage2Color,
];

interface Slide {
  key: string;
  caption: string;
}
interface Props {
  slides: Slide[];
}
const { slides } = Astro.props;
---

<section class="hero" aria-label="Mariposa" data-hero>
  <div class="hero__track">
    {
      slides.map((slide, i) => (
        <div
          class:list={['hero__slide', { 'is-active': i === 0 }]}
          data-slide
          aria-hidden={i === 0 ? 'false' : 'true'}
        >
          <div class="hero__frame" data-hero-frame>
            <Image
              class="hero__img"
              src={heroImages[i] ?? heroImages[0]}
              alt={slide.caption}
              widths={[720, 1280, 1920, 2560]}
              sizes="100vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
            />
          </div>
        </div>
      ))
    }
  </div>

  {/* Minimal foot scrim — keeps the gold dots legible against a light
      image. Top scrim removed: nav rests below the hero. */}
  <div class="hero__veil" aria-hidden="true"></div>

  {/* Indicators — small round dots, bottom-centre. Active dot is gold,
      inactive dots are white. No progress ring; the slider's pace is
      carried by the cross-fade and Ken Burns alone. */}
  <div class="hero__indicators" role="tablist" aria-label="Hero slides">
    {
      slides.map((slide, i) => (
        <button
          class:list={['hero__dot', { 'is-active': i === 0 }]}
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Show slide ${i + 1}`}
          data-tick={i}
        />
      ))
    }
  </div>
</section>

<style>
  .hero {
    /* Contained band — sized so the nav menu below the hero is visible
       on first paint without scrolling (the marigold.global pattern).
       64svh on a standard desktop viewport leaves the full 84px nav bar
       clearly in view; the min/max keep that true across screen sizes.
       Rich imagery and motion live inside this height, not beyond it. */
    position: relative;
    height: 64svh;
    min-height: 440px;
    max-height: 720px;
    overflow: hidden;
    background: var(--ink);
  }

  .hero__track {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    /* Plain cross-fade between slides — no gold wash. */
    transition: opacity var(--dur-slow) var(--ease-paper);
  }
  .hero__slide.is-active {
    opacity: 1;
  }

  /* The frame is the element the Ken Burns scale acts on, kept separate
     from the fading slide so the two transforms never fight. */
  .hero__frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Original colour — hero is a deliberate override of the design
       system's full-bleed duotone rule. No filter. */
    will-change: transform;
  }

  /* Foot scrim — a faint darkening at the foot only, so the gold
     slide-indicator ticks stay legible against a light image. No top
     scrim: the nav rests below the hero, and the imagery shows clean.
     Kept minimal so the original picture reads. */
  .hero__veil {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(to top, rgba(28, 25, 21, 0.34) 0%, transparent 24%);
  }

  /* Indicators — small round gold dots, bottom-centre of the hero band.
     Centred with left:50% + translateX(-50%) so the dot row is genuinely
     centred regardless of dot count. Seated at the foot, within the foot
     scrim's coverage so the gold reads on a light image. */
  .hero__indicators {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    z-index: 4;
  }

  /* Each dot is a fixed-size round button. Inactive dots are solid white;
     the active dot is gold. Two clean colours, no ambient translucency. */
  .hero__dot {
    position: relative;
    width: 10px;
    height: 10px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: var(--white);
    cursor: pointer;
    transition: background-color var(--dur-default) var(--ease-paper);
  }
  .hero__dot.is-active {
    background: var(--gold-leaf);
  }

  @media (max-width: 720px) {
    .hero {
      /* On a phone the band drops the crop entirely: it takes the hero
         images' native landscape ratio (3200×1800 = 16/9) and scales
         down proportionally as the viewport narrows. The full image
         shows, uncropped, no letterboxing — the header just gets
         smaller. No fixed svh height, no min/max. */
      height: auto;
      min-height: 0;
      max-height: none;
      aspect-ratio: 16 / 9;
    }

    /* No crop on mobile, so the frame fills with the whole image. */
    .hero__img {
      object-fit: contain;
    }

    /* The mobile band is much shorter than the desktop one (it scales
       with the image ratio). Pull the dots in toward the foot so they
       don't crowd the short band. */
    .hero__indicators {
      bottom: var(--space-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide { transition: opacity 0.01ms; }
  }
</style>

<script>
  import { gsap, REDUCED } from '../lib/motion';

  const hero = document.querySelector<HTMLElement>('[data-hero]');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-slide]'));
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-frame]'));
  const ticks = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tick]'));
  const ADVANCE_MS = 7000;

  if (hero && slides.length > 1) {
    let current = 0;
    let timer: number | undefined;
    let kenBurns: gsap.core.Tween | undefined;

    /* Ken Burns — the active frame eases from slightly enlarged toward
       true size over the full dwell. Slow, analogue: the eye should
       never catch it as a discrete move, only feel the frame breathe.
       The marigold hero gives its imagery the same quiet life. */
    const animateFrame = (idx: number) => {
      if (REDUCED) return;
      kenBurns?.kill();
      const frame = frames[idx];
      if (!frame) return;
      gsap.set(frame, { scale: 1.0, xPercent: 0 });
      kenBurns = gsap.fromTo(
        frame,
        { scale: 1.0, xPercent: 0 },
        {
          scale: 1.08,
          xPercent: idx % 2 === 0 ? 1.2 : -1.2,
          duration: (ADVANCE_MS + 1400) / 1000,
          ease: 'none',
        },
      );
    };

    const show = (next: number) => {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      ticks[current]?.classList.remove('is-active');
      ticks[current]?.setAttribute('aria-selected', 'false');

      current = (next + slides.length) % slides.length;

      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      ticks[current]?.classList.add('is-active');
      ticks[current]?.setAttribute('aria-selected', 'true');
      animateFrame(current);
    };

    const start = () => {
      if (REDUCED) return;
      stop();
      timer = window.setInterval(() => show(current + 1), ADVANCE_MS);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      kenBurns?.pause();
    };
    const resume = () => {
      kenBurns?.resume();
      start();
    };

    ticks.forEach((tick, i) => {
      tick.addEventListener('click', () => {
        show(i);
        start();
      });
    });

    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', resume);

    animateFrame(0);
    start();
  }
</script>
