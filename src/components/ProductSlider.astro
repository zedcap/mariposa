---
/* Home product section — Option B, the paired editorial slider.
   ------------------------------------------------------------------
   REBUILD (2026-05-21). The first cut wired the slider correctly but it
   sat still — two panels stacked behind a translate. This rebuild keeps
   Option B (resolved) and makes each frame a composed editorial spread:

   - a giant ghosted display letter behind the cigar (the Marigold
     title-break outline move — depth, scale on the page);
   - the cigar floating on a parallax drift, with a slow scale-settle;
   - the copy column cascading in word/line by word/line when its frame
     becomes active;
   - a kinetic slide between frames with the gold-sliver wash carried
     across (the slider's motion vocabulary matches the hero);
   - the whole section's header revealing on scroll-in.

   The range is two cigars; that pairing is the story. A two-dot
   indicator and an edge-peek keep the second SKU present.

   prefers-reduced-motion: no parallax, no drift; copy is shown in
   place; the track still moves between frames (a functional control,
   not decoration) but without the kinetic overshoot. */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import cigarVolage from '../assets/cigar-volage.png';
import cigarCaprice from '../assets/cigar-caprice.png';
import { withBase } from '../lib/path';

interface ProductFrame {
  name: string;
  slug: string;
  vitola: string;
  tagline: string;
  homeLede: string[];
  quickSpecs?: { label: string; value: string }[];
}
interface Props {
  products: ProductFrame[];
}
const { products } = Astro.props;

// Slug → cigar image.
const cigarImages: Record<string, ImageMetadata> = {
  volage: cigarVolage,
  caprice: cigarCaprice,
};

// Per-slug image mode. 'object' = cigar-on-void PNG floating in
// negative space on the section ground, no frame, no border, no
// hairline; soft drop-shadow gives the floating-object effect
// (Option 1, "Object on void" — Stephane 2026-05-24). 'scene' = full
// editorial photograph inside a bounded frame, edge-to-edge; modifier
// CSS retained for future use but not applied to the current range.
// Default is 'object' so adding a new SKU stays predictable.
const imageMode: Record<string, 'object' | 'scene'> = {
  volage: 'object',
  caprice: 'object',
};

// Slug → Discover link target override. Defaults to `/<slug>`; map an
// entry only when a frame should route somewhere other than its own
// product page.
const discoverHref: Record<string, string> = {};
---

<section class="range grain" id="range" aria-label="The Mariposa range" data-range data-cream-bg>
  {/* No section heading — Stephane review (2026-05-21): the slider
      stands alone, no eyebrow, no title. The brand statement opens the
      page in the position section above. The section's "modern" energy
      comes from the per-frame choreography, not a header. */}

  {/* Cream-bleed wedge — softens the edge where the white position
      statement above meets the cream product bed. Fades from white at
      the top (matching the section above) down to cream so the boundary
      reads as a gradient, not a horizontal cut. Sits behind the product
      content (z-index 0); the slider's frames render above. */}
  <div class="range__bleed" aria-hidden="true"></div>

  <div class="range__viewport" data-range-viewport>
    <div class="range__track" data-range-track>
      {
        products.map((product, fi) => (
          <article class:list={['range__frame', `range__frame--${product.slug}`]} data-range-frame data-frame-index={fi}>
            {/* Ghost letter — a giant display initial behind the cigar,
                the title-break depth move. Scrubs scale/rotate. */}
            <span class="range__ghost" data-range-ghost aria-hidden="true">
              {product.name.charAt(0)}
            </span>

            <div class="range__frame-inner container">
              <div class="range__media" data-range-media>
                <div class:list={['range__media-frame', `range__media-frame--${imageMode[product.slug] ?? 'object'}`]}>
                  {/* No frame, no border, no hairline in object mode
                      (Option 1, Stephane 2026-05-24). The cigar PNG
                      floats on the section ground; the soft
                      drop-shadow gives the floating-object effect. */}
                  <Image
                    class:list={['range__cigar', `range__cigar--${imageMode[product.slug] ?? 'object'}`]}
                    src={cigarImages[product.slug]}
                    alt={`The Mariposa ${product.name} cigar, ${product.tagline.toLowerCase()}`}
                    widths={[260, 420, 640]}
                    sizes="(max-width: 720px) 60vw, 32vw"
                    loading="lazy"
                  />
                </div>
              </div>

              <div class="range__copy" data-range-copy>
                <p class="range__vitola">{product.vitola}</p>
                <h3 class="range__name">{product.name}</h3>
                <p class="range__tagline">{product.tagline}</p>
                {product.homeLede.map((para) => (
                  <p class="range__lede">{para}</p>
                ))}
                {product.quickSpecs && product.quickSpecs.length > 0 && (
                  <dl class="range__quickspecs">
                    {product.quickSpecs.map((row) => (
                      <div class="range__quickspec-row">
                        <dt class="range__quickspec-label">{row.label}</dt>
                        <dd class="range__quickspec-value">{row.value}</dd>
                      </div>
                    ))}
                  </dl>
                )}
                <a class="range__link" href={withBase(discoverHref[product.slug] ?? `/${product.slug}`)}>
                  <span class="range__link-text">Discover {product.name}</span>
                  <span class="range__link-arrow" aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  {/* Controls — two-dot indicator + step buttons + a frame counter. */}
  <div class="range__controls container">
    <button class="range__step" type="button" data-range-prev aria-label="Previous cigar">
      <span aria-hidden="true">&larr;</span>
    </button>
    <div class="range__dots" role="tablist" aria-label="Cigars">
      {
        products.map((product, i) => (
          <button
            class:list={['range__dot', { 'is-active': i === 0 }]}
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={`Show ${product.name}`}
            data-range-dot={i}
          >
            <span class="range__dot-label">{product.name}</span>
          </button>
        ))
      }
    </div>
    <button class="range__step" type="button" data-range-next aria-label="Next cigar">
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>
</section>

<style>
  .range {
    position: relative;
    /* Cream product bed — begins the cream zone that runs through to
       the lifestyle section below (restored 2026-05-23: Stephane
       reversed the strip-cream pass). The handoff from the white
       position statement above is graded via .range__bleed.
       Top padding tightened ~25% (Stephane 2026-05-23) as part of the
       position-to-slider gap reduction; bottom padding kept on the same
       token shape but expressed asymmetrically so only the top closes
       toward the sub-line above. */
    background: #f2f0e9;
    padding-top: clamp(var(--space-7), 9vw, var(--space-9));
    /* Bottom padding matched to .range__controls margin-top (Stephane
       2026-05-23): the gap below the slider controls now mirrors the
       gap above them — same clamp, symmetric breathing room. Earlier
       half-step from clamp(--space-9, 12vw, --space-10) →
       clamp(--space-7, 6vw, --space-9) collapsed further to the
       controls' own top-gap token. Doubled (Stephane 2026-05-24):
       each clamp stop stepped up one token / 2× the vw so the
       controls-to-next-section gap doubles. Lift pass (Stephane
       2026-05-24): the slider needs to sit higher. The controls'
       margin-top is roughly halved AND this padding-bottom is stepped
       up — net effect is the whole slider block shifts up, with the
       gap below the controls now meaningfully larger than the gap
       above so the controls clearly belong to the image, not to the
       story below. */
    /* Gap below the slider increased ~1.5× (Stephane 2026-05-24): the
       clamp shifts from 64-96px to 96-144px so the breath between the
       controls and the section below opens up. Floor steps up one
       token (--space-8 → --space-9); ceiling is 1.5× the prior --space-9
       (96 → 144px). Top padding unchanged. */
    padding-bottom: clamp(var(--space-9), 7.5vw, calc(var(--space-9) * 1.5));
    overflow: hidden;
  }

  /* Cream-bleed wedge — the gradual handoff from the white position
     statement above into the cream product bed. Sits at the top of the
     section, fading from opaque white down to transparent so the cream
     bed emerges gradually. Without this the top edge reads as a banded
     horizontal cut. Stays behind the product content so the slider's
     imagery, hairline and ghost letter render cleanly above. The nav's
     rAF observer (Header.astro) samples this element's geometry to
     interpolate the nav's own background white→cream as the wedge
     passes through the nav band — removing this rule will silently
     disable the nav colour-track. */
  .range__bleed {
    position: absolute;
    inset: 0 0 auto 0;
    /* Height reduced ~25% (Stephane 2026-05-23): clamp(120/18vh/220)
       → clamp(90/13.5vh/165). Gradient stops and colour treatment
       unchanged; only the height shrinks. 90px floor preserves the
       three-stop fade (~30px per stop), well above the ~20px-per-stop
       threshold where a soft warming starts to read as a banded edge. */
    height: clamp(90px, 13.5vh, 165px);
    background: linear-gradient(
      to bottom,
      var(--white) 0%,
      rgba(255, 255, 255, 0.6) 45%,
      rgba(255, 255, 255, 0) 100%
    );
    z-index: 0;
    pointer-events: none;
  }

  /* ── Viewport / track ───────────────────────────────────────── */
  .range__viewport {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .range__track {
    display: flex;
    /* JS drives the transform; the transition is the kinetic slide. */
    transition: transform 720ms var(--ease-paper);
  }
  .range__frame {
    flex: 0 0 100%;
    position: relative;
    /* min-height halved 560 → 280 (Stephane review 2026-05-23). Set
       originally to accommodate the long Volage lede + a taller image
       aspect; with squared 1:1 images and the promoted shorter copy
       scale, natural content height now exceeds 280px in every case,
       so this floor is effectively inert at desktop widths. Kept
       (rather than removed) as a guard against the frame collapsing
       to nothing if a future SKU ships with very short copy. Dominant
       contributor to the image-bottom → controls-top gap: the prior
       560 floor + align-items:center was padding void above and below
       the content inside the viewport. */
    min-height: 280px;
    display: flex;
    align-items: center;
  }

  /* Ghost display initial — the depth layer. Sits behind the cigar,
     huge, faint, hanging off the grid. */
  .range__ghost {
    position: absolute;
    top: 50%;
    left: 4%;
    transform: translateY(-54%);
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(20rem, 42vw, 44rem);
    line-height: 0.7;
    color: var(--gold);
    /* Opacity stepped 0.07 → 0.05 (Stephane 2026-05-24, Option 1):
       with the gold frame, border and pink hairline removed the ghost
       letter is the only depth device left around the cigar; quieter
       opacity keeps it as a faint backdrop, not a competing element. */
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    will-change: transform;
  }

  .range__frame-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.92fr 1fr;
    gap: clamp(var(--space-7), 7vw, var(--space-10));
    align-items: center;
    width: 100%;
  }

  /* ── Cigar media ────────────────────────────────────────────── */
  .range__media {
    position: relative;
    will-change: transform;
  }
  /* Media frame — base container only. No background, no border, no
     aspect-ratio at the base level; visual treatment is owned by the
     mode modifier (--object or --scene). Object mode (active on the
     range today) puts a tall portrait box around the cigar PNG so it
     has vertical room without dominating the column. Scene-mode rules
     are retained below for future use but no SKU currently flags
     'scene'. (Stephane 2026-05-24, Option 1 — Object on void.) */
  .range__media-frame {
    position: relative;
    display: grid;
    place-items: center;
    overflow: visible;
  }

  /* Object mode — Option 1, "Object on void". Tall portrait frame so
     the slim cigar PNGs have vertical breathing room; no card, no
     border, no hairline, no grain overlay. The cigar floats on the
     section's cream ground with a soft directional drop-shadow giving
     the floating-object effect. (Stephane 2026-05-24.)

     Scale-down pass (Stephane 2026-05-24): the prior 3:5 frame + 70%
     max-width let the cigar dominate the column. Frame aspect-ratio
     dropped; vertical containment is now a hard pixel cap on the
     cigar itself. The PNGs are ~1:4 (Volage) and ~1:5 (Caprice), so
     a max-height controls visual mass more reliably than a max-width:
     once height is capped, the proportional width is small enough
     that max-width acts as a belt-and-braces guard at narrow desktops
     only. Frame min-height keeps the row from collapsing when the
     cigar is short. */
  .range__media-frame--object {
    /* Frame min-height bumped ×1.15 alongside the cigar (Stephane
       2026-05-24) so the larger Caprice object has room without the
       copy column pulling the row. 360/38vw/460 → 414/43.7vw/529. */
    min-height: clamp(414px, 43.7vw, 529px);
    padding: clamp(var(--space-5), 4vw, var(--space-7)) 0;
  }
  .range__cigar--object {
    width: auto;
    /* Belt: caps the cigar's visual mass against the copy column's
       ~420-480px height. Bumped ×1.15 (Stephane 2026-05-24):
       320/32vw/420 → 368/36.8vw/483. */
    max-height: clamp(368px, 36.8vw, 483px);
    /* Braces: at narrow desktops where the column is ~340px wide, a
       width cap keeps the (already-narrow) cigar from creeping toward
       the copy edge. Bumped ×1.15: 40% → 46%. */
    max-width: 46%;
    object-fit: contain;
    filter: drop-shadow(0 22px 40px rgba(31, 27, 23, 0.22));
    will-change: transform;
  }

  /* Scene mode — defined for future use. Bounded card holding a full
     editorial photograph edge-to-edge, with gold border, grain overlay
     and pink hairline. Not currently applied to any SKU; preserved so
     reactivating scene mode for a future SKU is a one-flag change in
     the imageMode map. */
  .range__media-frame--scene {
    background: var(--white);
    border: 1px solid var(--border-gold);
    aspect-ratio: 1 / 1;
    padding: 0;
    overflow: hidden;
  }
  .range__media-frame--scene::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--grain-image);
    background-size: 200px 200px;
    opacity: 0.025;
    pointer-events: none;
  }
  .range__cigar--scene {
    width: 100%;
    height: 100%;
    max-height: none;
    object-fit: cover;
    object-position: 50% 100%;
    filter: none;
  }

  /* ── Copy column ────────────────────────────────────────────── */
  /* Vitola — the cigar's shape name (Canonazo, Gordito). Replaces
     the earlier boxed edition/release pills. Eyebrow register: small,
     uppercase, tracked, gold-deep. Identical treatment across both
     SKUs — this is the only element the two cards still share at full
     parity (the name / tagline / lede may differ in size per slug). */
  .range__vitola {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    /* Halved vitola→name gap promoted to base (Stephane review
       2026-05-23): --space-5 → --space-3 now applies across the
       range, tightening the Gordito→Caprice gap to match Volage. */
    margin: 0 0 var(--space-3) 0;
  }

  /* Name / tagline / lede sizes (Stephane review 2026-05-23). The
     step-down originally introduced as a Volage-only modifier is now
     the base size for both SKUs — the side-by-side comparison decided
     in favour of the smaller scale across the range. The
     `.range__frame--volage` modifier has been retired. Same clamp
     shape as the prior step-down; lede sits at --fs-small (14px),
     the next named token below --fs-body (17px). */
  .range__name {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.6rem, 4.0vw, 2.8rem);
    line-height: 0.96;
    letter-spacing: var(--ls-display);
    margin: 0;
  }
  .range__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 2.0vw, 1.35rem);
    color: var(--ink);
    margin-top: var(--space-5);
  }
  .range__lede {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-soft);
    margin-top: var(--space-4);
    /* Slightly wider measure so the longer paragraphs don't tower. */
    max-width: 46ch;
  }

  /* ── Per-slug overrides ─────────────────────────────────────── */
  /* Volage — cigar bumped +30% vs the base (Stephane 2026-05-24).
     Only the cigar object scales; the ghost letter, copy column,
     frame layout and motion choreography are untouched. Each clamp
     stop on .range__cigar--object is multiplied by 1.3 and the
     max-width belt widens 40% → 52%. The media frame's min-height
     steps up so the taller cigar has vertical room without the
     copy column pushing the row. Caprice continues to use the
     base .range__cigar--object sizing. */
  .range__frame--volage .range__media-frame--object {
    /* Bumped ×1.15 alongside the cigar (Stephane 2026-05-24):
       468/49.4vw/598 → 538/56.8vw/688. */
    min-height: clamp(538px, 56.8vw, 688px);
  }
  .range__frame--volage .range__cigar--object {
    /* Bumped ×1.15 (Stephane 2026-05-24): 416/41.6vw/546 → 478/47.8vw/628;
       max-width 52% → 60%. */
    max-height: clamp(478px, 47.8vw, 628px);
    max-width: 60%;
  }

  /* ── Quick-spec block (inline dl, slider-only) ──────────────────
     A compact two-column spec list rendered under the lede in any
     slider frame whose data carries `quickSpecs`. Distinct from the
     /volage page spec strip: smaller, denser, no hairlines, no
     full-width rule. Label is the eyebrow register (uppercase,
     tracked, gold-deep); value is Hanken regular in --ink. Row gap
     stays inside the lede→link rhythm so the block reads as one more
     paragraph step, not a section break. */
  .range__quickspecs {
    margin: var(--space-5) 0 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: clamp(var(--space-5), 3vw, var(--space-6));
    row-gap: var(--space-2);
    max-width: 46ch;
  }
  .range__quickspec-row {
    display: contents;
  }
  .range__quickspec-label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    /* Optical baseline alignment with the value row: the eyebrow is
       smaller, so a 2px nudge keeps the cap-height on the same line
       as the value's x-height. */
    padding-top: 2px;
    margin: 0;
  }
  .range__quickspec-value {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 400;
    line-height: var(--lh-body);
    color: var(--ink);
    margin: 0;
  }

  /* Caprice — editorial spread flip (Stephane review 2026-05-23):
     image on the right, copy on the left. Volage stays as the base
     (image left, copy right). Mechanism: reassign grid-column on the
     two children inside .range__frame-inner so the media slots into
     column 2 and the copy into column 1. grid-template-columns,
     gaps, widths, aspect-ratio, padding and the motion choreography
     are all untouched — only the left/right position swaps. The
     ghost display initial moves to the right edge to sit opposite
     the image, preserving the editorial-spread sense (ghost letter
     hugs the copy side, image floats off the opposite edge).
     Mobile (≤720px) collapses to single column and is unaffected. */
  .range__frame--caprice .range__media {
    grid-column: 2;
  }
  .range__frame--caprice .range__copy {
    grid-column: 1;
    grid-row: 1;
  }
  /* Ghost letter on Caprice — anchored to the inner edge of the image
     column on the flipped layout (Stephane 2026-05-24, geometric fix).
     Base .range__ghost uses left: 4%, which on Caprice's flipped frame
     (image right, copy left) lands the ghost on the page-left edge,
     behind the COPY column — the wrong side of the cigar. Pin to ~48%
     so the ghost sits just to the left of where the cigar renders in
     column 2 of the 0.92fr / 1fr grid (accounting for the column gap),
     mirroring how Volage's ghost hugs its cigar. right: auto so the
     pin holds even if a future rule sets a right value. */
  .range__frame--caprice .range__ghost {
    /* Nudged 1.5cm right (Stephane 2026-05-24): the ghost was sitting
       a touch too close to the cigar's left edge on the flipped layout.
       calc(48% + 1.5cm) keeps the percentage anchor against the grid
       and adds a fixed physical offset (~56.7px at 96dpi). */
    left: calc(48% + 1.5cm);
    right: auto;
  }

  .range__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    /* Match the inter-paragraph rhythm of .range__lede (Stephane review
       2026-05-23): the lede→link gap reads as one more paragraph step,
       not a section break. Same token as .range__lede margin-top.
       Doubled (Stephane 2026-05-24): --space-4 → --space-6 so the
       Discover link sits a clear step away from the lede block. */
    margin-top: var(--space-6);
    font-family: var(--font-body);
    /* Stephane review 2026-05-23 (b): "it's just a link" — step down
       one token from --fs-small to --fs-eyebrow so the discover link
       reads as quiet nav, not a feature. Weight, case and tracking
       unchanged. */
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    text-decoration: none;
  }
  .range__link-text {
    position: relative;
    padding-bottom: 3px;
  }
  /* Underline draws left-to-right on hover — design-system link spec. */
  .range__link-text::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--gold-deep);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .range__link:hover .range__link-text::after,
  .range__link:focus-visible .range__link-text::after {
    transform: scaleX(1);
  }
  .range__link-arrow {
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .range__link:hover .range__link-arrow {
    transform: translateX(5px);
  }

  /* ── Controls ───────────────────────────────────────────────── */
  .range__controls {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    /* Halved (Stephane 2026-05-24) from clamp(--space-4, 2vw, --space-6)
       to bring the controls closer to the image — they should clearly
       belong to the image above, not float midway between the image
       and the story below. .range padding-bottom stepped up in the
       same pass so the controls→story gap remains meaningful. */
    margin-top: clamp(var(--space-2), 1vw, var(--space-4));
  }
  /* Step buttons — bare arrow glyphs. Stephane review 2026-05-23:
     the circle/border treatment read too button-like for a sub-control;
     the arrow alone is enough. Click-target preserved via padding
     (matches the prior 46px target). Focus ring restored on
     focus-visible so keyboard users still see the affordance. */
  .range__step {
    display: grid;
    place-items: center;
    padding: var(--space-3) var(--space-4);
    border: 0;
    background: transparent;
    color: var(--gold-deep);
    font-size: 1rem;
    cursor: pointer;
    transition:
      color var(--dur-default) var(--ease-paper),
      transform var(--dur-default) var(--ease-paper);
  }
  .range__step:hover {
    color: var(--gold);
    transform: translateY(-1px);
  }
  .range__step:active {
    transform: translateY(1px);
  }
  .range__step:focus-visible {
    outline: 1px solid var(--gold);
    outline-offset: 2px;
  }
  .range__dots {
    display: flex;
    gap: var(--space-5);
  }
  .range__dot {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
    border: 0;
    padding: var(--space-2) 0;
    cursor: pointer;
  }
  .range__dot::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--gold);
    background: transparent;
    transition:
      background-color var(--dur-default) var(--ease-paper),
      transform var(--dur-default) var(--ease-paper);
  }
  .range__dot.is-active::before {
    background: var(--gold);
    transform: scale(1.15);
  }
  .range__dot-label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--ash);
    transition: color var(--dur-default) var(--ease-paper);
  }
  .range__dot.is-active .range__dot-label {
    color: var(--gold-deep);
  }
  .range__dot:hover .range__dot-label {
    color: var(--gold-deep);
  }

  @media (max-width: 720px) {
    .range__frame {
      min-height: 0;
    }
    /* Mobile layering — three stacked layers in the frame (Stephane
       2026-05-24): ghost letter (back, existing position/opacity/z),
       cigar (middle, semi-transparent, vertically centred and tall),
       copy (front, opaque, readable on top). Grid collapses to a
       single column so the copy flows top-to-bottom in its natural
       order; the cigar is pulled out of flow with position:absolute
       and centred against the .range__frame positioning context. The
       Caprice desktop flip doesn't apply (single column on mobile);
       both SKUs share this treatment. */
    .range__frame-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      text-align: left;
    }
    /* Reset the Caprice desktop column/row assignments — irrelevant
       once .range__media is absolutely positioned, but kept defensive
       so the copy column always behaves as a normal block. */
    .range__frame--caprice .range__media,
    .range__frame--caprice .range__copy {
      grid-column: auto;
      grid-row: auto;
    }
    /* Caprice ghost-C — neutralise the desktop right-side anchor on
       mobile (Stephane 2026-05-25). Desktop pins the ghost to
       `left: calc(48% + 1.5cm)` to sit opposite the flipped image;
       on mobile the frame collapses to a single column with the cigar
       absolutely centred behind the copy, so the ghost must mirror
       Volage's base position (left: 4%). Without this reset the
       ghost-C and copy read as pushed too far right on mobile. */
    .range__frame--caprice .range__ghost {
      left: 4%;
      right: auto;
    }
    /* Cigar layer — middle. Pulled out of grid flow, anchored to the
       frame, vertically centred and centred horizontally. Tall and
       slim: max-height tuned to ~80vh so the cigar reads as a
       vertical column behind the copy. Opacity 0.4 (Stephane
       2026-05-25, swung 0.4 → 0.5 → 0.4 same day) keeps the copy
       on top readable without a scrim while letting the cigar
       sit faintly behind it. z-index 1 sits above the ghost
       (z 0) and below the copy (z 2). */
    .range__media {
      position: absolute;
      inset: 0;
      display: grid;
      /* place-items: start center (Stephane 2026-05-25) — anchor the
         cigar to the TOP of the absolute layer instead of centring it
         vertically. With centring, the tall cigar (max-height 80vh)
         overflows the short mobile frame symmetrically; the top is
         clipped by .range__viewport overflow:hidden. Volage shows the
         problem (wider cap = taller visible cigar at the same height);
         Caprice has more transparent top/bottom in its PNG so it gets
         away with centring. Anchoring to start pushes any overflow
         entirely below the frame (hidden by the same overflow:hidden),
         preserving the cigar's top on both SKUs. */
      place-items: start center;
      z-index: 1;
      opacity: 0.4;
      pointer-events: none;
    }
    .range__media-frame--object {
      aspect-ratio: auto;
      min-height: 0;
      max-width: none;
      margin: 0 auto;
      padding: 0;
    }
    .range__cigar--object {
      max-height: 80vh;
      max-width: 60%;
      width: auto;
      height: auto;
    }
    /* Volage mobile — same layered treatment. Sizing reverted to the
       earlier 80vh / 75% values (Stephane 2026-05-25, third pass): the
       60vh / 55% step shrank the cigar without solving the clip — the
       cap was still cut at the top. Root cause: `.range__media` is
       `position: absolute; inset: 0` relative to `.range__frame`, which
       on mobile collapses to `.range__copy`'s natural height. The
       frame's top edge therefore sits on the eyebrow line; with the
       base mobile `place-items: start center`, the cigar's PNG top
       edge is anchored to that same line, and the entrance scale (1.06
       → 1) plus parallax (yPercent -4 → 4) push the cap above it,
       where `.range__viewport`'s `overflow: hidden` clips. Fix is
       geometric, not size: translate the cigar img down inside its
       layer by 15% of its own height so the cap clears the top clip
       line with headroom for the parallax drift; any overflow now
       exits at the bottom (still clipped by the viewport — acceptable
       per Stephane, cap visibility is the priority). Translate scoped
       to the volage img only — Caprice is not reported as cropped and
       its PNG has more transparent padding above the cap, so the base
       `place-items: start center` continues to work there. */
    .range__frame--volage .range__media-frame--object {
      min-height: 0;
      max-width: none;
    }
    .range__frame--volage .range__cigar--object {
      max-height: 80vh;
      max-width: 75%;
    }
    .range__media-frame--scene {
      aspect-ratio: 1 / 1;
      max-width: 300px;
    }
    /* Copy layer — front. position:relative + z-index 2 so the text
       block sits clearly above the semi-transparent cigar. Colours,
       weights and sizes unchanged; no text shadows, no scrim. */
    .range__copy {
      position: relative;
      z-index: 2;
    }
    /* Ghost letter — back. Existing position / opacity / z-index 0
       carried through unchanged; this rule only adjusts the mobile
       size, as before. */
    .range__ghost {
      font-size: 30rem;
      opacity: 0.05;
    }
    .range__dot-label {
      display: none;
    }
  }
</style>

<script>
  import { gsap, REDUCED, ScrollTrigger } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-range]');
  const track = document.querySelector<HTMLElement>('[data-range-track]');
  const viewport = document.querySelector<HTMLElement>('[data-range-viewport]');
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-range-frame]'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-range-dot]'));
  const prev = document.querySelector<HTMLButtonElement>('[data-range-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-range-next]');

  if (section && track && frames.length > 1) {
    /* Media reads at half-opacity on mobile (object-on-void treatment);
       full opacity on desktop. Read once at init — no reflow listener
       needed; mobile/desktop swap requires a reload in normal use. */
    const MEDIA_OPACITY = window.matchMedia('(max-width: 720px)').matches ? 0.4 : 1;

    /* ── Per-frame entrance + parallax depth ───────────────────── */
    // Each frame's copy block is set ready to cascade in. The first
    // frame plays on scroll-in; subsequent frames play when activated.
    const frameState = frames.map((frame) => {
      const copyEls = frame.querySelectorAll<HTMLElement>(
        '.range__vitola, .range__name, .range__tagline, .range__lede, .range__quickspecs, .range__link',
      );
      const media = frame.querySelector<HTMLElement>('[data-range-media]');
      const ghost = frame.querySelector<HTMLElement>('[data-range-ghost]');
      return { frame, copyEls, media, ghost };
    });

    /* Play one frame's content in — copy cascades, media settles in,
       ghost letter eases up. (Pink hairline removed 2026-05-24 with
       the Option 1 object-on-void treatment; activation animation now
       lives in the copy cascade + media settle + ghost ease.) */
    const playFrame = (idx: number) => {
      const s = frameState[idx];
      if (!s) return;
      if (REDUCED) {
        gsap.set(s.copyEls, { opacity: 1, y: 0 });
        if (s.media) gsap.set(s.media, { opacity: MEDIA_OPACITY });
        if (s.ghost) gsap.set(s.ghost, { opacity: 0.05 });
        return;
      }
      gsap.fromTo(
        s.copyEls,
        { opacity: 0, y: 26 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', stagger: 0.09, overwrite: true },
      );
      if (s.media) {
        gsap.fromTo(
          s.media,
          { opacity: 0, scale: 1.06 },
          { opacity: MEDIA_OPACITY, scale: 1, duration: 1, ease: 'power2.out', overwrite: true },
        );
      }
      if (s.ghost) {
        gsap.fromTo(
          s.ghost,
          { opacity: 0, scale: 1.15 },
          { opacity: 0.05, scale: 1, duration: 1.2, ease: 'power2.out', overwrite: true },
        );
      }
    };

    // Pre-hide every frame's animatable content so nothing flashes.
    if (!REDUCED) {
      frameState.forEach((s) => {
        gsap.set(s.copyEls, { opacity: 0, y: 26 });
        if (s.media) gsap.set(s.media, { opacity: 0 });
        if (s.ghost) gsap.set(s.ghost, { opacity: 0 });
      });
    }

    // Frame 1 plays the first time the section scrolls into view.
    ScrollTrigger.create({
      trigger: viewport ?? section,
      start: 'top 75%',
      once: true,
      onEnter: () => playFrame(0),
    });

    /* Parallax — the cigar drifts a touch against the scroll while its
       section passes, and the ghost letter drifts the opposite way for
       depth. Scrub-tied; the Marigold title-break technique. */
    if (!REDUCED) {
      frameState.forEach((s) => {
        if (s.media) {
          gsap.fromTo(
            s.media,
            { yPercent: -4 },
            {
              yPercent: 4,
              ease: 'none',
              scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: true },
            },
          );
        }
        if (s.ghost) {
          gsap.fromTo(
            s.ghost,
            { yPercent: 6 },
            {
              yPercent: -6,
              ease: 'none',
              scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: true },
            },
          );
        }
      });
    }

    /* ── Slider navigation ─────────────────────────────────────── */
    let index = 0;
    let played = [true, ...Array(frames.length - 1).fill(false)];

    const go = (to: number) => {
      index = (to + frames.length) % frames.length;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
        dot.setAttribute('aria-selected', String(i === index));
      });
      // Play the frame's content the first time it becomes active.
      if (!played[index]) {
        played[index] = true;
        // Small delay so the cascade reads after the slide settles.
        window.setTimeout(() => playFrame(index), REDUCED ? 0 : 220);
      }
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));
    prev?.addEventListener('click', () => go(index - 1));
    next?.addEventListener('click', () => go(index + 1));

    /* Pointer swipe — drag the track left/right to switch frames. A
       lifestyle slider should feel direct to the hand. */
    if (viewport) {
      let startX = 0;
      let dragging = false;
      viewport.addEventListener('pointerdown', (e) => {
        dragging = true;
        startX = e.clientX;
      });
      const endDrag = (e: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 60) go(dx < 0 ? index + 1 : index - 1);
      };
      viewport.addEventListener('pointerup', endDrag);
      viewport.addEventListener('pointercancel', () => (dragging = false));
    }

    // Keyboard — arrow keys move the slider when a control is focused.
    section.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') go(index + 1);
      if (e.key === 'ArrowLeft') go(index - 1);
    });
  }
</script>
