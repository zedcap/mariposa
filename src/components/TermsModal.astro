---
/* ════════════════════════════════════════════════════════════════
   TermsModal — Mariposa House Rules

   Renders site-wide via BaseLayout. Hidden by default. Opens when
   any element on the page dispatches the custom event
       window.dispatchEvent(new CustomEvent('mariposa:open-terms'))

   The dialog now ships as a SHELL only. The 12 sections of legal
   copy used to be inlined here, which meant ~9KB of T&C body was
   sent on every page. They now live on the canonical /terms/ route
   (src/pages/terms.astro). When the modal opens, it fetches that
   page once and injects the [data-terms-content] section into the
   dialog body. The fetched HTML is cached in a module-scoped
   variable so subsequent opens reuse it.

   Footer uses a direct <a href> to /terms/ — the modal is reserved
   for the AGE-GATE context, where firing a navigation mid-decision
   would be jarring. One mechanism, two registers.

   Pattern: native <dialog> for free focus trap, ESC-to-close, and
   backdrop semantics. Backdrop click and the corner X also close.
   Focus returns to the opener element on close.
   ════════════════════════════════════════════════════════════════ */

import { withBase } from '../lib/path';

const introHeading = 'MARIPOSA HOUSE RULES';
const introSubtitle = 'Terms & Conditions';
const termsUrl = withBase('/terms/');
---

<dialog
  class="terms-modal"
  data-terms-modal
  data-terms-url={termsUrl}
  aria-labelledby="terms-modal-title"
  aria-modal="true"
>
  <div class="terms-modal__frame">
    <header class="terms-modal__bar">
      <div class="terms-modal__bar-titles">
        <h2 class="terms-modal__title" id="terms-modal-title">{introHeading}</h2>
        <p class="terms-modal__subtitle">{introSubtitle}</p>
      </div>
      <button
        class="terms-modal__close"
        type="button"
        data-terms-close
        aria-label="Close Terms"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        </svg>
      </button>
    </header>

    <div class="terms-modal__body" tabindex="0">
      {/* Body content is fetched from /terms/ on first open. The
          loading state shows briefly; the cached body reuses it
          on subsequent opens. */}
      <div class="terms-modal__loading" data-terms-loading>Loading...</div>
      <div class="terms-modal__content" data-terms-body hidden></div>
    </div>
  </div>
</dialog>

<style>
  /* ─── Dialog shell ────────────────────────────────────────── */
  .terms-modal {
    padding: 0;
    border: none;
    background: transparent;
    color: var(--ink);

    width: min(680px, calc(100vw - 2 * var(--page-pad-m)));
    max-height: 80vh;

    margin: auto;

    overflow: visible;
  }

  .terms-modal::backdrop {
    background: rgba(31, 27, 23, 0.62);
    backdrop-filter: blur(2px);
  }

  .terms-modal__frame {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
    background: var(--white);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    box-shadow: var(--shadow-lift);
    overflow: hidden;
  }

  /* ─── Sticky title bar ────────────────────────────────────── */
  .terms-modal__bar {
    position: sticky;
    top: 0;
    z-index: 2;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--pearl);
    border-bottom: 1px solid var(--border-gold);
  }

  .terms-modal__bar-titles {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .terms-modal__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0;
  }

  .terms-modal__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-h5);
    line-height: var(--lh-snug);
    color: var(--ink);
    margin: 0;
  }

  .terms-modal__close {
    flex: 0 0 auto;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: transparent;
    border: 1px solid var(--border-gold);
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      color var(--dur-default) var(--ease-paper),
      background-color var(--dur-default) var(--ease-paper),
      border-color var(--dur-default) var(--ease-paper);
  }
  .terms-modal__close:hover,
  .terms-modal__close:focus-visible {
    color: var(--ink);
    background: var(--white);
    border-color: var(--gold);
    outline: none;
  }

  /* ─── Scrollable body ─────────────────────────────────────── */
  .terms-modal__body {
    overflow-y: auto;
    padding: var(--space-6) var(--space-6) var(--space-7);
    scrollbar-gutter: stable;
  }
  .terms-modal__body:focus-visible {
    outline: none;
  }

  .terms-modal__loading {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--ink-soft);
    text-align: center;
    padding: var(--space-6) 0;
  }

  /* The fetched /terms/ markup carries its own .terms-page__* class
     names with their own styling (loaded by the standalone page).
     Once injected here, those rules still apply because the page
     CSS is bundled globally per route by Astro. To avoid the
     standalone page chrome (padding, max-width) doubling up inside
     the dialog, neutralise the outer wrapper when it lives in the
     modal context. */
  .terms-modal__content :global(.terms-page) {
    padding: 0;
    background: transparent;
  }
  .terms-modal__content :global(.terms-page__inner) {
    max-width: none;
  }
  .terms-modal__content :global(.terms-page__header) {
    /* The modal already carries a sticky title bar with the same
       headings; drop the duplicate masthead from the injected body. */
    display: none;
  }

  /* ─── Mobile ──────────────────────────────────────────────── */
  @media (max-width: 540px) {
    .terms-modal {
      width: calc(100vw - 2 * var(--space-4));
      max-height: 86vh;
    }
    .terms-modal__frame {
      max-height: 86vh;
    }
    .terms-modal__bar {
      padding: var(--space-4) var(--space-5);
    }
    .terms-modal__body {
      padding: var(--space-5) var(--space-5) var(--space-6);
    }
  }

  /* ─── Motion ──────────────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .terms-modal[open] .terms-modal__frame {
      animation: terms-rise var(--dur-default) var(--ease-paper);
    }
    .terms-modal[open]::backdrop {
      animation: terms-fade var(--dur-default) var(--ease-paper);
    }
  }
  @keyframes terms-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes terms-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>

<script>
  /* TermsModal behaviour.
     - Opens on the `mariposa:open-terms` custom event.
     - First open: fetches /terms/, extracts [data-terms-content],
       injects into the body, caches in a module-scoped string.
     - Subsequent opens: reuses the cached markup, no re-fetch.
     - Closes on backdrop click, X button, and ESC (native).
     - Locks body scroll while open (reuses the gate-locked class).
     - Returns focus to the opener element on close. */
  const dialog = document.querySelector<HTMLDialogElement>('[data-terms-modal]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-terms-close]');
  const bodyEl = document.querySelector<HTMLElement>('[data-terms-body]');
  const loadingEl = document.querySelector<HTMLElement>('[data-terms-loading]');

  /* Module-scoped cache. Populated on first successful fetch. */
  let cachedMarkup: string | null = null;
  let fetchInFlight: Promise<string> | null = null;

  async function loadTerms(url: string): Promise<string> {
    if (cachedMarkup !== null) return cachedMarkup;
    if (fetchInFlight) return fetchInFlight;
    fetchInFlight = (async () => {
      const res = await fetch(url, { credentials: 'same-origin' });
      if (!res.ok) throw new Error(`Failed to load terms: ${res.status}`);
      const html = await res.text();
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const node = doc.querySelector('[data-terms-content]');
      if (!node) throw new Error('Terms content not found in /terms/');
      cachedMarkup = node.outerHTML;
      return cachedMarkup;
    })();
    try {
      return await fetchInFlight;
    } finally {
      fetchInFlight = null;
    }
  }

  if (dialog) {
    let opener: HTMLElement | null = null;

    const open = async (evt: Event) => {
      const detail = (evt as CustomEvent).detail as { opener?: HTMLElement } | undefined;
      opener = detail?.opener ?? (document.activeElement as HTMLElement | null);
      if (typeof dialog.showModal === 'function') {
        dialog.showModal();
      } else {
        dialog.setAttribute('open', '');
      }
      document.body.classList.add('gate-locked');

      /* If already cached, paint immediately; otherwise fetch. */
      if (bodyEl && loadingEl) {
        if (cachedMarkup !== null) {
          bodyEl.innerHTML = cachedMarkup;
          bodyEl.hidden = false;
          loadingEl.hidden = true;
        } else {
          bodyEl.hidden = true;
          loadingEl.hidden = false;
          const url = dialog.dataset.termsUrl ?? '/terms/';
          try {
            const markup = await loadTerms(url);
            bodyEl.innerHTML = markup;
            bodyEl.hidden = false;
            loadingEl.hidden = true;
          } catch (e) {
            loadingEl.textContent = 'Could not load terms. Please visit /terms/.';
          }
        }
      }
    };

    const close = () => {
      if (dialog.open) dialog.close();
    };

    window.addEventListener('mariposa:open-terms', open as EventListener);

    closeBtn?.addEventListener('click', close);

    /* Backdrop click — when the user clicks the <dialog> element itself
       (not its inner frame), the click originated on the backdrop. */
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });

    /* Native ESC fires a 'cancel' event before close — let it proceed. */
    dialog.addEventListener('close', () => {
      document.body.classList.remove('gate-locked');
      if (opener && typeof opener.focus === 'function') {
        opener.focus();
      }
      opener = null;
    });
  }
</script>
