---
/* Home lifestyle section — the condensed Mariposa story.
   ------------------------------------------------------------------
   REBUILD (2026-05-21). The first cut was a tidy 1:1 column grid —
   image left, text right, both sitting still. The scope names this the
   section that "most needs to read as a lifestyle brand," and a static
   split panel is the opposite of that. This rebuild makes it an
   immersive editorial spread:

   - the section opens on a tall, near-full-bleed image with a slow
     parallax drift and a scale-settle (the Marigold hero-image move);
   - the story copy sits in a card that lifts off the image, breaking
     the grid line — the design system's "asymmetry is welcome";
   - the copy reveals paragraph by paragraph on scroll-in;
   - the closing line is set at display scale and unveiled through a
     clipping mask, the brand's emotional landing.

   Since the About page ships, this section stays atmospheric and
   points to /about.

   IMAGERY: the Mariposa brandmark composition (brandmark-sq.jpg) —
   the square brand artwork from the creative-assets set.

   prefers-reduced-motion: no parallax, no scale; copy shown in place. */
import { Image } from 'astro:assets';
import { withBase } from '../lib/path';
import lifestyleCollage from '../assets/brandmark-sq.jpg';

interface Props {
  eyebrow: string;
  paragraphs: string[];
  closingLine: string;
  aboutLinkLabel: string;
}
const { eyebrow, paragraphs, closingLine, aboutLinkLabel } = Astro.props;
---

<section class="story" aria-labelledby="story-heading" data-story data-cream-bg>
  {/* Cream-bleed wedge — softens the edge where the (pearl) product
      slider above meets the cream lifestyle bed. Sits above the image
      bed so it does not interfere with the parallax. */}
  <div class="story__bleed" aria-hidden="true"></div>

  {/* Full-bleed image bed with a parallax/scale drift. */}
  <div class="story__bed" data-story-bed>
    <div class="story__bed-media" data-story-media>
      <Image
        class="story__img"
        src={lifestyleCollage}
        alt="Mariposa brandmark composition: the lowercase wordmark, the gold band, and the butterfly motif."
        widths={[720, 1200, 1800]}
        sizes="100vw"
        loading="lazy"
      />
    </div>
    <div class="story__bed-wash" aria-hidden="true"></div>
  </div>

  {/* Story card — lifts off the image bed, breaking the grid. */}
  <div class="story__layer container">
    <article class="story__card grain" data-story-card>
      <p class="eyebrow story__eyebrow" id="story-heading">{eyebrow}</p>

      <div class="story__prose">
        {paragraphs.map((para) => <p class="story__para" data-story-para>{para}</p>)}
      </div>

      <h2 class="story__closing">
        {
          closingLine.split('. ').map((part, i, arr) => (
            <span class="motion-mask">
              <span class="motion-line">{part}{i < arr.length - 1 ? '.' : ''}</span>
            </span>
          ))
        }
      </h2>

      <a class="story__link" href={withBase('/about')} data-story-link>
        <span class="story__link-text">{aboutLinkLabel}</span>
        <span class="story__link-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </article>
  </div>
</section>

<style>
  .story {
    position: relative;
    /* Cream lifestyle bed — warmer than the pearl product section
       above. The transition is graded via .story__bleed; see below. */
    background: #f2f0e9;
    /* The section is tall — the image bed and the lifted card need
       room to overlap with deliberate negative space. */
    padding-block: clamp(var(--space-9), 14vw, calc(var(--space-10) * 1.4));
  }

  /* Cream-bleed wedge — the gradual handoff from the pearl section
     above (--bg-elevated, #FAFAF7) into the cream lifestyle bed.
     Sits ABOVE the image bed at the top of the section, fading from
     opaque pearl down to transparent so the image (and the cream
     beneath it) emerges gradually. Without this the top edge of the
     section reads as a banded horizontal cut between the pearl page
     above and the darkened image below. */
  .story__bleed {
    position: absolute;
    inset: 0 0 auto 0;
    height: clamp(120px, 18vh, 220px);
    background: linear-gradient(
      to bottom,
      var(--bg-elevated) 0%,
      rgba(250, 250, 247, 0.6) 45%,
      rgba(250, 250, 247, 0) 100%
    );
    /* Above the image bed (z-index 1) so it can soften the bed's
       top edge; below the story layer/card (z-index 2) so the card
       still sits cleanly above. */
    z-index: 1;
    pointer-events: none;
  }
  /* Image bed sits between the page background and the bleed wedge. */
  .story__bed { z-index: 0; }

  /* ── Image bed ──────────────────────────────────────────────── */
  .story__bed {
    position: absolute;
    inset: 0;
    /* The bed does not run the full section; it occupies the upper
       portion so the card can lift off its lower edge. */
    height: 68%;
    overflow: hidden;
  }
  .story__bed-media {
    position: absolute;
    /* Oversized so the parallax drift never reveals an edge. */
    inset: -12% 0;
    will-change: transform;
  }
  .story__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) sepia(0.24) contrast(1.04) brightness(0.86);
  }
  /* Wash — grades the image into the cream page so the card reads.
     Bottom stop matches the section background (#f2f0e9) so the bed
     dissolves into the cream rather than reintroducing a white edge. */
  .story__bed-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(28, 25, 21, 0.28) 0%, transparent 30%),
      linear-gradient(to top, #f2f0e9 0%, rgba(242, 240, 233, 0.2) 38%, transparent 60%);
  }

  /* ── Story card ─────────────────────────────────────────────── */
  .story__layer {
    position: relative;
    z-index: 2;
    /* Push the card down so it sits across the bed's lower edge. */
    padding-top: clamp(28vh, 34vw, 42vh);
  }
  .story__card {
    background: var(--pearl);
    border: 1px solid var(--border-gold);
    box-shadow: var(--shadow-lift);
    /* Asymmetric — the card hangs off the left grid line, not centred,
       and is held to an editorial measure, not full width. */
    max-width: 600px;
    margin-left: clamp(0px, 6vw, 96px);
    padding: clamp(var(--space-7), 5vw, var(--space-9));
  }
  /* Paper-grain over the card surface. */
  .story__card.grain::before {
    opacity: 0.06;
  }

  .story__eyebrow {
    margin-bottom: var(--space-6);
  }

  .story__para {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.15rem, 1.9vw, 1.4rem);
    line-height: var(--lh-loose);
    color: var(--ink);
  }
  .story__para + .story__para {
    margin-top: var(--space-5);
  }

  /* Closing line — display scale, unveiled through clipping masks. */
  .story__closing {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.06;
    letter-spacing: var(--ls-display);
    color: var(--gold-deep);
    margin: 0;
    margin-top: var(--space-8);
  }
  /* Block masks — padded top/bottom and pulled back by an equal
     negative margin so ascenders/descenders sit clear at rest while
     the slide-up travel is still clipped. */
  .story__closing .motion-mask {
    display: block;
    overflow: hidden;
    padding-block: 0.14em;
    margin-block: -0.14em;
  }
  .story__closing .motion-line {
    display: block;
  }

  .story__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-7);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: var(--ls-small);
    color: var(--gold-deep);
    text-decoration: none;
  }
  .story__link-text {
    position: relative;
    padding-bottom: 3px;
  }
  .story__link-text::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--gold-deep);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .story__link:hover .story__link-text::after,
  .story__link:focus-visible .story__link-text::after {
    transform: scaleX(1);
  }
  .story__link-arrow {
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .story__link:hover .story__link-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 720px) {
    .story__bed { height: 52%; }
    .story__layer { padding-top: clamp(22vh, 40vw, 34vh); }
    .story__card {
      margin-left: 0;
      padding: var(--space-7);
    }
  }
</style>

<script>
  import { reveal, revealLines, parallax, scaleScrub } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-story]');
  if (section) {
    const bed = section.querySelector<HTMLElement>('[data-story-bed]');
    const media = section.querySelector<HTMLElement>('[data-story-media]');
    const card = section.querySelector<HTMLElement>('[data-story-card]');
    const eyebrow = section.querySelector('.story__eyebrow');
    const paras = section.querySelectorAll('[data-story-para]');
    const masks = section.querySelectorAll('.story__closing .motion-mask');
    const link = section.querySelector('[data-story-link]');

    // The image bed drifts slowly against the scroll and eases from a
    // touch enlarged toward true size — the Marigold hero-image move.
    parallax(media, { depth: 90, scope: bed });
    scaleScrub(media, { from: 1.12, to: 1, scope: bed });

    // The card lifts in as a whole, then its contents cascade.
    if (card) reveal(card, { y: 40, duration: 1, start: 'top 82%' });
    if (eyebrow) reveal(eyebrow, { y: 14, duration: 0.6, delay: 0.15, start: 'top 80%' });
    reveal(paras, { y: 22, duration: 0.8, stagger: 0.14, delay: 0.2, start: 'top 78%' });

    // The closing line unveils through its masks — the emotional landing.
    revealLines(masks, { start: 'top 84%', stagger: 0.13 });

    if (link) reveal(link, { y: 16, duration: 0.7, delay: 0.1, start: 'top 88%' });
  }
</script>
