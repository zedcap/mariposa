---
/* Home lifestyle section — the condensed Mariposa story.
   ------------------------------------------------------------------
   2026-05-23. The image bed (brandmark-sq.jpg) and the duotone wash
   that floated behind the card have been removed; the card now sits
   directly on the page surface. The card-level "Mariposa" eyebrow has
   also been removed — the story opens straight into the italic prose.
   The closing display-scale line ("Don't wait for special occasions.
   Create them.") has been stripped as redundant with the footer
   brand-line; the closing thought now lives inline as the final
   sentence of the second paragraph.

   2026-05-23 (later). The mariposa wordmark now opens the card as a
   centred masthead, sized to match the .range__name SKU type in the
   product slider (clamp(1.6rem, 4.0vw, 2.8rem) — height, with auto
   width). Space-6 separates the mark from the first prose paragraph.

   2026-05-23 (revert). The cream section background (#f2f0e9) and
   the [data-cream-bg] hook for the nav observer are restored after
   Stephane reversed the strip-cream pass. The body is plain white
   again, and the paper-fibre texture is now scoped to the story
   card's interior only — applied as a tiled background on
   .story__card so the card reads as a paper-toned surface against
   the cream section bed. Card geometry, padding rhythm, and
   paragraph-by-paragraph reveal are preserved.

   prefers-reduced-motion: copy shown in place (handled by reveal). */

import { Image } from 'astro:assets';
import wordmarkWhite from '../assets/mariposa-logo-white.png';

interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section class="story" aria-labelledby="story-heading" data-story data-cream-bg>
  <div class="story__layer container">
    <article class="story__card grain" data-story-card>
      <h2 class="visually-hidden" id="story-heading">The Mariposa story</h2>

      <Image
        class="story__wordmark"
        src={wordmarkWhite}
        alt="Mariposa"
        widths={[260, 420, 640]}
        sizes="(max-width: 720px) 50vw, 320px"
        loading="lazy"
      />

      <div class="story__prose">
        {paragraphs.map((para) => <p class="story__para" data-story-para>{para}</p>)}
      </div>
    </article>
  </div>
</section>

<style>
  .story {
    position: relative;
    /* Cream section bed restored (Stephane 2026-05-23, revert): the
       lifestyle section returns to #f2f0e9, matching the product
       section above so the cream zone reads as one continuous band
       from the bleed wedge down to the footer.
       Top padding halved (Stephane review 2026-05-23): paired cut
       with .range's padding-bottom to close the slider-controls →
       story-card gap ~50%. Bottom padding halved in the same shape
       (Stephane review 2026-05-23, later) to close the story-card →
       footer gap ~50%; mirrors the top value exactly. Footer's own
       padding-top (--footer-rhythm: 48px) left alone — modest next
       to the story's 96–179px range, so one knob does the work. */
    background: #f2f0e9;
    padding-top: clamp(var(--space-7), 7vw, calc(var(--space-10) * 0.7));
    padding-bottom: clamp(var(--space-7), 7vw, calc(var(--space-10) * 0.7));
  }

  /* ── Story card ─────────────────────────────────────────────── */
  .story__layer {
    position: relative;
    z-index: 2;
  }
  .story__card {
    /* Pink card on cream bed (Stephane 2026-05-23, later). Replaces
       the pearl + paper-fibre treatment: solid --pink (#d06f98),
       no texture overlay (it didn't read over pink). Wordmark and
       prose flip to white below. Card geometry, border, lift, and
       reveal motion all preserved. */
    background-color: var(--pink);
    border: 1px solid var(--border-gold);
    box-shadow: var(--shadow-lift);
    /* Centered + widened (Stephane review 2026-05-23). Previous
       asymmetry (margin-left clamp + 600px cap) broke the now-removed
       brandmark image bed; with the bed gone the offset has no
       remaining rationale. Card recentred via margin-inline:auto and
       widened 600 → 760px so it occupies more horizontal real estate
       without losing the editorial measure on the prose inside. */
    max-width: 760px;
    margin-inline: auto;
    padding: clamp(var(--space-7), 5vw, var(--space-9));
  }
  /* Paper-grain over the card surface. */
  .story__card.grain::before {
    opacity: 0.06;
  }

  /* Wordmark masthead — centred above the prose, sized to match the
     SKU name in the product slider (.range__name). Width auto so the
     mark's natural aspect ratio (~6.66:1) is preserved. Block element
     with auto inline margins so the centre call is one-line to flip
     to left-alignment if Stephane prefers. */
  .story__wordmark {
    display: block;
    height: clamp(1.6rem, 4.0vw, 2.8rem);
    width: auto;
    margin-inline: auto;
    margin-bottom: var(--space-6);
  }

  .story__para {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    /* One step smaller (Stephane review 2026-05-23, later). Proportional
       drop on all three clamp values, ~83%: floor 0.95→0.8rem, middle
       1.8→1.5vw, ceiling 1.2→1.0rem. Italic treatment, line-height,
       paragraph reveal motion all preserved. */
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    line-height: var(--lh-loose);
    color: var(--white);
  }
  .story__para + .story__para {
    margin-top: var(--space-5);
  }

  @media (max-width: 720px) {
    .story__card {
      padding: var(--space-7);
    }
  }
</style>

<script>
  import { reveal } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-story]');
  if (section) {
    const card = section.querySelector<HTMLElement>('[data-story-card]');
    const paras = section.querySelectorAll('[data-story-para]');

    // The card lifts in as a whole, then its paragraphs cascade.
    if (card) reveal(card, { y: 40, duration: 1, start: 'top 82%' });
    reveal(paras, { y: 22, duration: 0.8, stagger: 0.14, delay: 0.2, start: 'top 78%' });
  }
</script>
