---
/* Base layout — the shared shell for every page.
   Wires the design tokens + base CSS, the age gate, the header,
   the sticky contact element, and the footer.

   Nav placement — marigold.global pattern. The header is NOT pinned to
   the top of the viewport. It sits in normal document flow directly
   below the hero, then `position: sticky; top: 0` makes it detach and
   stick to the top once the hero has scrolled away. (marigold.global
   does the same with a GSAP ScrollTrigger pin; native `sticky` gives
   the identical behaviour with no JavaScript.)

   A page with a hero passes its hero markup into the named `hero` slot.
   It renders before the header, so the header rests below it on load.
   A page with no hero leaves the `hero` slot empty: the header is then
   the first thing in flow and is stuck to the top from the start. One
   mechanism, both cases. */
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyContact from '../components/StickyContact.astro';
import AgeGate from '../components/AgeGate.astro';
import { withBase } from '../lib/path';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Mariposa — hand-rolled cigars from Jember, East Java. Volcanic Soul. 24-Carat Gold.',
} = Astro.props;

/* True when the page supplies hero markup. Drives the header's
   over-hero vs from-the-top resting state. */
const hasHero = Astro.slots.has('hero');

/* --grain-image carries the paper-grain SVG with the Astro `base` baked
   in. CSS url() references are not rewritten for the base, so the grain
   utilities in base.css / ProductSlider read this variable instead.
   Set on <html> so it resolves as a :root-level custom property.

   --bg-texture does the same job for the body's tiled paper-fibre
   background (texture.jpg, served from /public). Same reason: CSS url()
   cannot be hard-coded under a subpath deployment. */
const grainImage = `url("${withBase('/paper-grain.svg')}")`;
const bgTexture  = `url("${withBase('/texture.jpg')}")`;
---

<!doctype html>
<html lang="en" style={`--grain-image: ${grainImage}; --bg-texture: ${bgTexture};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <AgeGate />

    <main id="main">
      {/* Hero renders first so the header rests below it on load.
          Empty on hero-less pages — header then sits at the top. */}
      <slot name="hero" />
      <Header overHero={hasHero} />
      <slot />
    </main>

    <Footer />
    <StickyContact />

    <style>
      .skip-link {
        position: absolute;
        left: var(--space-4);
        top: -100px;
        z-index: 200;
        background: var(--ink);
        color: var(--white);
        padding: var(--space-3) var(--space-5);
        border-radius: var(--radius-xs);
        font-family: var(--font-body);
        font-size: var(--fs-small);
        text-decoration: none;
        transition: top var(--dur-quick) var(--ease-paper);
      }
      .skip-link:focus {
        top: var(--space-4);
      }
    </style>
  </body>
</html>
