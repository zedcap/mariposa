---
/* Home position statement — the brand's opening line on the page.
   ------------------------------------------------------------------
   REBUILD (2026-05-23). The first cut centred the line vertically in a
   tall section and unveiled it with a single masked rise. This version
   anchors the line at the top of the section — the gap from the
   nav-bar's bottom edge to the top of the headline equals one
   nav-height of breathing room (84px desktop, 66px mobile, matching
   Header.astro). The line is split into two halves that slide in from
   opposite sides ("Cuban Soul." from the left, "24 Carat Swiss Gold."
   from the right) and settle into one composed sentence. A small
   gold-leaf divider sits halfway between the headline and the sub-line.

   Treatment per the conventions overlay: "Cuban Soul." pink, the rest
   ink, both halves display italic, wrapping naturally — not locked to
   one line. The sub-line follows, quieter. */
import dividerGoldLeaf from '../assets/divider-gold-leaf.svg?raw';

interface Props {
  /** Brand position copy split into the pink half and the ink half. */
  positionPink: string;
  positionInk: string;
  subline: string;
}
const { positionPink, positionInk, subline } = Astro.props;
---

<section class="position" aria-label="Mariposa" data-position>
  <div class="position__inner container">
    {/* The position sentence. Each half lives inside a horizontal
        clipping mask; the inner line slides in from its side on entry
        and settles into the centred composition. */}
    <h2 class="position__line">
      <span class="position__half">
        <span class="slide-mask">
          <span class="slide-inner position__em" data-direction="left">{positionPink}</span>
        </span>
      </span>
      {' '}
      <span class="position__half">
        <span class="slide-mask">
          <span class="slide-inner position__ink" data-direction="right">{positionInk}</span>
        </span>
      </span>
    </h2>

    {/* Quiet gold-leaf ornament, halfway between the headline and the
        sub-line. Inlined so the SVG inherits the page's coloring and
        loads with no extra request. */}
    <div class="position__divider" aria-hidden="true" set:html={dividerGoldLeaf} />

    <p class="position__subline" data-position-subline>{subline}</p>
  </div>
</section>

<style>
  .position {
    background: var(--white);
    /* Symmetric vertical breathing room: top and bottom both equal one
       nav-height. Desktop: 84px (resting nav height). Mobile: 66px. The
       headline sits one nav-height below the nav-bar's bottom edge; the
       sub-line sits one nav-height above the next section. */
    padding-top: 84px;
    padding-bottom: 84px;
  }
  @media (max-width: 720px) {
    .position {
      padding-top: 66px;
      padding-bottom: 66px;
    }
  }

  .position__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Position sentence — display italic, wraps naturally.
     The conventions overlay forbids locking it to one line. */
  .position__line {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.9rem, 4.8vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: var(--ls-display);
    margin: 0;
    max-width: 18ch;
  }
  .position__half {
    display: inline;
  }
  .position__em { color: var(--pink); }
  .position__ink { color: var(--ink); }

  /* Horizontal slide-in mask. Each half is wrapped in a clipping box
     wide enough to absorb the off-stage transform; the inner element
     translates in from its side. Padding/negative margin pairs leave
     room for the italic's ascenders/descenders without clipping. */
  .slide-mask {
    display: inline-block;
    overflow: hidden;
    padding: 0.16em 0.06em;
    margin: -0.16em -0.06em;
    vertical-align: bottom;
  }
  .slide-inner {
    display: inline-block;
    /* JS sets the entry transform. Without JS the line is simply in
       place — no flash of off-stage content. */
  }

  /* Quiet gold-leaf divider — centred, narrow. "Very short": 96px on
     desktop, scaling down on mobile. Reads as a hairline ornament, not
     a feature. Static; no draw-in. */
  .position__divider {
    display: block;
    margin: clamp(var(--space-5), 4vw, var(--space-7)) auto;
    width: clamp(64px, 8vw, 96px);
    line-height: 0;
  }
  .position__divider :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .position__subline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.35rem, 2.8vw, 1.75rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    margin-top: 0;
    max-width: 34ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .position { min-height: 0; }
  }
</style>

<script>
  import { slideIn, reveal } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-position]');
  if (section) {
    const halves = section.querySelectorAll<HTMLElement>('.slide-inner');
    const subline = section.querySelector<HTMLElement>('[data-position-subline]');

    // Two halves slide in from opposite sides and settle.
    slideIn(halves, { start: 'top 78%' });

    // Sub-line settles in last.
    if (subline) reveal(subline, { y: 18, duration: 0.8, delay: 0.25, start: 'top 72%' });
  }
</script>
