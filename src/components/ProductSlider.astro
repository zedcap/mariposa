---
/* Home product section — Option B, the paired editorial slider.
   The range is two cigars; that pairing is the story. Two full-bleed
   editorial frames (Volage, Caprices) on a horizontal track. A two-dot
   indicator and an edge-peek of the next frame keep the second SKU
   present. Mirrors the hero's slider motion vocabulary.

   Each frame: cigar image (the tight-cropped PNG works as placeholder),
   name in display serif, tagline, a short lede, link to the product page. */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import cigarVolage from '../assets/cigar-volage.png';
import cigarCaprices from '../assets/cigar-caprices.png';
import { withBase } from '../lib/path';

interface ProductFrame {
  name: string;
  slug: string;
  edition?: string;
  tag?: string;
  tagline: string;
  homeLede: string;
}
interface Props {
  eyebrow: string;
  heading: string;
  products: ProductFrame[];
}
const { eyebrow, heading, products } = Astro.props;

const cigarImages: Record<string, ImageMetadata> = {
  volage: cigarVolage,
  caprices: cigarCaprices,
};
---

<section class="range grain" id="range" aria-labelledby="range-heading" data-range>
  <div class="range__head container">
    <p class="eyebrow eyebrow--rule">{eyebrow}</p>
    <h2 id="range-heading" class="range__heading">{heading}</h2>
  </div>

  <div class="range__viewport">
    <div class="range__track" data-range-track>
      {
        products.map((product) => (
          <article class="range__frame" data-range-frame>
            <div class="range__frame-inner container">
              <div class="range__media">
                <Image
                  class="range__cigar"
                  src={cigarImages[product.slug]}
                  alt={`The Mariposa ${product.name} cigar, ${product.tagline.toLowerCase()}`}
                  widths={[260, 420, 640]}
                  sizes="(max-width: 720px) 60vw, 30vw"
                  loading="lazy"
                />
              </div>
              <div class="range__copy">
                <div class="range__tags">
                  {product.edition && <span class="range__tag">{product.edition}</span>}
                  {product.tag && <span class="range__tag range__tag--muted">{product.tag}</span>}
                </div>
                <h3 class="range__name">{product.name}</h3>
                <p class="range__tagline">{product.tagline}</p>
                <p class="range__lede">{product.homeLede}</p>
                <a class="range__link" href={withBase(`/${product.slug}`)}>
                  Discover {product.name}
                  <span class="range__link-arrow" aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <!-- Two-dot indicator + minimal step controls -->
  <div class="range__controls container">
    <button class="range__step" type="button" data-range-prev aria-label="Previous cigar">
      <span aria-hidden="true">&larr;</span>
    </button>
    <div class="range__dots" role="tablist" aria-label="Cigars">
      {
        products.map((product, i) => (
          <button
            class:list={['range__dot', { 'is-active': i === 0 }]}
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={`Show ${product.name}`}
            data-range-dot={i}
          />
        ))
      }
    </div>
    <button class="range__step" type="button" data-range-next aria-label="Next cigar">
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>
</section>

<style>
  .range {
    background: var(--bg-elevated);
    padding-block: clamp(var(--space-8), 9vw, var(--space-10));
    overflow: hidden;
  }

  .range__head {
    margin-bottom: var(--space-8);
  }
  .range__heading {
    margin-top: var(--space-5);
    max-width: 18ch;
  }

  /* Viewport clips the track; the track translates between frames.
     A small horizontal inset lets the next frame peek at the edge. */
  .range__viewport {
    overflow: hidden;
  }
  .range__track {
    display: flex;
    transition: transform var(--dur-slow) var(--ease-paper);
  }
  .range__frame {
    flex: 0 0 100%;
  }

  .range__frame-inner {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: clamp(var(--space-6), 6vw, var(--space-10));
    align-items: center;
    min-height: 460px;
  }

  /* Cigar media — pearl panel, paper-grain, pink hairline (the pager wink). */
  .range__media {
    position: relative;
    background: var(--white);
    border: 1px solid var(--border-gold);
    aspect-ratio: 4 / 5;
    display: grid;
    place-items: center;
    padding: var(--space-8);
    overflow: hidden;
  }
  .range__media::before {
    content: "";
    position: absolute;
    inset: 0;
    /* --grain-image set on :root by BaseLayout — base-path baked in.
       CSS url() is not rewritten for Astro's `base`. */
    background-image: var(--grain-image);
    background-size: 200px 200px;
    opacity: 0.05;
    pointer-events: none;
  }
  .range__media::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: var(--pink);
  }
  .range__cigar {
    width: auto;
    max-height: 86%;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(31, 27, 23, 0.22));
  }

  .range__tags {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .range__tag {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-xs);
    padding: 4px 10px;
  }
  .range__tag--muted {
    color: var(--ash);
    border-color: var(--whisper);
  }

  .range__name {
    font-size: clamp(2.6rem, 5vw, 4rem);
    line-height: 1;
  }
  .range__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-h5);
    color: var(--ink);
    margin-top: var(--space-4);
  }
  .range__lede {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-soft);
    margin-top: var(--space-4);
    max-width: 38ch;
  }

  .range__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: var(--ls-small);
    color: var(--gold-deep);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--border-gold);
    transition: color var(--dur-default) var(--ease-paper);
  }
  .range__link:hover {
    color: var(--ink);
  }
  .range__link-arrow {
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .range__link:hover .range__link-arrow {
    transform: translateX(4px);
  }

  /* Controls */
  .range__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    margin-top: var(--space-8);
  }
  .range__step {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--gold-deep);
    font-size: 1rem;
    cursor: pointer;
    transition:
      background-color var(--dur-default) var(--ease-paper),
      transform var(--dur-default) var(--ease-paper);
  }
  .range__step:hover {
    background: var(--white);
    transform: translateY(-2px);
  }
  .range__dots {
    display: flex;
    gap: var(--space-3);
  }
  .range__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--gold);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition: background-color var(--dur-default) var(--ease-paper);
  }
  .range__dot.is-active {
    background: var(--gold);
  }

  @media (max-width: 720px) {
    .range__frame-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      min-height: 0;
      text-align: left;
    }
    .range__media {
      aspect-ratio: 3 / 4;
      max-width: 280px;
    }
  }
</style>

<script>
  // Product slider — horizontal track, two-dot indicator, step controls.
  const track = document.querySelector<HTMLElement>('[data-range-track]');
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-range-frame]'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-range-dot]'));
  const prev = document.querySelector<HTMLButtonElement>('[data-range-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-range-next]');

  if (track && frames.length > 1) {
    let index = 0;

    const go = (to: number) => {
      index = (to + frames.length) % frames.length;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
        dot.setAttribute('aria-selected', String(i === index));
      });
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));
    prev?.addEventListener('click', () => go(index - 1));
    next?.addEventListener('click', () => go(index + 1));
  }
</script>
