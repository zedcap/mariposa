---
/* Volage product page — seven-section rebuild.
   ------------------------------------------------------------------
   Refactor on 2026-05-23 from the original five-section spec page
   (hero / narrative lede / 12-row spec / 3-column tasting / cross-link).
   Replaced per Pax's research brief, Part 3, and Stephane's sign-off
   on the structure. Section-by-section sources:

     1. Hero               — refined. Format line stripped (duplicates
                             vitola). Existing image, existing rhythm.
     2. The signature      — NEW. Gold-leaf differentiator surfaced
                             out of the body copy and given its own
                             pearl-bed section, second on the page.
                             Image is a placeholder (commissioned
                             macro pending).
     3. Origin arc         — three beats (Argopuro / Jember / Time),
                             tall image + copy per beat. All three
                             images are placeholders.
     4. The cigar          — two-paragraph narrative, six-row
                             condensed spec strip, native <details>
                             for full specifications.
     5. The smoke arc      — three tasting thirds in a vertical
                             stack, sticky gold timeline marks the
                             0' / 15' / 30' / 45' beats. Existing
                             tasting copy preserved. Pairings NOT
                             included (future addition).
     6. Packaging          — three-up static gallery. All three
                             slots are placeholders.
     7. Cross-link         — existing centred crosslink to Caprice
                             preserved verbatim.

   Components: sections 2, 3, 5 are extracted into reusable
   components so Caprice can drop in its own content unchanged.
   Sections 1, 4, 6, 7 stay inline on this page — they either
   carry SKU-specific layout (hero) or are simple enough that
   componentising would cost more than it saves at this scale.

   Motion: rise-and-fade reveals via the shared helper. Sticky
   timeline in section 5 is CSS-only (no GSAP pin); active-tick
   tracking is a small IntersectionObserver inside the component.
   No scrubbed parallax anywhere. */

import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureBlock from '../components/SignatureBlock.astro';
import OriginArc from '../components/OriginArc.astro';
import SmokeArc from '../components/SmokeArc.astro';
import { withBase } from '../lib/path';
import cigarVolage from '../assets/cigar-volage-pink.jpg';

const product = (await getEntry('products', 'volage'))!.data;

/* Split specs into condensed + remainder for the section-4 strip
   and the full-specs reveal. If no condensedSpecKeys is supplied,
   all specs go in the strip. */
const condensedKeys = new Set(product.condensedSpecKeys ?? product.specs.map((s) => s.label));
const condensedSpecs = product.specs.filter((s) => condensedKeys.has(s.label));
const remainderSpecs = product.specs.filter((s) => !condensedKeys.has(s.label));

/* Per-beat shape for OriginArc. Image is omitted here — every beat
   is a placeholder until the commissioned shots land. When a beat
   gets an image, it imports from src/assets and passes the
   ImageMetadata in. */
const originBeats = (product.origin ?? []).map((b) => ({
  label: b.label,
  copy: b.copy,
  placeholderCaption: b.placeholderCaption,
}));
---

<BaseLayout title={`Mariposa — ${product.name}`}>
  {/* ─── 1. Hero ──────────────────────────────────────────────── */}
  <section class="hero" data-reveal-section>
    <div class="hero__inner container">
      <div class="hero__media" data-reveal-media>
        <div class="hero__media-frame">
          <span class="hero__hairline" aria-hidden="true"></span>
          <Image
            class="hero__cigar"
            src={cigarVolage}
            alt={`The Mariposa ${product.name} cigar, ${product.tagline.toLowerCase()}`}
            widths={[420, 720, 1080, 1440]}
            sizes="(max-width: 720px) 90vw, 48vw"
            loading="eager"
          />
        </div>
      </div>

      <div class="hero__copy" data-reveal-copy>
        {product.edition && (
          <p class="hero__edition">{product.edition}</p>
        )}
        <h1 class="hero__name">{product.name}</h1>
        <p class="hero__vitola">{product.vitola}</p>
        {/* Format line removed (per brief): duplicates vitola and adds
            noise. Format lives in the spec strip in section 4. */}
        <p class="hero__tagline">{product.tagline}</p>
      </div>
    </div>
  </section>

  {/* ─── 2. The signature — gold leaf ────────────────────────── */}
  {product.signature && (
    <SignatureBlock
      lede={product.signature.lede}
      paragraph={product.signature.paragraph}
      placeholderCaption={product.signature.placeholderCaption}
    />
  )}

  {/* ─── 3. Origin arc ───────────────────────────────────────── */}
  {originBeats.length > 0 && (
    <OriginArc beats={originBeats} />
  )}

  {/* ─── 4. The cigar — narrative + selective specs ──────────── */}
  <section class="cigar" aria-labelledby="cigar-heading" data-reveal-section>
    <div class="cigar__inner container">
      <p class="eyebrow cigar__eyebrow" id="cigar-heading">The cigar</p>

      {/* Two short narrative paragraphs — italic display, same body
          treatment used elsewhere on the page. */}
      <div class="cigar__narrative">
        {product.narrative.map((para) => (
          <p class="cigar__para" data-reveal-para>{para}</p>
        ))}
      </div>

      {/* Six-row condensed spec strip — single horizontal row at
          desktop, two-col at tablet, stacked at mobile. */}
      <dl class="cigar__strip" data-reveal-strip>
        {condensedSpecs.map((row) => (
          <div class="cigar__strip-row">
            <dt class="cigar__strip-label">{row.label}</dt>
            <dd class="cigar__strip-value">{row.value}</dd>
          </div>
        ))}
      </dl>

      {/* Full specs — native <details>, no JS dependency. Summary
          styled as a quiet eyebrow link. */}
      {remainderSpecs.length > 0 && (
        <details class="cigar__full">
          <summary class="cigar__full-summary">
            <span class="cigar__full-label">Full specifications</span>
            <span class="cigar__full-glyph" aria-hidden="true">+</span>
          </summary>
          <dl class="cigar__full-list">
            {remainderSpecs.map((row) => (
              <div class="cigar__full-row">
                <dt class="cigar__full-label-row">{row.label}</dt>
                <dd class="cigar__full-value">{row.value}</dd>
              </div>
            ))}
          </dl>
        </details>
      )}
    </div>
  </section>

  {/* ─── 5. The smoke arc ────────────────────────────────────── */}
  <SmokeArc tasting={product.tasting} />

  {/* ─── 6. Packaging — static gallery ───────────────────────── */}
  {product.packaging && product.packaging.length > 0 && (
    <section class="packaging" aria-labelledby="packaging-heading" data-reveal-section>
      <div class="packaging__inner container">
        <p class="eyebrow packaging__eyebrow" id="packaging-heading">Presentation</p>
        <p class="packaging__lede">
          Presented as a single cigar, the gold leaf set against the
          band and the postcard tucked alongside.
        </p>
        <div class="packaging__grid">
          {product.packaging.map((slot, i) => (
            <figure class="placeholder placeholder--square" aria-label={slot.placeholderCaption ?? `Packaging placeholder ${i + 1}`} data-reveal-pack>
              <span class="placeholder__corner placeholder__corner--tl" aria-hidden="true"></span>
              <span class="placeholder__corner placeholder__corner--tr" aria-hidden="true"></span>
              <span class="placeholder__corner placeholder__corner--bl" aria-hidden="true"></span>
              <span class="placeholder__corner placeholder__corner--br" aria-hidden="true"></span>
              <figcaption class="placeholder__caption">
                {slot.placeholderCaption ?? 'PLACEHOLDER: packaging shot required.'}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ─── 7. Cross-link — preserved ───────────────────────────── */}
  <section class="crosslink" data-reveal-section>
    <div class="crosslink__inner container">
      <a class="crosslink__link" href={withBase('/caprice')}>
        <span class="crosslink__lead">Also from Mariposa</span>
        <span class="crosslink__sku">Caprice</span>
        <span class="crosslink__arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Shared section rhythm ─────────────────────────────────── */
  section[data-reveal-section] {
    padding-block: clamp(var(--space-7), 7vw, var(--space-9));
  }

  /* ── 1. Hero ───────────────────────────────────────────────── */
  .hero {
    padding-top: clamp(var(--space-8), 9vw, var(--space-10));
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-7), 7vw, var(--space-10));
    align-items: center;
  }
  .hero__media {
    position: relative;
  }
  .hero__media-frame {
    position: relative;
    background: var(--white);
    border: 1px solid var(--border-gold);
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .hero__hairline {
    position: absolute;
    inset: 0 auto auto 0;
    height: 2px;
    width: 100%;
    background: var(--pink);
    z-index: 2;
  }
  .hero__cigar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 100%;
  }
  .hero__copy {
    display: flex;
    flex-direction: column;
  }
  .hero__edition {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 var(--space-5) 0;
  }
  .hero__name {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.2rem, 5.6vw, 4rem);
    line-height: 0.96;
    letter-spacing: var(--ls-display);
    margin: 0;
    color: var(--ink);
  }
  .hero__vitola {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: var(--space-5) 0 0 0;
  }
  .hero__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: var(--lh-snug);
    color: var(--ink);
    margin: var(--space-6) 0 0 0;
    max-width: 22ch;
  }

  /* ── 4. The cigar ──────────────────────────────────────────── */
  .cigar__inner {
    max-width: 880px;
    margin-inline: auto;
  }
  .cigar__eyebrow {
    margin-bottom: var(--space-7);
  }
  .cigar__narrative {
    max-width: 720px;
    margin-inline: auto;
  }
  .cigar__para {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 2.1vw, 1.45rem);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0;
  }
  .cigar__para + .cigar__para {
    margin-top: var(--space-5);
  }

  /* Condensed spec strip — six rows, two columns at desktop. */
  .cigar__strip {
    margin: clamp(var(--space-7), 6vw, var(--space-8)) 0 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(var(--space-6), 5vw, var(--space-9));
    row-gap: 0;
    border-top: 1px solid var(--border-gold);
  }
  .cigar__strip-row {
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) 1fr;
    gap: var(--space-5);
    align-items: baseline;
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--border-gold);
  }
  .cigar__strip-label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0;
  }
  .cigar__strip-value {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--ink);
    margin: 0;
    line-height: var(--lh-snug);
  }

  /* Full-specs disclosure — quiet, no chrome, summary as an
     underlined eyebrow with a plus glyph that rotates on open. */
  .cigar__full {
    margin-top: var(--space-7);
  }
  .cigar__full-summary {
    /* Remove default marker (Safari + Firefox). */
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    cursor: pointer;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--gold-deep);
    transition: color var(--dur-default) var(--ease-paper);
  }
  .cigar__full-summary::-webkit-details-marker {
    display: none;
  }
  .cigar__full-summary:hover {
    color: var(--ink);
  }
  .cigar__full-label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .cigar__full-glyph {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--gold-deep);
    transition: transform var(--dur-default) var(--ease-paper);
    display: inline-block;
    line-height: 1;
  }
  .cigar__full[open] .cigar__full-glyph {
    transform: rotate(45deg);
  }
  .cigar__full-list {
    margin: var(--space-6) 0 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(var(--space-6), 5vw, var(--space-9));
    row-gap: 0;
    border-top: 1px solid var(--border-gold);
  }
  .cigar__full-row {
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) 1fr;
    gap: var(--space-5);
    align-items: baseline;
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--border-gold);
  }
  .cigar__full-label-row {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0;
  }
  .cigar__full-value {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--ink);
    margin: 0;
    line-height: var(--lh-snug);
  }

  /* ── 6. Packaging ──────────────────────────────────────────── */
  .packaging {
    background: var(--pearl);
  }
  .packaging__inner {
    text-align: center;
  }
  .packaging__eyebrow {
    margin-bottom: var(--space-5);
  }
  .packaging__lede {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: var(--lh-loose);
    color: var(--ink);
    max-width: 44ch;
    margin: 0 auto var(--space-7) auto;
  }
  .packaging__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(var(--space-5), 4vw, var(--space-7));
    text-align: left;
  }
  .placeholder--square {
    aspect-ratio: 1 / 1;
  }
  @media (max-width: 720px) {
    .packaging__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Placeholder grammar (page-scoped, used by section 6) ──
     Same primitives as the components — kept inline here so the
     packaging grid doesn't depend on a shared partial. If a fourth
     placeholder use lands, extract. */
  .placeholder {
    position: relative;
    margin: 0;
    background: var(--white);
    border: 1px dashed var(--gold-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(var(--space-5), 4vw, var(--space-7));
  }
  .placeholder__caption {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-snug);
    letter-spacing: 0.02em;
    color: var(--gold-deep);
    text-align: center;
    max-width: 32ch;
  }
  .placeholder__corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--gold-deep);
  }
  .placeholder__corner--tl { top: -1px;  left: -1px;  border-right: 0; border-bottom: 0; }
  .placeholder__corner--tr { top: -1px;  right: -1px; border-left: 0;  border-bottom: 0; }
  .placeholder__corner--bl { bottom: -1px; left: -1px;  border-right: 0; border-top: 0; }
  .placeholder__corner--br { bottom: -1px; right: -1px; border-left: 0;  border-top: 0; }

  /* ── 7. Cross-link ─────────────────────────────────────────── */
  .crosslink {
    padding-bottom: clamp(var(--space-8), 9vw, var(--space-10));
  }
  .crosslink__inner {
    display: flex;
    justify-content: center;
  }
  .crosslink__link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-5) 0;
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    text-decoration: none;
    border-top: 1px solid var(--border-gold);
    border-bottom: 1px solid var(--border-gold);
  }
  .crosslink__lead {
    color: var(--ash);
  }
  .crosslink__sku {
    color: var(--gold-deep);
    position: relative;
    padding-bottom: 3px;
  }
  .crosslink__sku::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--gold-deep);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .crosslink__link:hover .crosslink__sku::after,
  .crosslink__link:focus-visible .crosslink__sku::after {
    transform: scaleX(1);
  }
  .crosslink__arrow {
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .crosslink__link:hover .crosslink__arrow {
    transform: translateX(5px);
  }

  /* ── Mobile collapse ───────────────────────────────────────── */
  @media (max-width: 720px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }
    .hero__media-frame {
      max-width: 360px;
      margin-inline: auto;
    }
    .cigar__strip,
    .cigar__full-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  /* Section reveals — restrained editorial entry. Each block's
     animatable children rise-and-fade as it scrolls into view.
     Reveals for the three componentised sections (signature,
     origin, smoke) are handled inside the components themselves. */
  import { reveal, refreshOnLoad } from '../lib/motion';

  // Hero — media and copy column rise together with a small stagger.
  const heroMedia = document.querySelector<HTMLElement>('[data-reveal-media]');
  const heroCopy  = document.querySelector<HTMLElement>('[data-reveal-copy]');
  if (heroMedia) reveal(heroMedia, { y: 32, duration: 1,   start: 'top 88%' });
  if (heroCopy)  reveal(heroCopy,  { y: 26, duration: 0.9, delay: 0.12, start: 'top 88%' });

  // Section 4 — narrative paragraphs cascade, spec strip lifts in.
  const cigarParas = document.querySelectorAll('.cigar [data-reveal-para]');
  const cigarStrip = document.querySelector<HTMLElement>('.cigar [data-reveal-strip]');
  if (cigarParas.length) reveal(cigarParas, { y: 22, duration: 0.9, stagger: 0.14, start: 'top 82%' });
  if (cigarStrip) reveal(cigarStrip, { y: 24, duration: 0.9, start: 'top 82%' });

  // Section 6 — packaging slots fade in as a block.
  const packs = document.querySelectorAll('.packaging [data-reveal-pack]');
  if (packs.length) reveal(packs, { y: 22, duration: 0.85, stagger: 0.12, start: 'top 84%' });

  // Section 7 — cross-link.
  const crosslink = document.querySelector<HTMLElement>('.crosslink__inner');
  if (crosslink) reveal(crosslink, { y: 22, duration: 0.8, start: 'top 88%' });

  refreshOnLoad();
</script>
