/* Same {{strong:...}} resolver the modal used. Kept locally — the
   modal source has been stripped; this is now the single owner of
   the data + rendering logic. */
function tokenise(raw: string): Array<{ kind: 'text' | 'strong'; value: string }> {
  const out: Array<{ kind: 'text' | 'strong'; value: string }> = [];
  const re = /\{\{strong:([^}]+)\}\}/g;
  let last = 0;
  let m: RegExpExecArray | null;
  while ((m = re.exec(raw)) !== null) {
    if (m.index > last) out.push({ kind: 'text', value: raw.slice(last, m.index) });
    out.push({ kind: 'strong', value: m[1] });
    last = m.index + m[0].length;
  }
  if (last < raw.length) out.push({ kind: 'text', value: raw.slice(last) });
  return out;
}
---

<BaseLayout title="Mariposa • Terms & Conditions" description="Mariposa House Rules — Terms & Conditions governing use of the site and purchase of our goods.">
  <article class="terms-page">
    {/* data-terms-content is the selector the TermsModal fetches and
        injects when the age-gate disclaimer fires open-terms. The
        article element above gets the standalone page chrome; this
        inner wrapper carries only the body content. */}
    <div class="terms-page__inner" data-terms-content>
      <nav class="terms-page__back terms-page__back--top" aria-label="Back">
        <a class="terms-page__back-link" href={homeHref} data-terms-back>
          <span aria-hidden="true">&larr;</span> Back
        </a>
      </nav>

      <header class="terms-page__header">
        <h1 class="terms-page__title">{introHeading}</h1>
        <p class="terms-page__subtitle">{introSubtitle}</p>
      </header>

      <p class="terms-page__intro">{intro}</p>

      {sections.map((s) => (
        <section class="terms-page__section">
          <h2 class="terms-page__heading">{s.heading}</h2>
          {s.blocks.map((block) =>
            Array.isArray(block) ? (
              <ul class="terms-page__list">
                {block.map((item) => (
                  <li class="terms-page__item">
                    {tokenise(item).map((t) =>
                      t.kind === 'strong' ? <strong>{t.value}</strong> : t.value
                    )}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="terms-page__p">
                {tokenise(block).map((t) =>
                  t.kind === 'strong' ? <strong>{t.value}</strong> : t.value
                )}
              </p>
            )
          )}
        </section>
      ))}

      <nav class="terms-page__back terms-page__back--bottom" aria-label="Back">
        <a class="terms-page__back-link" href={homeHref} data-terms-back>
          <span aria-hidden="true">&larr;</span> Back
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>

<script>
  /* Progressive enhancement: if the visitor arrived from the same
     origin, prefer history.back() so they land where they were.
     Otherwise the anchor's href (withBase('/')) carries them home. */
  document.querySelectorAll<HTMLAnchorElement>('[data-terms-back]').forEach((el) => {
    el.addEventListener('click', (e) => {
      try {
        if (document.referrer && new URL(document.referrer).origin === location.origin) {
          e.preventDefault();
          history.back();
        }
      } catch {
        /* malformed referrer — fall through to the anchor */
      }
    });
  });
</script>

<style>
  /* Page chrome — standalone-page only. Body typography
     (.terms-page__heading, __p, __list, __item, gold disc bullet,
     intro, section rhythm, strong colour) now lives in
     src/styles/base.css so the TermsModal — which fetches this
     page and injects [data-terms-content] into the dialog — picks
     up the same register wherever it's triggered. Only the
     standalone-page surround stays here: background, page padding,
     centred narrow measure, and the masthead block the modal
     hides via display: none. */
  .terms-page {
    background: var(--white);
    padding-block: var(--space-9, var(--space-8));
    padding-inline: var(--page-pad-m);
  }

  .terms-page__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .terms-page__back {
    /* Editorial restraint — small Hanken eyebrow-weight nav above the
       masthead and below the last section. Left-aligned, no underline,
       gold-deep on hover to match the brand pattern. */
    font-family: var(--font-body);
  }
  .terms-page__back--top {
    margin-bottom: var(--space-5);
  }
  .terms-page__back--bottom {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border-gold);
  }
  .terms-page__back-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-size: var(--fs-small);
    color: var(--ink-soft);
    text-decoration: none;
    transition: color var(--dur-default, 180ms) ease;
  }
  .terms-page__back-link:hover,
  .terms-page__back-link:focus-visible {
    color: var(--gold-deep);
  }

  .terms-page__header {
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border-gold);
  }

  .terms-page__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 var(--space-2);
  }

  .terms-page__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-h3);
    line-height: var(--lh-snug);
    color: var(--ink);
    margin: 0;
  }

  @media (max-width: 540px) {
    .terms-page {
      padding-inline: var(--space-5);
      padding-block: var(--space-7);
    }
  }
</style>
