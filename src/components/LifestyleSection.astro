---
/* Home lifestyle section — the condensed Mariposa story.
   ------------------------------------------------------------------
   2026-05-23. The image bed (brandmark-sq.jpg) and the duotone wash
   that floated behind the card have been removed; the card now sits
   on the cream section background alone. The card-level "Mariposa"
   eyebrow has also been removed — the story opens straight into the
   italic prose. The closing display-scale line ("Don't wait for
   special occasions. Create them.") has been stripped as redundant
   with the footer brand-line; the closing thought now lives inline
   as the final sentence of the second paragraph.

   The cream section background and [data-cream-bg] attribute stay
   so the sticky nav continues to adopt cream over this section.
   Card geometry, padding rhythm, and paragraph-by-paragraph reveal
   are preserved.

   prefers-reduced-motion: copy shown in place (handled by reveal). */

interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section class="story" aria-labelledby="story-heading" data-story data-cream-bg>
  <div class="story__layer container">
    <article class="story__card grain" data-story-card>
      <h2 class="visually-hidden" id="story-heading">The Mariposa story</h2>

      <div class="story__prose">
        {paragraphs.map((para) => <p class="story__para" data-story-para>{para}</p>)}
      </div>
    </article>
  </div>
</section>

<style>
  .story {
    position: relative;
    background: #f2f0e9;
    padding-block: clamp(var(--space-9), 14vw, calc(var(--space-10) * 1.4));
  }

  /* ── Story card ─────────────────────────────────────────────── */
  .story__layer {
    position: relative;
    z-index: 2;
  }
  .story__card {
    background: var(--pearl);
    border: 1px solid var(--border-gold);
    box-shadow: var(--shadow-lift);
    /* Asymmetric — the card hangs off the left grid line, not centred,
       and is held to an editorial measure, not full width. */
    max-width: 600px;
    margin-left: clamp(0px, 6vw, 96px);
    padding: clamp(var(--space-7), 5vw, var(--space-9));
  }
  /* Paper-grain over the card surface. */
  .story__card.grain::before {
    opacity: 0.06;
  }

  .story__para {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 2.0vw, 1.35rem);
    line-height: var(--lh-loose);
    color: var(--ink);
  }
  .story__para + .story__para {
    margin-top: var(--space-5);
  }

  @media (max-width: 720px) {
    .story__card {
      margin-left: 0;
      padding: var(--space-7);
    }
  }
</style>

<script>
  import { reveal } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-story]');
  if (section) {
    const card = section.querySelector<HTMLElement>('[data-story-card]');
    const paras = section.querySelectorAll('[data-story-para]');

    // The card lifts in as a whole, then its paragraphs cascade.
    if (card) reveal(card, { y: 40, duration: 1, start: 'top 82%' });
    reveal(paras, { y: 22, duration: 0.8, stagger: 0.14, delay: 0.2, start: 'top 78%' });
  }
</script>
