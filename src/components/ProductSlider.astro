---
/* Home product section — Option B, the paired editorial slider.
   ------------------------------------------------------------------
   REBUILD (2026-05-21). The first cut wired the slider correctly but it
   sat still — two panels stacked behind a translate. This rebuild keeps
   Option B (resolved) and makes each frame a composed editorial spread:

   - a giant ghosted display letter behind the cigar (the Marigold
     title-break outline move — depth, scale on the page);
   - the cigar floating on a parallax drift, with a slow scale-settle;
   - the copy column cascading in word/line by word/line when its frame
     becomes active;
   - a kinetic slide between frames with the gold-sliver wash carried
     across (the slider's motion vocabulary matches the hero);
   - the whole section's header revealing on scroll-in.

   The range is two cigars; that pairing is the story. A two-dot
   indicator and an edge-peek keep the second SKU present.

   prefers-reduced-motion: no parallax, no drift; copy is shown in
   place; the track still moves between frames (a functional control,
   not decoration) but without the kinetic overshoot. */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import cigarVolage from '../assets/cigar-volage-terrasse.jpg';
import cigarCaprice from '../assets/cigar-caprice.png';
import { withBase } from '../lib/path';

interface ProductFrame {
  name: string;
  slug: string;
  vitola: string;
  tagline: string;
  homeLede: string[];
}
interface Props {
  products: ProductFrame[];
}
const { products } = Astro.props;

const cigarImages: Record<string, ImageMetadata> = {
  volage: cigarVolage,
  caprice: cigarCaprice,
};

// Per-slug image mode. 'object' = cigar-on-void PNG, floats inside the
// padded card with drop-shadow. 'scene' = full editorial photograph,
// fills the frame edge-to-edge. The frame's gold border and pink
// hairline are preserved in both modes; the inner treatment is what
// changes. Default is 'object' so adding a new SKU stays predictable.
const imageMode: Record<string, 'object' | 'scene'> = {
  volage: 'scene',
  caprice: 'object',
};
---

<section class="range grain" id="range" aria-label="The Mariposa range" data-range data-cream-bg>
  {/* No section heading — Stephane review (2026-05-21): the slider
      stands alone, no eyebrow, no title. The brand statement opens the
      page in the position section above. The section's "modern" energy
      comes from the per-frame choreography, not a header. */}

  {/* Cream-bleed wedge — softens the edge where the white position
      statement above meets the cream product bed. Fades from white at
      the top (matching the section above) down to cream so the boundary
      reads as a gradient, not a horizontal cut. Sits behind the product
      content (z-index 0); the slider's frames render above. */}
  <div class="range__bleed" aria-hidden="true"></div>

  <div class="range__viewport" data-range-viewport>
    <div class="range__track" data-range-track>
      {
        products.map((product, fi) => (
          <article class:list={['range__frame', `range__frame--${product.slug}`]} data-range-frame data-frame-index={fi}>
            {/* Ghost letter — a giant display initial behind the cigar,
                the title-break depth move. Scrubs scale/rotate. */}
            <span class="range__ghost" data-range-ghost aria-hidden="true">
              {product.name.charAt(0)}
            </span>

            <div class="range__frame-inner container">
              <div class="range__media" data-range-media>
                <div class:list={['range__media-frame', `range__media-frame--${imageMode[product.slug] ?? 'object'}`]}>
                  {/* Pink hairline — the pager wink — drawn in on
                      activation; a real element so GSAP can scale it. */}
                  <span class="range__hairline" data-range-hairline aria-hidden="true"></span>
                  <Image
                    class:list={['range__cigar', `range__cigar--${imageMode[product.slug] ?? 'object'}`]}
                    src={cigarImages[product.slug]}
                    alt={`The Mariposa ${product.name} cigar, ${product.tagline.toLowerCase()}`}
                    widths={[260, 420, 640]}
                    sizes="(max-width: 720px) 60vw, 32vw"
                    loading="lazy"
                  />
                </div>
              </div>

              <div class="range__copy" data-range-copy>
                <p class="range__vitola">{product.vitola}</p>
                <h3 class="range__name">{product.name}</h3>
                <p class="range__tagline">{product.tagline}</p>
                {product.homeLede.map((para) => (
                  <p class="range__lede">{para}</p>
                ))}
                <a class="range__link" href={withBase(`/${product.slug}`)}>
                  <span class="range__link-text">Discover {product.name}</span>
                  <span class="range__link-arrow" aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  {/* Controls — two-dot indicator + step buttons + a frame counter. */}
  <div class="range__controls container">
    <button class="range__step" type="button" data-range-prev aria-label="Previous cigar">
      <span aria-hidden="true">&larr;</span>
    </button>
    <div class="range__dots" role="tablist" aria-label="Cigars">
      {
        products.map((product, i) => (
          <button
            class:list={['range__dot', { 'is-active': i === 0 }]}
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={`Show ${product.name}`}
            data-range-dot={i}
          >
            <span class="range__dot-label">{product.name}</span>
          </button>
        ))
      }
    </div>
    <button class="range__step" type="button" data-range-next aria-label="Next cigar">
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>
</section>

<style>
  .range {
    position: relative;
    /* Cream product bed — begins the cream zone that runs through to
       the lifestyle section below. The handoff from the white position
       statement above is graded via .range__bleed. */
    background: #f2f0e9;
    padding-block: clamp(var(--space-9), 12vw, var(--space-10));
    overflow: hidden;
  }

  /* Cream-bleed wedge — the gradual handoff from the white position
     statement above into the cream product bed. Sits at the top of the
     section, fading from opaque white down to transparent so the cream
     bed emerges gradually. Without this the top edge reads as a banded
     horizontal cut. Stays behind the product content so the slider's
     imagery, hairline and ghost letter render cleanly above. */
  .range__bleed {
    position: absolute;
    inset: 0 0 auto 0;
    height: clamp(120px, 18vh, 220px);
    background: linear-gradient(
      to bottom,
      var(--white) 0%,
      rgba(255, 255, 255, 0.6) 45%,
      rgba(255, 255, 255, 0) 100%
    );
    z-index: 0;
    pointer-events: none;
  }

  /* ── Viewport / track ───────────────────────────────────────── */
  .range__viewport {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .range__track {
    display: flex;
    /* JS drives the transform; the transition is the kinetic slide. */
    transition: transform 720ms var(--ease-paper);
  }
  .range__frame {
    flex: 0 0 100%;
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
  }

  /* Ghost display initial — the depth layer. Sits behind the cigar,
     huge, faint, hanging off the grid. */
  .range__ghost {
    position: absolute;
    top: 50%;
    left: 4%;
    transform: translateY(-54%);
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(20rem, 42vw, 44rem);
    line-height: 0.7;
    color: var(--gold);
    opacity: 0.07;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    will-change: transform;
  }

  .range__frame-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.92fr 1fr;
    gap: clamp(var(--space-7), 7vw, var(--space-10));
    align-items: center;
    width: 100%;
  }

  /* ── Cigar media ────────────────────────────────────────────── */
  .range__media {
    position: relative;
    will-change: transform;
  }
  .range__media-frame {
    position: relative;
    background: var(--white);
    border: 1px solid var(--border-gold);
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    padding: clamp(var(--space-6), 5vw, var(--space-9));
    overflow: hidden;
  }
  .range__media-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--grain-image);
    background-size: 200px 200px;
    opacity: 0.05;
    pointer-events: none;
  }
  /* The pink hairline — the pager wink — drawn in left-to-right on
     frame activation. A real element so GSAP can scale it. */
  .range__hairline {
    position: absolute;
    inset: 0 auto auto 0;
    height: 2px;
    width: 100%;
    background: var(--pink);
    transform-origin: left center;
    transform: scaleX(1);
    z-index: 2;
  }
  .range__cigar {
    width: auto;
    max-height: 86%;
    object-fit: contain;
    filter: drop-shadow(0 16px 32px rgba(31, 27, 23, 0.24));
    will-change: transform;
  }

  /* Scene mode — the frame holds a full editorial photograph instead of
     a cigar-on-void PNG. The card padding is collapsed so the image
     fills the frame edge-to-edge, the drop-shadow is dropped (a
     rectangular photo doesn't want one), and object-fit becomes cover
     with object-position favouring the cigar (lower-right in the
     terrasse shot). The gold border and pink hairline are preserved. */
  .range__media-frame--scene {
    padding: 0;
  }
  .range__media-frame--scene::before {
    /* Tone the grain overlay down over a real photograph; the photo
       carries its own texture. */
    opacity: 0.025;
  }
  .range__cigar--scene {
    width: 100%;
    height: 100%;
    max-height: none;
    object-fit: cover;
    object-position: 50% 100%;
    filter: none;
  }

  /* ── Copy column ────────────────────────────────────────────── */
  /* Vitola — the cigar's shape name (Canonazo, Gordito). Replaces
     the earlier boxed edition/release pills. Eyebrow register: small,
     uppercase, tracked, gold-deep. Identical treatment across both
     SKUs — this is the only element the two cards still share at full
     parity (the name / tagline / lede may differ in size per slug). */
  .range__vitola {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    /* Halved vitola→name gap promoted to base (Stephane review
       2026-05-23): --space-5 → --space-3 now applies across the
       range, tightening the Gordito→Caprice gap to match Volage. */
    margin: 0 0 var(--space-3) 0;
  }

  /* Name / tagline / lede sizes (Stephane review 2026-05-23). The
     step-down originally introduced as a Volage-only modifier is now
     the base size for both SKUs — the side-by-side comparison decided
     in favour of the smaller scale across the range. The
     `.range__frame--volage` modifier has been retired. Same clamp
     shape as the prior step-down; lede sits at --fs-small (14px),
     the next named token below --fs-body (17px). */
  .range__name {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.6rem, 4.0vw, 2.8rem);
    line-height: 0.96;
    letter-spacing: var(--ls-display);
    margin: 0;
  }
  .range__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 2.0vw, 1.35rem);
    color: var(--ink);
    margin-top: var(--space-5);
  }
  .range__lede {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--ink-soft);
    margin-top: var(--space-4);
    /* Slightly wider measure so the longer paragraphs don't tower. */
    max-width: 46ch;
  }

  /* ── Per-slug overrides ─────────────────────────────────────── */
  /* (Currently none — the prior `.range__frame--volage` halved-gap
     override was promoted to base on 2026-05-23 so Caprice inherits
     it. The `range__frame--<slug>` classes remain on the markup and
     are available for future per-SKU tweaks.) */

  .range__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-7);
    font-family: var(--font-body);
    /* Stephane review 2026-05-23 (b): "it's just a link" — step down
       one token from --fs-small to --fs-eyebrow so the discover link
       reads as quiet nav, not a feature. Weight, case and tracking
       unchanged. */
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    text-decoration: none;
  }
  .range__link-text {
    position: relative;
    padding-bottom: 3px;
  }
  /* Underline draws left-to-right on hover — design-system link spec. */
  .range__link-text::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--gold-deep);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .range__link:hover .range__link-text::after,
  .range__link:focus-visible .range__link-text::after {
    transform: scaleX(1);
  }
  .range__link-arrow {
    transition: transform var(--dur-default) var(--ease-paper);
  }
  .range__link:hover .range__link-arrow {
    transform: translateX(5px);
  }

  /* ── Controls ───────────────────────────────────────────────── */
  .range__controls {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    margin-top: clamp(var(--space-5), 3vw, var(--space-7));
  }
  /* Step buttons — bare arrow glyphs. Stephane review 2026-05-23:
     the circle/border treatment read too button-like for a sub-control;
     the arrow alone is enough. Click-target preserved via padding
     (matches the prior 46px target). Focus ring restored on
     focus-visible so keyboard users still see the affordance. */
  .range__step {
    display: grid;
    place-items: center;
    padding: var(--space-3) var(--space-4);
    border: 0;
    background: transparent;
    color: var(--gold-deep);
    font-size: 1rem;
    cursor: pointer;
    transition:
      color var(--dur-default) var(--ease-paper),
      transform var(--dur-default) var(--ease-paper);
  }
  .range__step:hover {
    color: var(--gold);
    transform: translateY(-1px);
  }
  .range__step:active {
    transform: translateY(1px);
  }
  .range__step:focus-visible {
    outline: 1px solid var(--gold);
    outline-offset: 2px;
  }
  .range__dots {
    display: flex;
    gap: var(--space-5);
  }
  .range__dot {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: transparent;
    border: 0;
    padding: var(--space-2) 0;
    cursor: pointer;
  }
  .range__dot::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--gold);
    background: transparent;
    transition:
      background-color var(--dur-default) var(--ease-paper),
      transform var(--dur-default) var(--ease-paper);
  }
  .range__dot.is-active::before {
    background: var(--gold);
    transform: scale(1.15);
  }
  .range__dot-label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 400;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--ash);
    transition: color var(--dur-default) var(--ease-paper);
  }
  .range__dot.is-active .range__dot-label {
    color: var(--gold-deep);
  }
  .range__dot:hover .range__dot-label {
    color: var(--gold-deep);
  }

  @media (max-width: 720px) {
    .range__frame {
      min-height: 0;
    }
    .range__frame-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      text-align: left;
    }
    .range__media-frame {
      aspect-ratio: 3 / 4;
      max-width: 300px;
    }
    .range__ghost {
      font-size: 30rem;
      opacity: 0.05;
    }
    .range__dot-label {
      display: none;
    }
  }
</style>

<script>
  import { gsap, REDUCED, ScrollTrigger } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-range]');
  const track = document.querySelector<HTMLElement>('[data-range-track]');
  const viewport = document.querySelector<HTMLElement>('[data-range-viewport]');
  const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-range-frame]'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-range-dot]'));
  const prev = document.querySelector<HTMLButtonElement>('[data-range-prev]');
  const next = document.querySelector<HTMLButtonElement>('[data-range-next]');

  if (section && track && frames.length > 1) {
    /* ── Per-frame entrance + parallax depth ───────────────────── */
    // Each frame's copy block is set ready to cascade in. The first
    // frame plays on scroll-in; subsequent frames play when activated.
    const frameState = frames.map((frame) => {
      const copyEls = frame.querySelectorAll<HTMLElement>(
        '.range__vitola, .range__name, .range__tagline, .range__lede, .range__link',
      );
      const media = frame.querySelector<HTMLElement>('[data-range-media]');
      const ghost = frame.querySelector<HTMLElement>('[data-range-ghost]');
      const hairline = frame.querySelector<HTMLElement>('[data-range-hairline]');
      return { frame, copyEls, media, ghost, hairline };
    });

    /* Play one frame's content in — copy cascades, media settles in,
       ghost letter eases up, the pink hairline draws across. */
    const playFrame = (idx: number) => {
      const s = frameState[idx];
      if (!s) return;
      if (REDUCED) {
        gsap.set(s.copyEls, { opacity: 1, y: 0 });
        if (s.media) gsap.set(s.media, { opacity: 1 });
        if (s.ghost) gsap.set(s.ghost, { opacity: 0.07 });
        if (s.hairline) gsap.set(s.hairline, { scaleX: 1 });
        return;
      }
      gsap.fromTo(
        s.copyEls,
        { opacity: 0, y: 26 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', stagger: 0.09, overwrite: true },
      );
      if (s.media) {
        gsap.fromTo(
          s.media,
          { opacity: 0, scale: 1.06 },
          { opacity: 1, scale: 1, duration: 1, ease: 'power2.out', overwrite: true },
        );
      }
      if (s.ghost) {
        gsap.fromTo(
          s.ghost,
          { opacity: 0, scale: 1.15 },
          { opacity: 0.07, scale: 1, duration: 1.2, ease: 'power2.out', overwrite: true },
        );
      }
      if (s.hairline) {
        gsap.fromTo(
          s.hairline,
          { scaleX: 0 },
          { scaleX: 1, duration: 0.9, ease: 'power2.out', delay: 0.15, overwrite: true },
        );
      }
    };

    // Pre-hide every frame's animatable content so nothing flashes.
    if (!REDUCED) {
      frameState.forEach((s) => {
        gsap.set(s.copyEls, { opacity: 0, y: 26 });
        if (s.media) gsap.set(s.media, { opacity: 0 });
        if (s.ghost) gsap.set(s.ghost, { opacity: 0 });
        if (s.hairline) gsap.set(s.hairline, { scaleX: 0 });
      });
    }

    // Frame 1 plays the first time the section scrolls into view.
    ScrollTrigger.create({
      trigger: viewport ?? section,
      start: 'top 75%',
      once: true,
      onEnter: () => playFrame(0),
    });

    /* Parallax — the cigar drifts a touch against the scroll while its
       section passes, and the ghost letter drifts the opposite way for
       depth. Scrub-tied; the Marigold title-break technique. */
    if (!REDUCED) {
      frameState.forEach((s) => {
        if (s.media) {
          gsap.fromTo(
            s.media,
            { yPercent: -4 },
            {
              yPercent: 4,
              ease: 'none',
              scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: true },
            },
          );
        }
        if (s.ghost) {
          gsap.fromTo(
            s.ghost,
            { yPercent: 6 },
            {
              yPercent: -6,
              ease: 'none',
              scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: true },
            },
          );
        }
      });
    }

    /* ── Slider navigation ─────────────────────────────────────── */
    let index = 0;
    let played = [true, ...Array(frames.length - 1).fill(false)];

    const go = (to: number) => {
      index = (to + frames.length) % frames.length;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
        dot.setAttribute('aria-selected', String(i === index));
      });
      // Play the frame's content the first time it becomes active.
      if (!played[index]) {
        played[index] = true;
        // Small delay so the cascade reads after the slide settles.
        window.setTimeout(() => playFrame(index), REDUCED ? 0 : 220);
      }
    };

    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));
    prev?.addEventListener('click', () => go(index - 1));
    next?.addEventListener('click', () => go(index + 1));

    /* Pointer swipe — drag the track left/right to switch frames. A
       lifestyle slider should feel direct to the hand. */
    if (viewport) {
      let startX = 0;
      let dragging = false;
      viewport.addEventListener('pointerdown', (e) => {
        dragging = true;
        startX = e.clientX;
      });
      const endDrag = (e: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 60) go(dx < 0 ? index + 1 : index - 1);
      };
      viewport.addEventListener('pointerup', endDrag);
      viewport.addEventListener('pointercancel', () => (dragging = false));
    }

    // Keyboard — arrow keys move the slider when a control is focused.
    section.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') go(index + 1);
      if (e.key === 'ArrowLeft') go(index - 1);
    });
  }
</script>
