---
/* 21+ age gate — full-screen interstitial.
   ------------------------------------------------------------------
   2026-05-25. Replaced the prior full-bleed gold-wordmark design with
   the revised "card on translucent overlay" treatment Stephane picked
   from `age-gate-mocks.astro`. The home page sits visible behind a
   60% white overlay; a centred white card with pink hairline carries
   the question, side-by-side Yes / No buttons, a Remember-me tickbox
   (circular, ink-fill), and an inline Terms & Conditions trigger that
   fires the existing `mariposa:open-terms` event.

   Persistence:
   - "Yes" with Remember-me CHECKED  → localStorage['mariposaAgeConfirmed'] = 'true'
   - "Yes" with Remember-me UNCHECKED → sessionStorage['mariposaAgeConfirmed'] = 'true'
   - "No"  → redirect to /refusal/. No storage write — we don't
             remember a decline (could be a typo, a returning visitor
             might be of age). location.assign so the back button
             doesn't bring them back to the gated page in this session.

   A tiny inline head script clears the gate before paint if either
   store carries the flag, so a returning visitor never sees a flash. */
import { getEntry } from 'astro:content';
import { withBase } from '../lib/path';

const global = (await getEntry('site', 'global'))!.data as {
  ageGate: {
    question: string;
    confirm: string;
    decline: string;
  };
};
const { ageGate } = global;
---

{/* Runs before paint: if either store carries the flag, hide the gate
    and unlock scroll so a confirmed visitor never sees it. */}
<script is:inline>
  (function () {
    try {
      var ok =
        localStorage.getItem('mariposaAgeConfirmed') === 'true' ||
        sessionStorage.getItem('mariposaAgeConfirmed') === 'true';
      if (ok) {
        document.documentElement.setAttribute('data-age-ok', 'true');
      }
    } catch (e) {
      /* storage blocked — gate stays, visitor confirms each visit */
    }
  })();
</script>

<div class="age-gate" data-age-gate data-refusal-url={withBase('/refusal/')} aria-hidden="false">
  {/* Overlay — full-stage, 60% white, blocks the page beneath. */}
  <div class="age-gate__overlay" aria-hidden="true"></div>

  {/* Card — centred, opaque white, pink hairline, editorial frame. */}
  <div class="gate-card" role="dialog" aria-modal="true" aria-labelledby="age-gate-q">
    <span class="wordmark gate-card__mark">mariposa</span>

    <h2 class="gate-card__question" id="age-gate-q">{ageGate.question}</h2>

    <div class="gate-card__choices">
      <button class="gate-btn gate-btn--solid" type="button" data-age-confirm>
        {ageGate.confirm}
      </button>
      <button class="gate-btn gate-btn--outline" type="button" data-age-decline>
        {ageGate.decline}
      </button>
    </div>

    <label class="gate-card__remember">
      <input type="checkbox" class="gate-check" data-age-remember checked />
      <span class="gate-card__remember-text">Remember me on this device</span>
    </label>

    <p class="gate-card__disclaimer">
      By continuing, you confirm that you are of legal smoking age
      and agree to our{' '}
      <button type="button" class="gate-card__terms" data-open-terms>
        Terms &amp; Conditions
      </button>.
    </p>
  </div>
</div>

<style>
  .age-gate {
    position: fixed;
    inset: 0;
    z-index: 100;
  }
  /* Confirmed visitor (flag valid): never render the gate. */
  :global(html[data-age-ok='true']) .age-gate {
    display: none;
  }

  /* ─── Overlay — 60% white ────────────────────────────────── */
  .age-gate__overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--white) 60%, transparent);
  }

  /* ═══════════════════════════════════════════════════════════
     Gate card — centred, opaque, pink hairline.
     ═══════════════════════════════════════════════════════════ */
  .gate-card {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);

    width: min(440px, 90vw);
    background: var(--white);
    border: 1px solid var(--pink);

    padding-block: var(--space-7);
    padding-inline: var(--space-8);

    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .gate-card__mark {
    font-size: var(--fs-h5);
    color: var(--ink);
    line-height: 1;
  }

  .gate-card__question {
    margin: var(--space-6) 0 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: var(--lh-snug);
    color: var(--ink);
  }

  .gate-card__choices {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
    width: 100%;
    justify-content: center;
  }

  /* Buttons — square corners (--radius-xs) for the editorial register. */
  .gate-btn {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: var(--ls-small);
    border-radius: var(--radius-xs);
    padding: 12px 24px;
    cursor: pointer;
    flex: 1 1 auto;
    min-width: 120px;
    transition:
      background-color var(--dur-default) var(--ease-paper),
      color var(--dur-default) var(--ease-paper);
  }
  .gate-btn--solid {
    color: var(--white);
    background: var(--ink);
    border: 1px solid var(--ink);
  }
  .gate-btn--solid:hover {
    background: color-mix(in srgb, var(--ink) 85%, var(--white));
  }
  .gate-btn--outline {
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--ink);
  }
  .gate-btn--outline:hover {
    background: var(--pearl);
  }

  /* Remember-me — checkbox + label on one row. Amend (a): circular. */
  .gate-card__remember {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--ink-soft);
  }
  .gate-check {
    appearance: none;
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border: 1px solid var(--ink);
    background: var(--white);
    border-radius: 50%;
    display: inline-grid;
    place-content: center;
    cursor: pointer;
    margin: 0;
  }
  .gate-check::before {
    content: '';
    width: 8px;
    height: 8px;
    transform: scale(0);
    transition: transform var(--dur-quick) var(--ease-paper);
    background: var(--ink);
    border-radius: 50%;
  }
  .gate-check:checked::before {
    transform: scale(1);
  }
  .gate-check:focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 2px;
  }

  .gate-card__disclaimer {
    margin: var(--space-4) 0 0 0;
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    line-height: var(--lh-body);
    color: var(--ash);
    max-width: 36ch;
  }
  /* Amend (b): no underline. Amend (c): gold on hover/focus. */
  .gate-card__terms {
    font: inherit;
    color: var(--ink);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: none;
    transition: color var(--dur-quick) var(--ease-paper);
  }
  .gate-card__terms:hover,
  .gate-card__terms:focus-visible {
    color: var(--gold-deep);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .gate-card {
      padding-block: var(--space-6);
      padding-inline: var(--space-6);
    }
    .gate-card__choices { flex-wrap: wrap; }
  }
</style>

<script>
  /* Age gate behaviour.
     - Yes  : persist flag (localStorage if Remember-me, else sessionStorage),
              remove the gate, unlock scroll.
     - No   : no-op for now — Stephane has not specified the refusal
              destination. Gate stays visible. Flagged for follow-up.
     - T&C  : dispatches the existing `mariposa:open-terms` event. */
  const gate = document.querySelector<HTMLElement>('[data-age-gate]');
  const confirmBtn = document.querySelector<HTMLButtonElement>('[data-age-confirm]');
  const declineBtn = document.querySelector<HTMLButtonElement>('[data-age-decline]');
  const rememberBox = document.querySelector<HTMLInputElement>('[data-age-remember]');
  const termsBtn = document.querySelector<HTMLButtonElement>('[data-open-terms]');

  const ALREADY_OK = document.documentElement.getAttribute('data-age-ok') === 'true';
  const FLAG_KEY = 'mariposaAgeConfirmed';

  if (gate && confirmBtn && declineBtn && rememberBox) {
    if (!ALREADY_OK) {
      document.body.classList.add('gate-locked');
      confirmBtn.focus();
    }

    confirmBtn.addEventListener('click', () => {
      try {
        const store = rememberBox.checked ? localStorage : sessionStorage;
        store.setItem(FLAG_KEY, 'true');
      } catch (e) {
        /* storage blocked — gate will re-prompt next visit, acceptable */
      }
      gate.remove();
      document.body.classList.remove('gate-locked');
    });

    declineBtn.addEventListener('click', () => {
      /* Redirect to /refusal/. No storage write — we don't remember
         a decline (could be a typo, or a returning visitor might be
         of age). location.assign so the back button doesn't bring
         the visitor back to the gated page in this session. The
         URL is base-prefixed in the .astro template (data attribute)
         so it resolves under any Astro `base`. */
      const url = gate.dataset.refusalUrl ?? '/refusal/';
      window.location.assign(url);
    });
  }

  termsBtn?.addEventListener('click', () => {
    window.dispatchEvent(
      new CustomEvent('mariposa:open-terms', { detail: { opener: termsBtn } })
    );
  });
</script>
