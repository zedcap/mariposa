---
/* Home lifestyle section — the condensed Mariposa story.
   ------------------------------------------------------------------
   2026-05-24. Rebuild as Option A (full-bleed room), Stephane's pick
   from `/story-mocks`. The cream-bed card-on-paper pattern is gone:
   the section is now an 85vh edge-to-edge photographic ground
   (volage_gold.jpg) with the story prose set in white italic
   Spectral over a three-stop dark gradient.

   Adjustments to the mock-A baseline:
     1. The eyebrow text ("Mariposa — a small story") is replaced by
        the white mariposa wordmark, sized to the same height the
        masthead wordmark used previously (clamp(1.6rem, 4.0vw,
        2.8rem)). The mark opens the column at top; the prose closes.
        No closing wordmark below the prose.
     2. Background image: assets/story-bg-volage-gold.jpg (copied from
        the creative-assets cigars folder). object-position 50% 35%
        keeps the cigar shaft and 24-carat gold leaf in frame across
        the 85vh band; the gradient bites hardest behind the prose's
        vertical position (~42% ink mid-stop) so the white type holds.

   Cream-bed mechanics:
     - data-cream-bg attribute REMOVED. The section is now
       photographic, not cream — the nav observer should return to
       opaque white over this section. The product slider above keeps
       its data-cream-bg, so the observer mechanism is unchanged for
       that surface.

   Motion:
     - Single rise-and-fade on the prose column (wordmark + prose
       lifted together as one block). The previous
       paragraph-by-paragraph cascade was a card-era flourish; with
       the card gone, a single editorial settle reads cleaner.

   prefers-reduced-motion: copy shown in place (handled by reveal). */

import { Image } from 'astro:assets';
import storyBg from '../assets/story-bg-volage-gold.jpg';
import wordmarkWhite from '../assets/mariposa-logo-white.png';

interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section class="story" aria-labelledby="story-heading" data-story>
  <h2 class="visually-hidden" id="story-heading">The Mariposa story</h2>

  <Image
    class="story__bg"
    src={storyBg}
    alt=""
    aria-hidden="true"
    widths={[960, 1440, 1920, 2560]}
    sizes="100vw"
    loading="lazy"
  />

  <div class="story__scrim" aria-hidden="true"></div>

  <div class="story__inner" data-story-inner>
    <Image
      class="story__wordmark"
      src={wordmarkWhite}
      alt="Mariposa"
      widths={[260, 420, 640]}
      sizes="(max-width: 720px) 50vw, 320px"
      loading="lazy"
    />

    <div class="story__prose">
      {paragraphs.map((para) => <p>{para}</p>)}
    </div>
  </div>
</section>

<style>
  /* ── Section frame ──────────────────────────────────────────────
     85vh band, edge-to-edge of the viewport. No container; the
     section is its own bleed. min-height keeps the composition
     intact on very short viewports (laptop landscape, etc.). */
  .story {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 560px;
    overflow: hidden;
    display: grid;
    place-items: center;
    isolation: isolate;
  }

  /* ── Photographic ground ────────────────────────────────────────
     Astro <Image> emits a sized <img>; we pin it absolutely and let
     object-fit / object-position handle the crop. object-position
     50% 35% keeps the gold-leaf signature and cigar shaft in frame
     across the 85vh band; the source is squareish, so trimming top
     and bottom is the honest read. */
  .story__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 35%;
    z-index: 0;
  }

  /* ── Gradient overlay ───────────────────────────────────────────
     Three-stop dark-to-clear, biting hardest mid-section where the
     prose sits. ~18 / 42 / 28% ink — enough to hold white italic
     Spectral, light enough to keep the photographic ground reading
     as a photograph rather than a slab. Mobile gets a stronger pull
     because the prose occupies a larger share of the frame. */
  .story__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(31, 27, 23, 0.18) 0%,
      rgba(31, 27, 23, 0.42) 50%,
      rgba(31, 27, 23, 0.28) 100%
    );
  }

  /* ── Prose column ───────────────────────────────────────────────
     Centred, white italic Spectral. Wordmark at top, prose
     immediately below — there is no closing mark; the prose is the
     close.

     Width (Stephane 2026-05-24): widened from 52ch to 800px (~8/12
     of the 1200px design container). The narrower 52ch measure read
     as a text box centred in the photo; 800px gives the prose enough
     horizontal real estate to sit as a full editorial column over
     the photographic ground. Mobile is unaffected — the column there
     is bound by the viewport gutters, not the max. */
  .story__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: var(--page-pad-m);
    max-inline-size: 800px;
    margin-inline: auto;
  }

  .story__wordmark {
    display: block;
    height: clamp(1.6rem, 4.0vw, 2.8rem);
    width: auto;
    margin-inline: auto;
    margin-bottom: var(--space-7);
  }

  .story__prose p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    line-height: var(--lh-loose);
    color: var(--white);
  }
  .story__prose p + p {
    margin-top: var(--space-5);
  }

  /* ── Mobile ─────────────────────────────────────────────────────
     Strengthen the scrim so the prose stays legible against the
     larger relative share of the frame the type occupies on phones.

     Vertical separation (Stephane 2026-05-24, pass 3): the previous
     pass halved the band height on mobile (85vh→42.5vh / 560px→280px)
     reading "halve the padding" as a height move. The actual ask was
     MARGIN — visible space ABOVE and BELOW the band, separating it
     from the sections above/below. Band height restored to the
     original 85vh / 560px (matches desktop) so the photographic ground
     reads at full editorial weight on phones; margin-block adds the
     breathing room between this section and its neighbours.
     clamp(--space-7, 8vw, --space-9) = 48-96px floor/ceiling, ~8vw
     fluid in between (~32px at 400px viewport, ~58px at 720px). The
     section is full-bleed and has no container, so margin-block on
     the section element itself is the right insertion point. */
  @media (max-width: 720px) {
    /* Internal vertical space (Stephane 2026-05-24, pass 4): the
       85vh / 560px-min band centring the content via place-items
       produced ~110-140px of void above the wordmark and below the
       last paragraph. Spec: halve that. Mechanism: drop the fixed
       band height entirely, let content + explicit padding-block
       define the section height. clamp(--space-7, 12vw, --space-8)
       = 48-64px (48px floor, ~48px at 400vw, 64px at 720vw), ~half
       of the prior centring void. External margin-block unchanged. */
    .story {
      height: auto;
      min-height: 0;
      padding-block: clamp(var(--space-7), 12vw, var(--space-8));
      margin-block: clamp(var(--space-7), 8vw, var(--space-9));
    }
    .story__scrim {
      background: linear-gradient(
        180deg,
        rgba(31, 27, 23, 0.28) 0%,
        rgba(31, 27, 23, 0.55) 50%,
        rgba(31, 27, 23, 0.38) 100%
      );
    }
  }
</style>

<script>
  import { reveal } from '../lib/motion';

  /* Single rise-and-fade on the prose column. Wordmark + paragraphs
     lift together as one editorial block; the previous paragraph-by-
     paragraph cascade belonged to the card era and would feel busy
     against a still photographic ground. */
  const inner = document.querySelector<HTMLElement>('[data-story-inner]');
  if (inner) reveal(inner, { y: 32, duration: 1, start: 'top 82%' });
</script>
