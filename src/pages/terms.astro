---
/* Terms & Conditions — standalone, indexable, sharable.
   ------------------------------------------------------------------
   Extracted from the inline TermsModal body so the 12 sections of
   legal copy no longer ship on every route. The modal shell remains
   in BaseLayout for the age-gate "T&C" trigger (which fetches this
   page and injects [data-terms-content] into the dialog so the
   visitor doesn't navigate away mid-decision). The footer link is
   now a direct <a href> to this canonical URL.

   Copy is verbatim Stephane (2026-05-24) — the same data the modal
   used to inline. Typography follows the design system: Hanken
   eyebrows in uppercase, Spectral display subtitle, gold-deep
   accents, gold disc bullet markers. */

import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/path';

const homeHref = withBase('/');

interface Section {
  heading: string;
  blocks: Array<string | string[]>;
}

