---
/* About — Editorial mock (Option A: Issue masthead with numbered beats
   and one pull quote).
   ------------------------------------------------------------------
   Standalone proposal page at /about-editorial-mocks/. Direct-URL
   only — NOT linked from the nav. The live /about page is unchanged.

   Source: about-editorial-research.md (Pax, 2026-05-25), section 5 —
   the build spec for Option A. All decisions trace back to that brief.

   Origins beat copy and Founder paragraphs are the verbatim strings
   from the live /about (which in turn come from
   `mariposa cigars copy.docx`). Mirrored here so the editorial
   treatment changes without the content changing.

   Photography vs placeholder:
     · Beat I — REAL atmosphere (hero-mp-1.jpg), column-width 16:9.
     · Beat II — DASHED placeholder, half-column inset, 1:1.
     · Beat III — REAL atmosphere (hero-mp-3.jpg), column-width 3:2.
     · Beat IV — DASHED placeholder, full-bleed ~70vh — the article's
                 photographic peak, deliberately saved for the close.
     · Founder portrait — REAL (sz_smoking_2.jpg), half-column inset
                          before paragraph 1 (Pax's recommended
                          variant; gap 4 in §6 of brief). */

import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

import beat1Atmosphere from '../assets/hero-mp-1.jpg';
import beat3Atmosphere from '../assets/hero-mp-3.jpg';
import szSmoking from '../assets/sz_smoking_2.jpg';

/* ─── Origins copy — verbatim, mirrors live /about ───────── */

const beat1Eyebrow = 'Argopuro · Jember, East Java · 1859';
const beat1Body =
  'Mariposa is hand-rolled in Jember, East Java. A region whose rich cigar-making heritage dates back to 1859. It is also home to Pak Abdul Kahar Muzakir, a cigar aficionado and industry veteran who has dedicated his life to a singular pursuit: capturing the essence of Cuban tradition by cultivating Havana seeds in Indonesian soil.';

const beat2Eyebrow = 'Twenty years · Volcanic earth';
const beat2Body =
  'The wrapper, binder, and filler are all born from Havana-seed tobacco that has spent nearly two decades acclimatizing to Jember’s volcanic earth. The result is a perfect marriage of flavor profiles, blending the distinct spice and oiliness of Cuban genetics with Java’s native earthy sweetness.';

const beat3Eyebrow = 'Patience · Three years';
const beat3Body =
  'Patience is central to the craft. In keeping with the strict standards of Cuba’s escogida, each leaf type is meticulously sorted and fermented for 24 months, then rested for another twelve. That is nearly three years from leaf to finished cigar, a slow maturation that yields rich flavors and an undeniably smooth smoke.';

const beat4Eyebrow = 'The workshop · By hand';
const beat4Body =
  'Mariposa cigars are entirely hand-rolled by a dedicated team of female rollers, mirroring Cuba’s revered torcedoras, many of whom come from families that have worked tobacco for generations. Using premium long-filler, three-part construction, and entubado bunching for a perfectly even draw, each cigar is finished with a classic Cuban triple cap. Every single stick is draw-tested and inspected by hand before it leaves the workshop, guaranteeing a flawless smoking experience.';

/* ─── Founder copy — verbatim. Three uniform paragraphs.
       The Havana-seed sentence is LIFTED from paragraph 3 of the
       live /about and rendered as the closing pull quote — it does
       NOT appear in the body paragraphs. */

const storyParas = [
  'Mariposa’s story begins with a journey. Driven by a lifelong taste for cigars, founder Stephane Zermatten followed his curiosity to the tobacco fields of East Java.',
  'What he discovered inspired him to craft a blend for his own humidor and closest friends. Yet, as word spread and a wider circle grew curious, he knew it couldn’t remain a private reserve. The brand was born to bring this unique cigar to a growing community in Bali and beyond.',
  'Today, Mariposa captures the rich, multi-cultural soul of cigars, giving friends around the world the perfect excuse to light up, slow down, and share a good conversation. Whatever the hour.',
];
const pullQuote =
  'A Havana-seed smoke, adorned in gold leaf, for the people who don’t wait for special occasions, but create them.';

/* ─── Standfirst placeholders. Per brief §6 gap 3: ship with
       placeholder italic decks so Stephane can react; Axel passes
       once direction is signed off. */
const mastheadStandfirst =
  'Four beats from a volcanic range in East Java — land, leaf, time, and the workshop where Cuba’s craft is kept by hand.';
const founderStandfirst =
  'The founder of Mariposa, on the curiosity that became a humidor and then a brand.';

/* ─── Placeholder captions (un-commissioned beats) ─────────── */
const capBeat2 =
  'PLACEHOLDER: Havana-seed nursery — leaf detail or tobacco on volcanic soil. Square, ~1:1, half-column inset.';
const capBeat4 =
  'PLACEHOLDER: Jember rolling room — torcedoras at work, hands and leaf. Landscape, full-bleed ~70vh. The credibility shot, saved for the close.';

const placeholderNote = 'Placeholder atmosphere — final shot to be commissioned';
---

<BaseLayout title="Mariposa • About — Editorial mock (Option A)">

  {/* ════════════════════════════════════════════════════════════
      Discreet mock ribbon — tells Stephane what he is looking at.
      Not part of the editorial. Same pattern as /about-mocks.
      ════════════════════════════════════════════════════════════ */}
  <section class="mock-ribbon" aria-label="Mock context">
    <div class="container">
      <p class="mock-ribbon__eyebrow">About &mdash; Editorial Mock (Option A: Issue masthead)</p>
      <p class="mock-ribbon__note">
        Pax&rsquo;s recommended direction from <em>about-editorial-research.md</em>. Numbered
        beats, one pull quote, founder as the closing feature. The live <code>/about</code>
        page is unchanged.
      </p>
    </div>
  </section>

  <article class="about-ed">

    {/* ── Issue masthead ─────────────────────────────────────── */}
    <header class="about-ed__masthead" data-reveal>
      <p class="about-ed__masthead-eyebrow">The Origins Issue &middot; Mariposa &middot; 01</p>
      <h1 class="about-ed__masthead-headline">Where Indonesia learned to roll cigars.</h1>
      <p class="about-ed__masthead-standfirst">{mastheadStandfirst}</p>
      <span class="about-ed__masthead-rule" aria-hidden="true"></span>
    </header>

    {/* ── Beat I — Argopuro. Column-width landscape, drop cap. ── */}
    <section class="about-ed__beat" aria-label="I. Argopuro" data-reveal>
      <p class="about-ed__numeral" aria-hidden="true">I.</p>
      <p class="about-ed__beat-eyebrow">{beat1Eyebrow}</p>
      <p class="about-ed__body about-ed__body--dropcap">{beat1Body}</p>
      <figure class="about-ed__figure about-ed__figure--column">
        <Image
          src={beat1Atmosphere}
          alt="Atmospheric placeholder standing in for the Argopuro range, East Java — final shot to be commissioned."
          class="about-ed__img"
          widths={[720, 1080, 1440, 1800]}
          sizes="(max-width: 720px) 100vw, 720px"
          loading="eager"
        />
        <p class="about-ed__placeholder-note">{placeholderNote}</p>
        <figcaption class="about-ed__caption">Argopuro range, East Java.</figcaption>
      </figure>
    </section>

    {/* ── Beat II — Twenty years. Half-column inset placeholder. ── */}
    <section class="about-ed__beat about-ed__beat--inset" aria-label="II. Twenty years" data-reveal>
      <p class="about-ed__numeral" aria-hidden="true">II.</p>
      <p class="about-ed__beat-eyebrow">{beat2Eyebrow}</p>
      <figure class="about-ed__figure about-ed__figure--inset placeholder placeholder--1x1" aria-label="Volcanic-earth / seed placeholder">
        <span class="placeholder__corner placeholder__corner--tl" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--tr" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--bl" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--br" aria-hidden="true"></span>
        <figcaption class="placeholder__caption">{capBeat2}</figcaption>
      </figure>
      <p class="about-ed__body">{beat2Body}</p>
      <p class="about-ed__caption about-ed__caption--inset">Havana-seed leaf, Jember nursery.</p>
    </section>

    {/* ── Beat III — Patience. Column-width 3:2 landscape. ────── */}
    <section class="about-ed__beat" aria-label="III. Patience" data-reveal>
      <p class="about-ed__numeral" aria-hidden="true">III.</p>
      <p class="about-ed__beat-eyebrow">{beat3Eyebrow}</p>
      <p class="about-ed__body">{beat3Body}</p>
      <figure class="about-ed__figure about-ed__figure--column">
        <Image
          src={beat3Atmosphere}
          alt="Atmospheric placeholder standing in for the escogida / ageing-room shot — final shot to be commissioned."
          class="about-ed__img"
          widths={[720, 1080, 1440, 1800]}
          sizes="(max-width: 720px) 100vw, 720px"
        />
        <p class="about-ed__placeholder-note">{placeholderNote}</p>
        <figcaption class="about-ed__caption">Escogida fermentation &mdash; month 4 / month 22.</figcaption>
      </figure>
    </section>

    {/* ── Beat IV — The workshop. Full-bleed ~70vh placeholder. ── */}
    <section class="about-ed__beat about-ed__beat--bleed" aria-label="IV. The workshop" data-reveal>
      <p class="about-ed__numeral" aria-hidden="true">IV.</p>
      <p class="about-ed__beat-eyebrow">{beat4Eyebrow}</p>
      <p class="about-ed__body">{beat4Body}</p>
      <figure class="about-ed__figure--bleed placeholder placeholder--bleed" aria-label="Jember rolling-room placeholder (full-bleed)">
        <span class="placeholder__corner placeholder__corner--tl" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--tr" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--bl" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--br" aria-hidden="true"></span>
        <figcaption class="placeholder__caption">{capBeat4}</figcaption>
      </figure>
      <p class="about-ed__caption about-ed__caption--bleed">Photograph: [Name] &mdash; Jember rolling room, 2026.</p>
    </section>

    {/* ── Origins → Founder transition. Quiet hairline + eyebrow.
           No display text. ──────────────────────────────────── */}
    <div class="about-ed__transition" data-reveal>
      <span class="about-ed__transition-rule" aria-hidden="true"></span>
      <p class="about-ed__transition-eyebrow">The Founder &middot; A Feature</p>
    </div>

    {/* ── Founder feature. Three uniform paragraphs, half-column
           portrait before paragraph 1, pull quote at the close. ── */}
    <section class="about-ed__feature" aria-label="The Founder" data-reveal>
      <h2 class="about-ed__feature-headline">Stephane Zermatten.</h2>
      <p class="about-ed__feature-standfirst">{founderStandfirst}</p>

      <figure class="about-ed__feature-figure">
        <Image
          src={szSmoking}
          alt="Portrait of founder Stephane Zermatten lighting a Mariposa cigar."
          class="about-ed__feature-img"
          widths={[360, 540, 720, 960]}
          sizes="(max-width: 720px) 100vw, 320px"
          loading="lazy"
        />
        <figcaption class="about-ed__caption about-ed__caption--feature">
          Stephane Zermatten &middot; Jember, East Java.
        </figcaption>
      </figure>

      <p class="about-ed__feature-body">{storyParas[0]}</p>
      <p class="about-ed__feature-body">{storyParas[1]}</p>
      <p class="about-ed__feature-body">{storyParas[2]}</p>

      <blockquote class="about-ed__pullquote" data-reveal>
        <p>{pullQuote}</p>
      </blockquote>
    </section>

  </article>

</BaseLayout>

<script>
  import { reveal, refreshOnLoad } from '../lib/motion';
  const blocks = document.querySelectorAll('[data-reveal]');
  blocks.forEach((b) => reveal(b));
  refreshOnLoad();
</script>

<style>
  /* ═══════════════════════════════════════════════════════════
     Mock ribbon — discreet "you are looking at a mock" banner.
     Same dark-ground / gold-eyebrow grammar as /about-mocks
     label blocks, but pared down because there is only one
     option to label here.
     ═══════════════════════════════════════════════════════════ */
  .mock-ribbon {
    background: var(--ink);
    color: var(--pearl);
    padding-block: var(--space-5);
  }
  .mock-ribbon__eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-section);
    color: var(--gold-leaf);
    margin: 0 0 var(--space-2) 0;
  }
  .mock-ribbon__note {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    color: var(--pearl);
    margin: 0;
    max-width: 78ch;
  }
  .mock-ribbon__note code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.92em;
  }

  /* ═══════════════════════════════════════════════════════════
     Article shell. White ground throughout (Section 5
     implementation note: avoid pearl/white alternation;
     uniformity of ground is part of the editorial logic).
     ═══════════════════════════════════════════════════════════ */
  .about-ed {
    background: var(--white);
    color: var(--ink);
    /* Single centred article column. Masthead, transition, and
       full-bleed figures break out wider; everything else lives
       at this measure. */
    --col: 720px;
  }
  .about-ed > .about-ed__masthead,
  .about-ed > .about-ed__beat,
  .about-ed > .about-ed__transition,
  .about-ed > .about-ed__feature {
    width: 100%;
    max-width: var(--col);
    margin-inline: auto;
    padding-inline: var(--page-pad-d);
    box-sizing: content-box;
  }

  /* ═══════════════════════════════════════════════════════════
     Masthead — issue eyebrow, display headline, standfirst,
     gold-leaf hairline.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__masthead {
    text-align: center;
    padding-block: clamp(var(--space-9), 12vw, var(--space-10));
  }
  .about-ed__masthead-eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-section);
    color: var(--gold-deep);
    margin: 0 0 var(--space-6) 0;
  }
  .about-ed__masthead-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: var(--lh-tight);
    color: var(--ink);
    margin: 0 auto var(--space-6) auto;
    max-width: 18ch;
    letter-spacing: var(--ls-display);
  }
  .about-ed__masthead-standfirst {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    margin: 0 auto var(--space-7) auto;
    max-width: 56ch;
  }
  .about-ed__masthead-rule {
    display: block;
    width: 80px;
    height: 1px;
    background: var(--gold-leaf);
    margin: 0 auto;
  }

  /* ═══════════════════════════════════════════════════════════
     Beats — single centred article column. Each beat opens with
     a Spectral italic numeral (I., II., III., IV.) anchored on
     its own line, then a Hanken caps eyebrow, then body. Figure
     placement varies by beat per Pax's spec.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__beat {
    padding-block: clamp(var(--space-8), 9vw, var(--space-9));
  }
  .about-ed__numeral {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3.5rem, 6vw, 5rem);
    line-height: 1;
    color: var(--gold-deep);
    margin: 0 0 var(--space-3) 0;
    letter-spacing: var(--ls-display);
  }
  .about-ed__beat-eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-section);
    color: var(--gold-deep);
    margin: 0 0 var(--space-6) 0;
  }
  .about-ed__body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0;
  }
  /* Drop cap — single instance, on beat I paragraph only. */
  .about-ed__body--dropcap::first-letter {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--gold-deep);
    font-size: clamp(3.5rem, 6vw, 4.5rem);
    line-height: 0.85;
    float: left;
    padding-right: var(--space-3);
    padding-top: 0.08em;
  }

  /* ═══════════════════════════════════════════════════════════
     Figures.
       --column : sits at article-column width below the body.
       --inset  : half-column, floated right, lives inside beat II.
       --bleed  : full-bleed ~70vh, used at beat IV (the article's
                  photographic peak).
     ═══════════════════════════════════════════════════════════ */
  .about-ed__figure {
    margin: var(--space-7) 0 0 0;
  }
  .about-ed__figure--column {
    position: relative;
  }
  .about-ed__figure--column .about-ed__img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--pearl);
  }
  /* Beat III leans slightly taller — 3:2 per Pax's spec. */
  .about-ed__beat:nth-of-type(3) .about-ed__figure--column .about-ed__img {
    aspect-ratio: 3 / 2;
  }

  /* Inset figure — beat II. The placeholder lives at half-column
     width, floated right of the body paragraph. */
  .about-ed__beat--inset {
    /* The figure floats; the body paragraph wraps to its left.
       Numeral + eyebrow sit above as block elements. */
  }
  .about-ed__figure--inset {
    float: right;
    width: min(48%, 320px);
    margin: var(--space-2) 0 var(--space-5) var(--space-6);
    aspect-ratio: 1 / 1;
  }
  .about-ed__caption--inset {
    clear: both;
    margin-top: var(--space-4);
    text-align: right;
  }

  /* Captions — italic Hanken, gold-deep, var(--fs-small). */
  .about-ed__caption {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-style: italic;
    letter-spacing: var(--ls-small);
    color: var(--gold-deep);
    margin: var(--space-3) 0 0 0;
  }

  /* Placeholder note overlay — same convention as live /about. */
  .about-ed__placeholder-note {
    position: absolute;
    top: clamp(var(--space-3), 2vw, var(--space-4));
    left: clamp(var(--space-3), 2vw, var(--space-4));
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-leaf);
    background: color-mix(in srgb, var(--ink) 55%, transparent);
    padding: 4px 10px;
    margin: 0;
    max-width: 28ch;
    z-index: 2;
  }

  /* ═══════════════════════════════════════════════════════════
     Beat IV — full-bleed ~70vh placeholder. The article's
     photographic peak, saved for the close. The body paragraph
     still lives in the article column above; the figure breaks
     out to viewport edges below.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__beat--bleed {
    /* The bleed figure breaks out of the article column. The
       beat's numeral, eyebrow, body, and post-bleed caption all
       sit at column width via the parent rule; the figure itself
       overrides max-width below. */
  }
  .about-ed__figure--bleed {
    width: 100vw;
    position: relative;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: var(--space-7);
    margin-bottom: 0;
    height: 70vh;
    min-height: 480px;
    aspect-ratio: auto;
    /* Override .placeholder padding so the figure fills the bleed. */
    padding: clamp(var(--space-6), 5vw, var(--space-8));
  }
  .about-ed__caption--bleed {
    margin-top: var(--space-4);
    text-align: center;
  }

  /* ═══════════════════════════════════════════════════════════
     Origins → Founder transition. Quiet. Thin grey hairline,
     centred Hanken eyebrow. No display text — that belongs to
     the feature itself.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__transition {
    text-align: center;
    padding-block: clamp(var(--space-8), 10vw, var(--space-9));
  }
  .about-ed__transition-rule {
    display: block;
    width: 100px;
    height: 1px;
    background: var(--hairline);
    margin: 0 auto var(--space-6) auto;
  }
  .about-ed__transition-eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-section);
    color: var(--gold-deep);
    margin: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     Founder feature. Display headline → standfirst →
     half-column inset portrait → three UNIFORM Hanken-body
     paragraphs → closing pull quote.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__feature {
    padding-block: clamp(var(--space-7), 8vw, var(--space-9)) clamp(var(--space-9), 12vw, var(--space-10));
  }
  .about-ed__feature-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: var(--lh-tight);
    color: var(--ink);
    margin: 0 0 var(--space-5) 0;
    letter-spacing: var(--ls-display);
  }
  .about-ed__feature-standfirst {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    margin: 0 0 var(--space-7) 0;
    max-width: 56ch;
  }
  .about-ed__feature-figure {
    float: right;
    width: min(48%, 320px);
    margin: var(--space-1) 0 var(--space-5) var(--space-6);
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .about-ed__feature-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .about-ed__caption--feature {
    margin-top: var(--space-3);
    text-align: left;
  }
  /* Three uniform paragraphs. No italic lede. No drop cap.
     Identical typography on all three. */
  .about-ed__feature-body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0 0 var(--space-5) 0;
  }
  .about-ed__feature-body:last-of-type {
    margin-bottom: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     Pull quote — the page's closing line. Spectral italic,
     gold-deep, centred, gold-leaf hairlines top and bottom.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__pullquote {
    clear: both;
    margin: var(--space-8) auto 0 auto;
    max-width: 840px;
    padding: var(--space-7) 0;
    border-top: 1px solid var(--gold-leaf);
    border-bottom: 1px solid var(--gold-leaf);
    text-align: center;
  }
  .about-ed__pullquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    line-height: var(--lh-snug);
    color: var(--gold-deep);
    margin: 0 auto;
    max-width: 32ch;
  }

  /* ═══════════════════════════════════════════════════════════
