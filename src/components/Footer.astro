---
/* Shared footer. Wordmark, brand line, copyright.
   Contact channels handled by the sticky contact element.
   21+ requirement handled by the age gate at entry.
   No legal-entity line (resolved decision 5). */
import { getEntry } from 'astro:content';

const global = (await getEntry('site', 'global'))!.data as {
  footer: { brandLine: string; copyright: string };
};
const { footer } = global;

/* Deterministic break: "Create them." always lands on its own line,
   regardless of viewport width. Split on the final sentence break so
   the content config stays a single string. */
const brandParts = footer.brandLine.split(/\.\s+(?=[^.]+\.?$)/);
const brandLead = brandParts.length > 1 ? `${brandParts[0]}.` : footer.brandLine;
const brandTail = brandParts.length > 1 ? brandParts.slice(1).join('. ') : '';
---

<footer class="site-footer grain" data-footer>
  <div class="site-footer__inner container">
    <p class="site-footer__brandline" data-footer-brandline>
      <span class="site-footer__brandline-lead">{brandLead}</span>
      {brandTail && <span class="site-footer__brandline-tail">{brandTail}</span>}
    </p>

    <hr class="rule-gold site-footer__rule" />

    <div class="site-footer__bottom">
      <span class="wordmark site-footer__mark">mariposa</span>
      <p class="site-footer__copyright">{footer.copyright}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-rhythm: var(--space-7); /* 48px — single vertical unit */
    background: var(--bg-elevated);
    border-top: 1px solid var(--border-gold);
  }

  .site-footer__inner {
    padding-block: var(--footer-rhythm);
    position: relative;
  }

  .site-footer__brandline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    /* Fluid: 18px at ~320px viewport, scales to 28px desktop ceiling.
       Floor chosen so the lead sentence (33ch) fits in the 272px
       content width at narrowest target without wrapping. */
    font-size: clamp(18px, 5.6vw, var(--fs-h4));
    line-height: var(--lh-snug);
    color: var(--ink);
    margin: 0;
  }
  .site-footer__brandline-lead,
  .site-footer__brandline-tail {
    display: block;
    white-space: nowrap;
  }

  .site-footer__rule {
    margin-block: var(--footer-rhythm);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-7);
    flex-wrap: wrap;
  }

  .site-footer__mark {
    font-size: 1rem;
    color: var(--gold-deep);
  }

  .site-footer__copyright {
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    color: var(--ash);
    margin: 0;
    text-align: right;
  }

  @media (max-width: 720px) {
    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
    .site-footer__copyright {
      text-align: left;
    }
  }
</style>

<script>
  /* The brand line reveals on scroll-in so the footer is part of the
     page's choreography, not a static stop. */
  import { reveal } from '../lib/motion';
  const brandline = document.querySelector('[data-footer-brandline]');
  if (brandline) reveal(brandline, { y: 22, duration: 0.9, start: 'top 92%' });
</script>
