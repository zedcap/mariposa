---
/* Home — one-page vertical scroll.
   Hero slider, product section (Option B), lifestyle section.
   The hero goes into BaseLayout's named `hero` slot, so the nav rests
   directly below it on load and sticks to the top on scroll
   (marigold.global pattern). Copy comes from content collections. */
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import ProductSlider from '../components/ProductSlider.astro';
import LifestyleSection from '../components/LifestyleSection.astro';

const global = (await getEntry('site', 'global'))!.data as {
  positionLine: string;
};
const home = (await getEntry('site', 'home'))!.data as {
  hero: {
    subline: string;
    scrollCue: string;
    slides: { key: string; caption: string }[];
  };
  productSection: { eyebrow: string; heading: string };
  lifestyle: {
    eyebrow: string;
    paragraphs: string[];
    closingLine: string;
    aboutLinkLabel: string;
  };
};

const products = (await getCollection('products'))
  .map((entry) => entry.data)
  .sort((a, b) => a.order - b.order);
---

<BaseLayout title="Mariposa — Cuban Soul. 24 Carat Swiss Gold.">
  <HeroSlider
    slot="hero"
    positionLine={global.positionLine}
    subline={home.hero.subline}
    scrollCue={home.hero.scrollCue}
    slides={home.hero.slides}
  />

  <ProductSlider
    eyebrow={home.productSection.eyebrow}
    heading={home.productSection.heading}
    products={products}
  />

  <LifestyleSection
    eyebrow={home.lifestyle.eyebrow}
    paragraphs={home.lifestyle.paragraphs}
    closingLine={home.lifestyle.closingLine}
    aboutLinkLabel={home.lifestyle.aboutLinkLabel}
  />
</BaseLayout>
