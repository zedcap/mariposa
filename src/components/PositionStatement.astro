---
/* Home position statement — the brand's opening line on the page.
   ------------------------------------------------------------------
   REBUILD (2026-05-21). The first cut centred a small italic line in a
   tidy block — correct, restrained, and exactly the wrong energy. This
   rebuild gives the statement room and weight: a tall section the line
   commands, the position sentence at display scale, revealed line by
   line through clipping masks as the section enters, and a slow gold
   hairline that draws itself in. The Marigold text-animation move,
   applied to the brand's defining sentence.

   Treatment per the conventions overlay: "Cuban Soul." pink, the rest
   ink, both halves display italic, wrapping naturally — not locked to
   one line. The sub-line follows, quieter. */
interface Props {
  /** Brand position copy split into the pink half and the ink half. */
  positionPink: string;
  positionInk: string;
  subline: string;
}
const { positionPink, positionInk, subline } = Astro.props;
---

<section class="position" aria-label="Mariposa" data-position>
  <div class="position__inner container">
    {/* The position sentence. Each half is wrapped in a clipping mask;
        the inner line slides up from below the mask edge on entry —
        the Marigold masked-headline reveal. */}
    <h2 class="position__line">
      <span class="motion-mask">
        <span class="motion-line position__em">{positionPink}</span>
      </span>
      {' '}
      <span class="motion-mask">
        <span class="motion-line position__ink">{positionInk}</span>
      </span>
    </h2>

    <p class="position__subline" data-position-subline>{subline}</p>
  </div>
</section>

<style>
  .position {
    background: var(--white);
    /* A tall section — the statement is given room to be the only thing
       in the viewport when it lands. */
    min-height: 86svh;
    display: grid;
    place-items: center;
    padding-block: clamp(var(--space-9), 14vw, var(--space-10));
  }

  .position__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Position sentence — display italic, wraps naturally.
     The conventions overlay forbids locking it to one line. */
  .position__line {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.9rem, 4.8vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: var(--ls-display);
    margin: 0;
    max-width: 18ch;
  }
  .position__em {
    color: var(--pink);
  }
  .position__ink {
    color: var(--ink);
  }

  /* Masked reveal — each half of the sentence lives in a clipping box.
     The box is padded top/bottom (and pulled back by an equal negative
     margin) so the italic's ascenders and descenders have room at
     rest; only the slide-up travel is clipped, never the glyph. A
     touch of x-padding clears the italic overshoot. */
  .motion-mask {
    display: inline-block;
    overflow: hidden;
    padding: 0.16em 0.06em;
    margin: -0.16em -0.06em;
    vertical-align: bottom;
  }
  .motion-line {
    display: inline-block;
    /* JS sets the entry transform. Without JS the line is simply in
       place — no flash of clipped content. */
  }

  .position__subline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.35rem, 2.8vw, 1.75rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    margin-top: var(--space-7);
    max-width: 34ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .position { min-height: 0; }
  }
</style>

<script>
  import { revealLines, reveal } from '../lib/motion';

  const section = document.querySelector<HTMLElement>('[data-position]');
  if (section) {
    const masks = section.querySelectorAll('.motion-mask');
    const subline = section.querySelector<HTMLElement>('[data-position-subline]');

    // The sentence unveils line by line through the masks.
    revealLines(masks, { start: 'top 78%', stagger: 0.14 });

    // Sub-line settles in last.
    if (subline) reveal(subline, { y: 18, duration: 0.8, delay: 0.15, start: 'top 72%' });
  }
</script>
