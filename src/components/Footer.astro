---
/* Shared footer. Wordmark, brand line, copyright + Terms trigger.
   Contact channels handled by the sticky contact element.
   21+ requirement handled by the age gate at entry.
   No legal-entity line (resolved decision 5).

   The copyright reads as one continuous sentence: a static lead
   ("© 2026 Mariposa.") followed by a trigger phrase ("Terms &
   Conditions.") that opens the TermsModal via the
   `mariposa:open-terms` custom event. The trigger is a
   <button> styled to read as inline text — same register as the
   surrounding copyright, only the hover underline marks it as
   interactive. The modal is rendered site-wide by BaseLayout. */
import { getEntry } from 'astro:content';

const global = (await getEntry('site', 'global'))!.data as {
  footer: { brandLine: string; copyrightLead: string; termsLabel: string };
};
const { footer } = global;
---

<footer class="site-footer grain" data-footer>
  <div class="site-footer__inner container">
    <p class="site-footer__brandline" data-footer-brandline>{footer.brandLine}</p>

    <hr class="rule-gold site-footer__rule" />

    <div class="site-footer__bottom">
      <span class="wordmark site-footer__mark">mariposa</span>
      <p class="site-footer__copyright">
        {footer.copyrightLead}{' '}
        <button class="site-footer__terms" type="button" data-terms-open>{footer.termsLabel}</button>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-rhythm: var(--space-7); /* 48px — single vertical unit */
    background: var(--bg-elevated);
    border-top: 1px solid var(--border-gold);
  }

  .site-footer__inner {
    padding-block: var(--footer-rhythm);
    /* Top breathing room doubled (Stephane 2026-05-24): the gap above
       the brand line — "For those who don't wait for special occasions,
       but create them." — opens to 2× --footer-rhythm so the line sits
       further off the section above. Bottom padding stays on the base
       --footer-rhythm so the rhythm below the rule is unchanged. */
    padding-top: calc(var(--footer-rhythm) * 2);
    position: relative;
  }

  .site-footer__brandline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    /* Single-line at all viewports. The 64-char sentence has to hold
       inside the 272px mobile content well (320px viewport − 2 × 24px
       page padding). Italic Cormorant runs ~0.45em average advance,
       so the ceiling at 320px is ~9.4px — floor set to 10px and the
       vw middle (2.8vw → 8.96px at 320px) lets the floor bind there.
       Scales back to --fs-h6 (18px) on desktop. */
    font-size: clamp(10px, 2.8vw, var(--fs-h6));
    line-height: var(--lh-snug);
    color: var(--ink);
    margin: 0;
    white-space: nowrap;
  }

  .site-footer__rule {
    /* Halved gap above and below the divider per Stephane 2026-05-23.
       --footer-rhythm (48px) stays on the section padding and the
       brand-line / bottom rhythm; the divider alone gets the tighter
       block margin. */
    margin-block: var(--space-5);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-7);
    flex-wrap: wrap;
  }

  .site-footer__mark {
    font-size: 1rem;
    color: var(--gold-deep);
  }

  .site-footer__copyright {
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    color: var(--ash);
    margin: 0;
    text-align: right;
  }

  /* Inline Terms trigger — same register as the copyright text, no
     decoration at rest; hover lifts colour and reveals a hairline
     underline. The phrase "Terms & Conditions." sits inside the
     copyright sentence as the inline trigger. <button> is reset
     to read as text so the sentence flows uninterrupted. */
  .site-footer__terms {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    padding: 0 0 1px;
    margin: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      color var(--dur-default) var(--ease-paper),
      border-color var(--dur-default) var(--ease-paper);
  }
  .site-footer__terms:hover,
  .site-footer__terms:focus-visible {
    color: var(--ink);
    border-bottom-color: var(--gold);
    outline: none;
  }

  @media (max-width: 720px) {
    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      /* Stack gap reverts to the desktop --space-7 (48px) — Stephane
         2026-05-24 reversed the prior tighten pass; the wordmark and
         copyright should keep the section's standard vertical unit
         even when stacked. */
    }
    /* Brand line one step up on mobile (Stephane 2026-05-24): the
       single-line clamp above was binding to its 10px floor on the
       narrowest viewports, reading too small. To step up cleanly we
       drop the single-line constraint on mobile and let the sentence
       wrap; the floor lifts to 13px (--fs-caption), slope to 3.6vw,
       ceiling to --fs-h6 (18px). Wraps to two lines at 320px-360px,
       single line above ~480px. Desktop unchanged: this rule only
       applies under 720px; the desktop clamp and white-space:nowrap
       above are untouched. */
    .site-footer__brandline {
      font-size: clamp(13px, 3.6vw, var(--fs-h6));
      white-space: normal;
    }
    .site-footer__copyright {
      text-align: left;
      /* Step down two sizes (Stephane 2026-05-24): --fs-caption (13px)
         → --fs-eyebrow (12px) → 11px. No named token below --fs-eyebrow;
         literal 11px is the micro-fine-print step. Desktop unchanged. */
      font-size: 11px;
    }
  }
</style>

<script>
  /* The brand line reveals on scroll-in so the footer is part of the
     page's choreography, not a static stop. */
  import { reveal } from '../lib/motion';
  const brandline = document.querySelector('[data-footer-brandline]');
  if (brandline) reveal(brandline, { y: 22, duration: 0.9, start: 'top 92%' });

  /* Open TermsModal on click. The modal returns focus to the opener
     element on close, so we pass `this` through the event detail. */
  const termsBtn = document.querySelector<HTMLButtonElement>('[data-terms-open]');
  termsBtn?.addEventListener('click', () => {
    window.dispatchEvent(
      new CustomEvent('mariposa:open-terms', { detail: { opener: termsBtn } })
    );
  });
</script>
