---
/* Volage product page — restructured 2026-05-24.
   ------------------------------------------------------------------
   Header replaced with Option A (tagline-led) from
   volage-header-research.md, Part 3 — Pax's recommended pick.
   Same-day pass also removed the SignatureBlock invocation and
   the Caprice cross-link section. The page now sequences:

     1. Hero            — Option A. Pearl ground, 62/38 split,
                          tagline as protagonist on a 22ch
                          measure, "Volage" as a quiet signature
                          beneath. cigar-volage.png with a soft
                          drop shadow, no frame.
     2. The cigar       — narrative + PROFILE / BLEND specs.
     3. The smoke arc   — tasting thirds on a sticky timeline.
     4. Presentation    — three-up packaging gallery (placeholders).

   The SignatureBlock import and invocation were dropped; the
   component file remains on disk for possible reuse. The Caprice
   cross-link markup + CSS + reveal were removed; the page now
   terminates at Presentation and runs straight into the footer.

   Background flow (top to bottom): pearl (hero) → white (cigar) →
   white (smoke arc, component-owned) → pearl (presentation) →
   footer. Two pearl beds at the two compositional pauses, white
   in between for reading. The earlier cream #f2f0e9 crosslink
   bed went with the section it served.

   Motion: rise-and-fade reveals via the shared helper. Hero
   uses the Option A cascade — eyebrow → rule (drawing
   left-to-right) → tagline → signature, with the cigar
   fading and scaling alongside. */

import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SmokeArc from '../components/SmokeArc.astro';
import cigarVolage from '../assets/cigar-volage.png';

const product = (await getEntry('products', 'volage'))!.data;
---

<BaseLayout title={`Mariposa • ${product.name}`}>
  {/* ─── 1. Hero — Option A, signature-above-tagline ──────────
       Source + visual order now match (Stephane 2026-05-24):
         eyebrow (Canonazo only) → hairline → signature (Volage) →
         tagline.
       The earlier flex `order` flip is retired — <h1>Volage</h1>
       sits above the tagline in both the DOM and on screen. The
       eyebrow drops the edition + middle-dot; vitola alone. */}
  <section class="hero" data-reveal-section>
    <div class="hero__inner container">
      <div class="hero__copy" data-reveal-copy>
        <p class="hero__eyebrow">{product.vitola}</p>
        <span class="hero__rule" aria-hidden="true"></span>
        <h1 class="hero__signature">{product.name}</h1>
        <p class="hero__tagline">{product.tagline}</p>
      </div>

      <div class="hero__media" data-reveal-media>
        <Image
          class="hero__cigar"
          src={cigarVolage}
          alt={`The Mariposa ${product.name} cigar, ${product.tagline.toLowerCase()}`}
          widths={[260, 420, 640, 860]}
          sizes="(max-width: 720px) 65vw, 30vw"
          loading="eager"
        />
      </div>
    </div>
  </section>

  {/* ─── 2. The cigar — narrative + full specs ───────────────── */}
  <section class="cigar" aria-labelledby="cigar-heading" data-reveal-section>
    <div class="cigar__inner container">
      <p class="eyebrow cigar__eyebrow" id="cigar-heading">The cigar</p>

      {/* Narrative — four paragraphs in two treatments (Stephane
          2026-05-24). The first entry of `narrative` reads as a
          punchier body-font intro (Hanken Grotesk, regular, body
          register); paragraphs 2-4 carry the italic Spectral
          treatment matching .cigar__para. Treatment is decided
          here, not in JSON — keeps the schema flat and the
          first-paragraph-is-intro rule explicit at the render
          site. Paragraph rhythm is shared (--space-5 between any
          two), so the intro reads as part of the same beat
          rather than a separate block. */}
      <div class="cigar__narrative">
        {product.narrative.map((para, i) => (
          <p
            class={i === 0 ? 'cigar__intro' : 'cigar__para'}
            data-reveal-para
          >
            {para}
          </p>
        ))}
      </div>

      {/* Spec list — split into two blocks of six (Stephane review
          2026-05-24). Block 1 = the headline-grade specs (Vitola,
          Strength, Format, Origin, Smoke time, Release). Block 2 =
          the leaf/build/time specs (Wrapper, Binder, Filler,
          Construction, Fermentation, Ageing). Each block gets its
          own full-width gold rule on top via the .cigar__strip
          border-top; per-row bottom rules are kept for readability.
          JSON order is row-by-row interleaved (left then right per
          row) to match CSS Grid's default auto-flow:row fill. */}
      <p class="cigar__strip-title" data-reveal-strip>Profile</p>
      <dl class="cigar__strip" data-reveal-strip>
        {product.specs.slice(0, 6).map((row) => (
          <div class="cigar__strip-row">
            <dt class="cigar__strip-label">{row.label}</dt>
            <dd class="cigar__strip-value">{row.value}</dd>
          </div>
        ))}
      </dl>
      <p class="cigar__strip-title cigar__strip-title--second" data-reveal-strip>Blend</p>
      <dl class="cigar__strip cigar__strip--second" data-reveal-strip>
        {product.specs.slice(6).map((row) => (
          <div class="cigar__strip-row">
            <dt class="cigar__strip-label">{row.label}</dt>
            <dd class="cigar__strip-value">{row.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  {/* ─── 3. The smoke arc ────────────────────────────────────── */}
  <SmokeArc tasting={product.tasting} />

  {/* ─── 4. Presentation — static gallery ────────────────────── */}
  {product.packaging && product.packaging.length > 0 && (
    <section class="packaging" aria-labelledby="packaging-heading" data-reveal-section>
      <div class="packaging__inner container">
        <p class="eyebrow packaging__eyebrow" id="packaging-heading">Presentation</p>
        <p class="packaging__lede">
          Presented as a single cigar, the gold leaf set against the
          band and the postcard tucked alongside.
        </p>
        <div class="packaging__grid">
          {product.packaging.map((slot, i) => (
            <figure class="placeholder placeholder--square" aria-label={slot.placeholderCaption ?? `Packaging placeholder ${i + 1}`} data-reveal-pack>
              <span class="placeholder__corner placeholder__corner--tl" aria-hidden="true"></span>
              <span class="placeholder__corner placeholder__corner--tr" aria-hidden="true"></span>
              <span class="placeholder__corner placeholder__corner--bl" aria-hidden="true"></span>
              <span class="placeholder__corner placeholder__corner--br" aria-hidden="true"></span>
              <figcaption class="placeholder__caption">
                {slot.placeholderCaption ?? 'PLACEHOLDER: packaging shot required.'}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ── Shared section rhythm ─────────────────────────────────── */
  section[data-reveal-section] {
    padding-block: clamp(var(--space-7), 7vw, var(--space-9));
  }

  /* ── 1. Hero — Option A, tagline-led ───────────────────────
     Pearl ground, constrained to the container (not full-bleed).
     62/38 split at desktop: type left, image right. The tagline
     is the loudest element on the page; "Volage" sits beneath as
     a quiet signature. Source-order keeps <h1>Volage</h1> first;
     flex `order` flips the visual sequence to:
       eyebrow → rule → tagline → signature (Volage). */
  .hero {
    background: var(--pearl);
    /* Commit the viewport on entry, per Option A spec (88–95vh).
       Override the shared section rhythm to land on the min-height
       move rather than padding alone. */
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding-block: clamp(var(--space-8), 10vw, var(--space-10));
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 62fr 38fr;
    gap: clamp(var(--space-7), 7vw, var(--space-10));
    align-items: center;
    width: 100%;
  }

  /* Copy column — source order matches visual order
     (eyebrow → rule → signature → tagline). The earlier flex
     `order` choreography was retired when the signature moved
     above the tagline. */
  .hero__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0 0 var(--space-5) 0;
  }
  .hero__rule {
    display: block;
    width: 120px;
    height: 1px;
    background: var(--gold-leaf);
    margin: 0 0 var(--space-6) 0;
    /* Drawn-in entry: starts at scaleX(0); the rule's tween in the
       script below scales it to 1 left-to-right shortly after the
       copy column enters. Resting state for prefers-reduced-motion
       restored in the script (the helper handles that branch). */
    transform: scaleX(0);
    transform-origin: left center;
  }
  /* Signature — one step up the scale (Stephane 2026-05-24):
     1.2/2vw/1.5rem → 1.4/2.4vw/1.75rem. Stays smaller than the
     tagline; tagline keeps its size-protagonist role. */
  .hero__signature {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 300;
    font-size: clamp(1.4rem, 2.4vw, 1.75rem);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-display);
    color: var(--ink);
    margin: 0 0 var(--space-5) 0;
  }
  .hero__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    line-height: 1.05;
    color: var(--ink);
    margin: 0;
    max-width: 22ch;
  }

  /* Image column — existing isolated-cigar PNG (alpha channel),
     centred in its grid cell, no frame. Soft directional drop
     shadow stands in for the old gold border — matches the home
     slider's floating-cigar shadow register. */
  .hero__media {
    display: grid;
    place-items: center;
  }
  .hero__cigar {
    width: auto;
    max-width: 78%;
    max-height: 72vh;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 24px 40px rgba(31, 27, 23, 0.18));
  }

  @media (prefers-reduced-motion: reduce) {
    /* Reduced-motion: the rule renders at its resting (full-width)
       state immediately. The reveal script also no-ops under the
       helper's REDUCED branch, so a CSS-level fallback here keeps
       things sane if the script never runs at all. */
    .hero__rule {
      transform: scaleX(1);
    }
  }

  /* ── 2. The cigar ──────────────────────────────────────────── */
  .cigar__inner {
    max-width: 880px;
    margin-inline: auto;
  }
  .cigar__eyebrow {
    margin-bottom: var(--space-7);
  }
  .cigar__narrative {
    max-width: 720px;
    margin-inline: auto;
  }
  .cigar__para {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    /* Matched to .smoke__note (2026-05-23) so the cigar narrative
       reads at the same register as the tasting notes. */
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0;
  }
  /* Intro — Hanken body register, punchier than the italic Spectral
     run that follows (Stephane 2026-05-24). Sits at body size with
     body line-height so it reads declaratively; the italic
     paragraphs underneath carry the slower, editorial cadence. */
  .cigar__intro {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 400;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink);
    margin: 0;
  }
  /* Shared paragraph rhythm — any narrative paragraph (intro or
     italic) inherits the same gap from its predecessor. */
  .cigar__intro + .cigar__para,
  .cigar__para + .cigar__para {
    margin-top: var(--space-5);
  }

  /* Spec list — two columns at desktop, stacked on mobile. Split
     into two blocks of six (Stephane 2026-05-24); each block carries
     its own full-width gold rule between the title and the first
     spec row, so the visual order is title → rule → first spec row.
     The rule lives on .cigar__strip (border-top); the title carries
     only the gap (margin-bottom) that separates it from the rule. */
  /* Font treatment matched to THE CIGAR eyebrow (.eyebrow in base.css)
     per Stephane 2026-05-24: weight 400→600, letter-spacing --ls-eyebrow
     →--ls-section, color --gold-deep→--accent-strong. font-family,
     font-size and text-transform were already aligned. Title→rule gap
     (margin-bottom: --space-3) preserved — .cigar__eyebrow's --space-7
     bottom margin governs eyebrow→narrative spacing, a different beat
     and not mirrored here. */
  .cigar__strip-title {
    margin: clamp(var(--space-7), 6vw, var(--space-8)) 0 var(--space-3) 0;
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--accent-strong);
  }
  /* Second title — same grammar, smaller top gap so the two blocks
     sit closer together than the first block does to the narrative. */
  .cigar__strip-title--second {
    margin-top: clamp(var(--space-5), 3vw, var(--space-6));
  }
  .cigar__strip {
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--border-gold);
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(var(--space-6), 5vw, var(--space-9));
    row-gap: 0;
  }
  .cigar__strip-row {
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) 1fr;
    gap: var(--space-5);
    align-items: baseline;
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--border-gold);
  }
  /* Block 1's last two rows (Smoke time + Release) drop their bottom
     hairline — the full-width gold rule above block 2 already serves
     as the visual break, so the per-row line under block 1's last row
     reads as a duplicate. (Stephane 2026-05-24.) Block 2's rows keep
     their hairlines so the spec list still reads as a tabulated set,
     including the final row which terminates against the page below. */
  .cigar__strip:not(.cigar__strip--second) > .cigar__strip-row:nth-last-child(-n+2) {
    border-bottom: 0;
  }
  .cigar__strip-label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--gold-deep);
    margin: 0;
  }
  .cigar__strip-value {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--ink);
    margin: 0;
    line-height: var(--lh-snug);
    /* Honour newlines embedded in JSON spec values (Binder, Filler,
       Construction). Whitespace within a run still collapses; only
       \n breaks render as line breaks. (Stephane 2026-05-24.) */
    white-space: pre-line;
  }

  /* ── 4. Presentation ──────────────────────────────────────────
     Pearl bed — anchors the page's lower compositional pause and
     mirrors the hero's pearl ground at the top. Smoke arc above
     stays on the default white, so the sequence reads pearl →
     white → white → pearl → footer (the footer itself is
     component-owned pearl), one continuous editorial sheet
     with two warmed beds at the two compositional pauses. */
  .packaging {
    background: var(--pearl);
  }
  .packaging__inner {
    text-align: center;
  }
  .packaging__eyebrow {
    margin-bottom: var(--space-5);
  }
  .packaging__lede {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: var(--lh-loose);
    color: var(--ink);
    max-width: 44ch;
    margin: 0 auto var(--space-7) auto;
  }
  .packaging__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(var(--space-5), 4vw, var(--space-7));
    text-align: left;
  }
  .placeholder--square {
    aspect-ratio: 1 / 1;
  }
  @media (max-width: 720px) {
    .packaging__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Placeholder grammar (page-scoped, used by section 4) ──
     Same primitives as the components — kept inline here so the
     packaging grid doesn't depend on a shared partial. If a fourth
     placeholder use lands, extract. */
  .placeholder {
    position: relative;
    margin: 0;
    background: var(--white);
    border: 1px dashed var(--gold-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(var(--space-5), 4vw, var(--space-7));
  }
  .placeholder__caption {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-snug);
    letter-spacing: 0.02em;
    color: var(--gold-deep);
    text-align: center;
    max-width: 32ch;
  }
  .placeholder__corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--gold-deep);
  }
  .placeholder__corner--tl { top: -1px;  left: -1px;  border-right: 0; border-bottom: 0; }
  .placeholder__corner--tr { top: -1px;  right: -1px; border-left: 0;  border-bottom: 0; }
  .placeholder__corner--bl { bottom: -1px; left: -1px;  border-right: 0; border-top: 0; }
  .placeholder__corner--br { bottom: -1px; right: -1px; border-left: 0;  border-top: 0; }

  /* ── Mobile collapse ───────────────────────────────────────── */
  @media (max-width: 720px) {
    .hero {
      min-height: 0;
      padding-block: clamp(var(--space-7), 12vw, var(--space-9));
    }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }
    /* On mobile, restore image-above-type reading order — flex
       order on .hero__copy keeps tagline-above-signature; the
       outer grid handles media-vs-copy stacking. */
    .hero__media {
      order: -1;
    }
    .hero__cigar {
      max-width: 65vw;
      max-height: 60vh;
    }
    .cigar__strip {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  /* Section reveals — restrained editorial entry. Each block's
     animatable children rise-and-fade as it scrolls into view.
     Reveals for the componentised sections (smoke) are handled
     inside the components themselves. */
  import { reveal, refreshOnLoad, gsap } from '../lib/motion';

  // Hero — Option A cascade.
  //   Copy column rises as a single composed unit; cigar image
  //   fades and lifts alongside; the gold hairline draws in from
  //   left to right on its own scrollTrigger so the visual order
  //   reads as eyebrow → rule (drawing) → tagline → signature.
  const heroMedia = document.querySelector<HTMLElement>('.hero [data-reveal-media]');
  const heroCopy  = document.querySelector<HTMLElement>('.hero [data-reveal-copy]');
  const heroRule  = document.querySelector<HTMLElement>('.hero__rule');
  if (heroCopy)  reveal(heroCopy,  { y: 28, duration: 0.95, start: 'top 88%' });
  if (heroMedia) reveal(heroMedia, { y: 24, duration: 1.1, delay: 0.1, start: 'top 88%' });
  if (heroRule) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      gsap.set(heroRule, { scaleX: 1 });
    } else {
      gsap.to(heroRule, {
        scaleX: 1,
        duration: 0.6,
        delay: 0.25,
        ease: 'power2.out',
        scrollTrigger: { trigger: heroCopy ?? heroRule, start: 'top 88%', toggleActions: 'play none none none' },
      });
    }
  }

  // Section 2 (cigar) — narrative paragraphs cascade, spec strips lift in.
  const cigarParas = document.querySelectorAll('.cigar [data-reveal-para]');
  const cigarStrips = document.querySelectorAll<HTMLElement>('.cigar [data-reveal-strip]');
  if (cigarParas.length) reveal(cigarParas, { y: 22, duration: 0.9, stagger: 0.14, start: 'top 82%' });
  if (cigarStrips.length) reveal(cigarStrips, { y: 24, duration: 0.9, stagger: 0.1, start: 'top 82%' });

  // Section 4 (presentation) — packaging slots fade in as a block.
  const packs = document.querySelectorAll('.packaging [data-reveal-pack]');
  if (packs.length) reveal(packs, { y: 22, duration: 0.85, stagger: 0.12, start: 'top 84%' });

  refreshOnLoad();
</script>
