---
/* SignatureBlock — the gold-leaf differentiator section.
   ------------------------------------------------------------------
   Section 2 of a SKU page (per the Volage redesign brief). One short
   display-italic line + one supporting paragraph, paired with a
   landscape macro of the gold leaf on the cigar. Pearl bed, generous
   block padding, a gold-deep hairline under the lede.

   Image handling: if `image` is supplied (an `ImageMetadata` from
   astro:assets, imported by the caller), it renders through <Image>.
   If not, a labelled placeholder box renders in its place — dashed
   gold-deep border, caption inside, so reviewers see at a glance
   what needs to be commissioned.

   Componentised so Caprice can drop in its own copy + image later. */

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  lede: string;
  paragraph: string;
  /* Macro shot of gold leaf on the cigar. When undefined, a labelled
     placeholder renders. */
  image?: ImageMetadata;
  /* Alt text for the photo (or, on a placeholder, the caption text
     itself is used so screen readers still announce the brief). */
  alt?: string;
  /* Visible caption rendered inside the placeholder box when no
     image is supplied. Always present so the brief is legible. */
  placeholderCaption?: string;
}

const { lede, paragraph, image, alt, placeholderCaption } = Astro.props;
---

<section class="signature" aria-label="The signature" data-reveal-section>
  <div class="signature__inner container">
    <div class="signature__copy" data-reveal-copy>
      <p class="signature__lede">{lede}</p>
      <p class="signature__para">{paragraph}</p>
    </div>

    <div class="signature__media" data-reveal-media>
      {image ? (
        <Image
          class="signature__image"
          src={image}
          alt={alt ?? lede}
          widths={[480, 720, 1080]}
          sizes="(max-width: 720px) 90vw, 48vw"
          loading="lazy"
        />
      ) : (
        <figure class="placeholder" aria-label={placeholderCaption ?? 'Image placeholder'}>
          <span class="placeholder__corner placeholder__corner--tl" aria-hidden="true"></span>
          <span class="placeholder__corner placeholder__corner--tr" aria-hidden="true"></span>
          <span class="placeholder__corner placeholder__corner--bl" aria-hidden="true"></span>
          <span class="placeholder__corner placeholder__corner--br" aria-hidden="true"></span>
          <figcaption class="placeholder__caption">
            {placeholderCaption ?? 'PLACEHOLDER: image required.'}
          </figcaption>
        </figure>
      )}
    </div>
  </div>
</section>

<style>
  /* Pearl bed, generous block padding. Same rhythm as the home
     lifestyle section. */
  .signature {
    background: var(--pearl);
    padding-block: clamp(var(--space-8), 9vw, var(--space-10));
  }
  .signature__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-7), 7vw, var(--space-10));
    align-items: center;
  }

  /* Copy column ─────────────────────────────────────────────── */
  .signature__copy {
    max-width: 36ch;
  }
  /* The lede — italic display, the line that has to land first. */
  .signature__lede {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 3.4vw, 2.2rem);
    line-height: var(--lh-snug);
    color: var(--ink);
    margin: 0;
    /* Gold-deep hairline rule under the lede — the conventions overlay's
       divider grammar. */
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--gold-deep);
  }
  .signature__para {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--ink-soft);
    margin: var(--space-6) 0 0 0;
  }

  /* Media / placeholder column ─────────────────────────────── */
  .signature__media {
    position: relative;
  }
  .signature__image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--border-gold);
  }

  /* Placeholder — dashed gold-deep border, caption centred, label
     read at a glance. Same treatment used across every placeholder
     slot on the page so absent shots are uniformly legible. */
  .placeholder {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    background: var(--white);
    border: 1px dashed var(--gold-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(var(--space-5), 4vw, var(--space-7));
  }
  .placeholder__caption {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-snug);
    letter-spacing: 0.02em;
    color: var(--gold-deep);
    text-align: center;
    max-width: 36ch;
  }
  /* Four small corner ticks — visual cue that this is a marked-out
     slot, not a finished frame. Pure decoration, hidden from AT. */
  .placeholder__corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--gold-deep);
  }
  .placeholder__corner--tl { top: -1px;  left: -1px;  border-right: 0; border-bottom: 0; }
  .placeholder__corner--tr { top: -1px;  right: -1px; border-left: 0;  border-bottom: 0; }
  .placeholder__corner--bl { bottom: -1px; left: -1px;  border-right: 0; border-top: 0; }
  .placeholder__corner--br { bottom: -1px; right: -1px; border-left: 0;  border-top: 0; }

  @media (max-width: 720px) {
    .signature__inner {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }
    .signature__copy {
      max-width: none;
    }
  }
</style>

<script>
  /* Section reveal — copy + media rise on enter, slight stagger.
     Reduced-motion handled by the helper. */
  import { reveal } from '../lib/motion';

  const copy  = document.querySelector<HTMLElement>('.signature [data-reveal-copy]');
  const media = document.querySelector<HTMLElement>('.signature [data-reveal-media]');
  if (copy)  reveal(copy,  { y: 26, duration: 0.95, start: 'top 84%' });
  if (media) reveal(media, { y: 30, duration: 1, delay: 0.12, start: 'top 84%' });
</script>
