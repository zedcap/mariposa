---
/* About — live editorial page.
   ------------------------------------------------------------------
   Promoted from src/pages/about-editorial-mocks.astro (Option A:
   issue masthead with four beats and one pull quote, founder as the
   closing feature) on 2026-05-25 with Stephane's amends:
     · Masthead copy rewritten (Mariposa · Origins / A Cuban Heritage
       Reborn in Volcanic Earth / Havana-seed standfirst).
     · Roman numerals dropped — section titles are the only anchor.
     · Drop cap on every Origins beat, sized to span ~3 lines.
     · Beat titles replaced: A Singular Pursuit, Volcanic Terroir,
       A Three-Year Journey, Uncompromising Craftsmanship.
     · Mock ribbon removed.
   Origins body copy and founder paragraphs remain verbatim from
   `mariposa cigars copy.docx`. */

import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/path';

import beat1Atmosphere from '../assets/hero-mp-1.jpg';
import beat3Atmosphere from '../assets/hero-mp-3.jpg';
import szSmoking from '../assets/sz_smoking_2.jpg';

/* ─── Origins copy — verbatim, body unchanged from mock ────── */

const beat1Title = 'A Singular Pursuit';
const beat1Body =
  "Mariposa is hand-rolled in Jember, East Java. A region whose rich cigar-making heritage dates back to 1859. It is also home to Pak Abdul Kahar Muzakir, a cigar aficionado and industry veteran who has dedicated his life to a singular pursuit: capturing the essence of Cuban tradition by cultivating Havana seeds in Indonesian soil.";

const beat2Title = 'Volcanic Terroir';
const beat2Body =
  "The wrapper, binder, and filler are all born from Havana-seed tobacco that has spent nearly two decades acclimatizing to Jember's volcanic earth. The result is a perfect marriage of flavor profiles, blending the distinct spice and oiliness of Cuban genetics with Java's native earthy sweetness.";

const beat3Title = 'A Three-Year Journey';
const beat3Body =
  "Patience is central to the craft. In keeping with the strict standards of Cuba's escogida, each leaf type is meticulously sorted and fermented for 24 months, then rested for another twelve. That is nearly three years from leaf to finished cigar, a slow maturation that yields rich flavors and an undeniably smooth smoke.";

const beat4Title = 'Uncompromising Craftsmanship';
const beat4Body =
  "Mariposa cigars are entirely hand-rolled by a dedicated team of female rollers, mirroring Cuba's revered torcedoras, many of whom come from families that have worked tobacco for generations. Using premium long-filler, three-part construction, and entubado bunching for a perfectly even draw, each cigar is finished with a classic Cuban triple cap. Every single stick is draw-tested and inspected by hand before it leaves the workshop, guaranteeing a flawless smoking experience.";

/* ─── Founder copy — verbatim. Three uniform paragraphs.
       The Havana-seed sentence is LIFTED from paragraph 3 of the
       original copy and rendered as the closing pull quote. */

const storyParas = [
  "Mariposa's story begins with a journey. Driven by a lifelong taste for cigars, founder Stephane Zermatten followed his curiosity to the tobacco fields of East Java.",
  "What he discovered inspired him to craft a blend for his own humidor and closest friends. Yet, as word spread and a wider circle grew curious, he knew it couldn't remain a private reserve. The brand was born to bring this unique cigar to a growing community in Bali and beyond.",
  "Today, Mariposa captures the rich, multi-cultural soul of cigars, giving friends around the world the perfect excuse to light up, slow down, and share a good conversation. Whatever the hour.",
];
const closingQuote =
  "\"Life isn't meant to be spent waiting for special occasions; it is about creating them on any ordinary day. The gold leaf on each Mariposa is my personal reminder to pause, slow down, and truly savour the hours shared with friends.\"";

const founderStandfirst =
  "What began as a founder's personal journey into the tobacco fields of East Java evolved into an exclusive blend made for close friends. Today, Mariposa brings that private reserve spirit with global friends around the world.";

/* ─── Placeholder captions (un-commissioned beats) ─────────── */
const capBeat2 =
  'PLACEHOLDER: Havana-seed nursery — leaf detail or tobacco on volcanic soil. Landscape 4:3, half-column inset, floated right.';
const capBeat4 =
  'PLACEHOLDER: Jember rolling room — torcedoras at work, hands and leaf. Landscape 4:3, half-column inset, floated left.';

const placeholderNote = 'Placeholder atmosphere — final shot to be commissioned';
---

<BaseLayout title="Mariposa • About">

  <article class="about-ed">

    {/* ── Issue masthead ─────────────────────────────────────── */}
    <header class="about-ed__masthead" data-reveal>
      <p class="about-ed__masthead-eyebrow">Mariposa &middot; Origins</p>
      <h1 class="about-ed__masthead-headline">A Cuban Heritage Reborn in Volcanic Earth</h1>
      <p class="about-ed__masthead-standfirst">Cultivated from Havana seeds nurtured for two decades in East Java, Mariposa is rooted in classic craftsmanship. Hand-rolled by female rollers, each cigar blends the rich complexity of Cuban heritage with the sweet depth of volcanic soil.</p>
      <span class="about-ed__masthead-rule" aria-hidden="true"></span>
    </header>

    {/* ── Beat 1 — A Singular Pursuit. Column-width landscape. ── */}
    <section class="about-ed__beat" aria-label="A Singular Pursuit" data-reveal>
      <h2 class="about-ed__beat-title">{beat1Title}</h2>
      <p class="about-ed__body about-ed__body--dropcap">{beat1Body}</p>
      <figure class="about-ed__figure about-ed__figure--column">
        <Image
          src={beat1Atmosphere}
          alt="Atmospheric placeholder standing in for the Argopuro range, East Java — final shot to be commissioned."
          class="about-ed__img"
          widths={[720, 1080, 1440, 1800]}
          sizes="(max-width: 720px) 100vw, 720px"
          loading="eager"
        />
        <p class="about-ed__placeholder-note">{placeholderNote}</p>
        <figcaption class="about-ed__caption">Argopuro range, East Java.</figcaption>
      </figure>
    </section>

    {/* ── Beat 2 — Volcanic Terroir. Half-column 4:3 inset photograph, floated right. ── */}
    <section class="about-ed__beat about-ed__beat--inset" aria-label="Volcanic Terroir" data-reveal>
      <h2 class="about-ed__beat-title">{beat2Title}</h2>
      <figure class="about-ed__figure about-ed__figure--inset about-ed__figure--inset-right">
        <img
          src={withBase('/origins-volcanic.jpg')}
          alt="Young tobacco plants growing under shade tents in East Java."
          class="about-ed__figure-inset-img"
          loading="lazy"
        />
      </figure>
      <p class="about-ed__body about-ed__body--dropcap">{beat2Body}</p>
      <p class="about-ed__caption about-ed__caption--inset">Havana-seed leaf, Jember nursery.</p>
    </section>

    {/* ── Beat 3 — A Three-Year Journey. Column-width 3:2 landscape. ── */}
    <section class="about-ed__beat" aria-label="A Three-Year Journey" data-reveal>
      <h2 class="about-ed__beat-title">{beat3Title}</h2>
      <p class="about-ed__body about-ed__body--dropcap">{beat3Body}</p>
      <figure class="about-ed__figure about-ed__figure--column">
        <Image
          src={beat3Atmosphere}
          alt="Atmospheric placeholder standing in for the escogida / ageing-room shot — final shot to be commissioned."
          class="about-ed__img"
          widths={[720, 1080, 1440, 1800]}
          sizes="(max-width: 720px) 100vw, 720px"
        />
        <p class="about-ed__placeholder-note">{placeholderNote}</p>
        <figcaption class="about-ed__caption">Escogida fermentation &mdash; month 4 / month 22.</figcaption>
      </figure>
    </section>

    {/* ── Beat 4 — Uncompromising Craftsmanship. Half-column 4:3 inset placeholder, floated left (mirror of beat 2). ── */}
    <section class="about-ed__beat about-ed__beat--inset" aria-label="Uncompromising Craftsmanship" data-reveal>
      <h2 class="about-ed__beat-title">{beat4Title}</h2>
      <figure class="about-ed__figure about-ed__figure--inset about-ed__figure--inset-left placeholder placeholder--4x3" aria-label="Jember rolling-room placeholder">
        <span class="placeholder__corner placeholder__corner--tl" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--tr" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--bl" aria-hidden="true"></span>
        <span class="placeholder__corner placeholder__corner--br" aria-hidden="true"></span>
        <figcaption class="placeholder__caption">{capBeat4}</figcaption>
      </figure>
      <p class="about-ed__body about-ed__body--dropcap">{beat4Body}</p>
      <p class="about-ed__caption about-ed__caption--inset">Photograph: [Name] &mdash; Jember rolling room, 2026.</p>
    </section>

    {/* ── Origins → Founder transition. Bridge quote panel
           (Treatment 3 with pink top hairline) replaces the former
           pink hairline divider; eyebrow follows below. ── */}
    <div class="about-ed__transition" data-reveal>
      <aside class="about-ed__bridge-panel">
        <p class="about-ed__bridge-quote">{closingQuote}</p>
      </aside>
      <p class="about-ed__transition-eyebrow">From Private Reserve to Shared Passion</p>
    </div>

    {/* ── Founder feature. Three uniform paragraphs, half-column
           portrait before paragraph 1. No closing element — the
           bridge quote above absorbed that role. ── */}
    <section class="about-ed__feature" aria-label="The Founder" data-reveal>
      <p class="about-ed__feature-standfirst">{founderStandfirst}</p>

      <figure class="about-ed__feature-figure">
        <Image
          src={szSmoking}
          alt="Portrait of founder Stephane Zermatten lighting a Mariposa cigar."
          class="about-ed__feature-img"
          widths={[360, 540, 720, 960]}
          sizes="(max-width: 720px) 100vw, 320px"
          loading="lazy"
        />
        <figcaption class="about-ed__caption about-ed__caption--feature">
          Stephane Zermatten &middot; Jember, East Java.
        </figcaption>
      </figure>

      <p class="about-ed__feature-body">{storyParas[0]}</p>
      <p class="about-ed__feature-body">{storyParas[1]}</p>
      <p class="about-ed__feature-body">{storyParas[2]}</p>
    </section>

  </article>

</BaseLayout>

<script>
  import { reveal, refreshOnLoad } from '../lib/motion';
  const blocks = document.querySelectorAll('[data-reveal]');
  blocks.forEach((b) => reveal(b));
  refreshOnLoad();
</script>

<style>
  /* ═══════════════════════════════════════════════════════════
     Article shell. White ground throughout — uniformity of
     ground is part of the editorial logic.
     ═══════════════════════════════════════════════════════════ */
  .about-ed {
    background: var(--white);
    color: var(--ink);
    /* Single centred article column. Masthead, transition, and
       full-bleed figures break out wider; everything else lives
       at this measure. */
    --col: 720px;
  }
  .about-ed > .about-ed__masthead,
  .about-ed > .about-ed__beat,
  .about-ed > .about-ed__transition,
  .about-ed > .about-ed__feature {
    width: 100%;
    /* border-box (inherited site default). max-width absorbs the
       horizontal padding so the content measure stays at --col while
       the rendered box never exceeds the viewport — the previous
       content-box override caused horizontal scroll between 720px
       and 912px viewports (width:100% + 192px padding) and a ~48px
       overflow on mobile (width:100% + 48px padding). */
    max-width: calc(var(--col) + 2 * var(--page-pad-d));
    margin-inline: auto;
    padding-inline: var(--page-pad-d);
  }

  /* ═══════════════════════════════════════════════════════════
     Masthead — issue eyebrow, display headline, standfirst,
     gold-leaf hairline.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__masthead {
    text-align: center;
    padding-top: clamp(calc(var(--space-9) * 0.8), 9.6vw, calc(var(--space-10) * 0.8));
    padding-bottom: clamp(calc(var(--space-9) * 0.75), 9vw, calc(var(--space-10) * 0.75));
  }
  .about-ed__masthead-eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-section);
    color: var(--gold-deep);
    margin: 0 0 var(--space-6) 0;
  }
  .about-ed__masthead-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: var(--lh-tight);
    color: var(--ink);
    margin: 0 auto var(--space-6) auto;
    max-width: 18ch;
    letter-spacing: var(--ls-display);
  }
  .about-ed__masthead-standfirst {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    margin: 0 auto var(--space-7) auto;
    max-width: 56ch;
  }
  .about-ed__masthead-rule {
    display: block;
    width: 80px;
    height: 1px;
    background: var(--pink);
    margin: 0 auto;
  }

  /* ═══════════════════════════════════════════════════════════
     Beats — single centred article column. Each beat opens with
     a section title (no roman numerals; title is the only
     structural anchor). Then body + figure per beat's variant.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__beat {
    padding-block: clamp(var(--space-8), 9vw, var(--space-9));
  }
  /* First beat — tighten gap above by 25% (paired with the
     masthead's reduced padding-bottom). Hard-coded value approved
     by Stephane; unchanged when subsequent beats' top space was
     halved. */
  .about-ed__beat:first-of-type {
    padding-top: clamp(calc(var(--space-8) * 0.75), 6.75vw, calc(var(--space-9) * 0.75));
  }
  /* Beats 2-4 — halve the space above to tighten the article's
     mid-cadence. padding-bottom inherited from the base rule
     keeps the trailing inter-beat rhythm untouched. */
  .about-ed__beat:not(:first-of-type) {
    padding-top: clamp(calc(var(--space-8) * 0.5), 4.5vw, calc(var(--space-9) * 0.5));
  }
  /* Section title — Spectral italic, gold-deep family removed in
     favour of ink for legibility against the gold drop cap;
     consistent typography across all four beats. */
  .about-ed__beat-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: var(--lh-tight);
    color: var(--ink);
    margin: 0 0 var(--space-6) 0;
    letter-spacing: var(--ls-display);
  }
  .about-ed__body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0;
  }
  /* Drop cap — applied to every Origins beat. Spectral italic,
     gold-deep, sized to span ~3 lines of body text.
     Math: body line-height is var(--lh-loose) ≈ 1.75 × var(--fs-body)
     (= ~1.75rem). Three lines ≈ 5.25rem. Setting font-size at
     5rem (clamp upper bound) with line-height 0.82 yields a glyph
     box roughly 3× the body line, so the float wraps 3 lines to
     the right before resuming full-width on line 4. */
  .about-ed__body--dropcap::first-letter {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--gold-deep);
    font-size: clamp(5.265rem, 8.19vw, 6.435rem);
    line-height: 0.82;
    float: left;
    padding-right: var(--space-3);
    padding-top: 0.06em;
  }

  /* ═══════════════════════════════════════════════════════════
     Figures.
       --column      : sits at article-column width below the body.
       --inset       : half-column, 4:3, floated. Side via the
                       --inset-right / --inset-left modifier.
                       Used at beats 2 and 4.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__figure {
    margin: var(--space-7) 0 0 0;
  }
  .about-ed__figure--column {
    position: relative;
  }
  .about-ed__figure--column .about-ed__img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--pearl);
  }
  /* Beat 3 leans slightly taller — 3:2. */
  .about-ed__beat:nth-of-type(3) .about-ed__figure--column .about-ed__img {
    aspect-ratio: 3 / 2;
  }

  /* Inset figure — beats 2 and 4. Half-column width, 4:3 landscape.
     Float side set by the directional modifier so beats 2 and 4
     alternate (right / left). 1px pink hairline frame as the
     editorial slot frame for real photographs. Placeholders keep
     their dashed-gold border (rule further down) — the `.placeholder`
     class shares this wrapper but overrides the border so the
     pending-shot reading stays intact. Same slot, different state. */
  .about-ed__figure--inset {
    width: min(48%, 320px);
    aspect-ratio: 4 / 3;
    border: 1px solid var(--pink);
    box-sizing: border-box;
    overflow: hidden;
  }
  /* Real-photo inset img — fills the 4:3 frame, crops to fit so
     non-4:3 sources don't distort. */
  .about-ed__figure-inset-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  /* Placeholder + inset together — restore the dashed-gold border
     on the placeholder variant so beat 4 still reads as pending.
     This wins because the selector is more specific than the
     wrapper rule above. */
  .about-ed__figure--inset.placeholder {
    border: 1px dashed var(--gold-deep);
    overflow: visible;
  }
  .about-ed__figure--inset-right {
    float: right;
    margin: var(--space-2) 0 var(--space-5) var(--space-6);
  }
  .about-ed__figure--inset-left {
    float: left;
    margin: var(--space-2) var(--space-6) var(--space-5) 0;
  }
  .about-ed__caption--inset {
    clear: both;
    margin-top: var(--space-4);
    text-align: right;
  }

  /* Captions — italic Hanken, gold-deep, small. */
  .about-ed__caption {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-style: italic;
    letter-spacing: var(--ls-small);
    color: var(--gold-deep);
    margin: var(--space-3) 0 0 0;
  }

  /* Placeholder note overlay. */
  .about-ed__placeholder-note {
    position: absolute;
    top: clamp(var(--space-3), 2vw, var(--space-4));
    left: clamp(var(--space-3), 2vw, var(--space-4));
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--ls-section);
    text-transform: uppercase;
    color: var(--gold-leaf);
    background: color-mix(in srgb, var(--ink) 55%, transparent);
    padding: 4px 10px;
    margin: 0;
    max-width: 28ch;
    z-index: 2;
  }

  /* ═══════════════════════════════════════════════════════════
     Origins → Founder transition.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__transition {
    text-align: center;
    /* Top gap reduced 25% twice (Stephane) — 0.75 × 0.75 = 0.5625. Bottom halved twice (Stephane) — pairs with .about-ed__feature padding-top halving to quarter the eyebrow → standfirst gap. */
    padding-top: clamp(calc(var(--space-8) * 0.5625), 5.625vw, calc(var(--space-9) * 0.5625));
    padding-bottom: clamp(calc(var(--space-8) * 0.25), 2.5vw, calc(var(--space-9) * 0.25));
  }
  /* Bridge quote panel — Treatment 3 from /about-quote-mocks
     (cream/pearl panel, Spectral italic gold-deep type, centred,
     hairlines top + bottom), with one modification: TOP hairline
     is --pink (this page only), BOTTOM stays --gold-deep. Sits
     between the last Origins beat and the eyebrow that follows.
     Bottom margin matches the new bridge-ABOVE expression exactly
     (identical clamp) so the panel stays symmetric if tokens change. */
  .about-ed__bridge-panel {
    clear: both;
    margin: 0 0 clamp(calc(var(--space-8) * 0.5625), 5.625vw, calc(var(--space-9) * 0.5625)) 0;
    background: var(--pearl);
    border-top: 1px solid var(--pink);
    border-bottom: 1px solid var(--gold-deep);
    padding-block: var(--space-7);
    padding-inline: var(--space-5);
  }
  .about-ed__bridge-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: var(--lh-snug);
    color: var(--gold-deep);
    margin: 0 auto;
    text-align: center;
    max-width: 48ch;
  }
  .about-ed__transition-eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-section);
    color: var(--gold-deep);
    margin: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     Founder feature.
     ═══════════════════════════════════════════════════════════ */
  .about-ed__feature {
    /* Bottom gap below pull quote reduced 50% (Stephane). Top halved twice (Stephane) — 0.5 × 0.5 = 0.25 — pairs with .about-ed__transition padding-bottom (now 0.25) to halve the eyebrow → standfirst gap again. */
    padding-block: clamp(calc(var(--space-7) * 0.25), 2vw, calc(var(--space-9) * 0.25)) clamp(calc(var(--space-9) * 0.5), 6vw, calc(var(--space-10) * 0.5));
  }
  .about-ed__feature-standfirst {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: var(--lh-snug);
    color: var(--ink-soft);
    margin: 0 0 var(--space-7) 0;
    max-width: 56ch;
  }
  .about-ed__feature-figure {
    float: right;
    /* Width scaled 0.75× (Stephane) — portrait floats over ~2 paragraphs not 3. */
    width: min(36%, 240px);
    margin: var(--space-1) 0 var(--space-5) var(--space-6);
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .about-ed__feature-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .about-ed__caption--feature {
    margin-top: var(--space-3);
    text-align: left;
  }
  .about-ed__feature-body {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--ink);
    margin: 0 0 var(--space-5) 0;
  }
  .about-ed__feature-body:last-of-type {
    margin-bottom: 0;
  }

  /* ═══════════════════════════════════════════════════════════
     Placeholder grammar — same dashed-gold convention as the
     rest of the site.
     ═══════════════════════════════════════════════════════════ */
  .placeholder {
    position: relative;
    margin: 0;
    background: var(--white);
    border: 1px dashed var(--gold-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(var(--space-5), 4vw, var(--space-7));
  }
  .placeholder--4x3 { aspect-ratio: 4 / 3; }
  .placeholder__caption {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-snug);
    letter-spacing: 0.02em;
    color: var(--gold-deep);
    text-align: center;
    max-width: 32ch;
    margin: 0;
  }
  .placeholder__corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--gold-deep);
    z-index: 2;
  }
  .placeholder__corner--tl { top: -1px;    left: -1px;  border-right: 0; border-bottom: 0; }
  .placeholder__corner--tr { top: -1px;    right: -1px; border-left: 0;  border-bottom: 0; }
  .placeholder__corner--bl { bottom: -1px; left: -1px;  border-right: 0; border-top: 0; }
  .placeholder__corner--br { bottom: -1px; right: -1px; border-left: 0;  border-top: 0; }

  /* ═══════════════════════════════════════════════════════════
     Mobile — ≤720px. Drop cap kept on mobile: at clamp lower
